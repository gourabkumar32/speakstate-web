<%- include('partials/header') %>

<div class="min-h-screen flex items-center justify-center">
    <div class="bg-gray-800 rounded-lg shadow-lg border border-gray-700 p-8 max-w-md w-full">
        <h1 class="text-3xl font-bold text-red-400 mb-4">Error</h1>
        <p class="text-gray-300 mb-6"><%= typeof message !== 'undefined' ? message : (typeof error !== 'undefined' ? error : 'An unexpected error occurred') %></p>
        <a href="/" class="block text-center bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded transition duration-200">
            Return Home
        </a>
    </div>
</div>

<%- include('partials/footer') %>