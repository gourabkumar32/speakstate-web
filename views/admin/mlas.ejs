<%- include('../partials/header', { title: 'Manage MLAs' }) %>
<link rel="stylesheet" href="/css/style.css">

<div class="container bg-gray-800 p-6 rounded-lg shadow-lg">
    <h1 class="text-2xl font-bold mb-6 text-white">Manage MLAs</h1>

    <% if (success && success.length > 0) { %>
<div class="alert alert-success"><%= success %></div>
<% } %>
    <% if (error && error.length > 0) { %>
<div class="alert alert-danger"><%= error %></div>
<% } %>

    <!-- State Selection Form -->
    <div class="form-section bg-gray-700 p-6 rounded-lg mb-8">
        <h2 class="text-xl font-semibold mb-4 text-white">Select State</h2>
        <div class="form-group">
            <label for="selectedState" class="text-gray-300">State:</label>
            <select id="selectedState" class="w-full bg-gray-600 text-black rounded p-2 mt-1">
                <option value="">Select a state</option>
                <option value="Andhra Pradesh">Andhra Pradesh</option>
                <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                <option value="Assam">Assam</option>
                <option value="Bihar">Bihar</option>
                <option value="Chhattisgarh">Chhattisgarh</option>
                <option value="Delhi">Delhi</option>
                <option value="Goa">Goa</option>
                <option value="Gujarat">Gujarat</option>
                <option value="Haryana">Haryana</option>
                <option value="Himachal Pradesh">Himachal Pradesh</option>
                <option value="Jharkhand">Jharkhand</option>
                <option value="Karnataka">Karnataka</option>
                <option value="Kerala">Kerala</option>
                <option value="Madhya Pradesh">Madhya Pradesh</option>
                <option value="Maharashtra">Maharashtra</option>
                <option value="Manipur">Manipur</option>
                <option value="Meghalaya">Meghalaya</option>
                <option value="Mizoram">Mizoram</option>
                <option value="Nagaland">Nagaland</option>
                <option value="Odisha">Odisha</option>
                <option value="Punjab">Punjab</option>
                <option value="Rajasthan">Rajasthan</option>
                <option value="Sikkim">Sikkim</option>
                <option value="Tamil Nadu">Tamil Nadu</option>
                <option value="Telangana">Telangana</option>
                <option value="Tripura">Tripura</option>
                <option value="Uttar Pradesh">Uttar Pradesh</option>
                <option value="Uttarakhand">Uttarakhand</option>
                <option value="West Bengal">West Bengal</option>
            </select>
        </div>
    </div>

    <!-- Add MLA Form -->
    <div class="form-section bg-gray-700 p-6 rounded-lg mb-8" id="addMlaForm" style="display: none;">
        <h2 class="text-xl font-semibold mb-4 text-white">Add New MLA</h2>
        <form action="/admin/mlas" method="POST" enctype="multipart/form-data">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-group">
                    <label for="name" class="text-gray-300">Name:</label>
                    <input type="text" id="name" name="name" required 
                           class="w-full bg-gray-600 text-black rounded p-2 mt-1">
                </div>

                <div class="form-group">
                    <label for="constituency" class="text-gray-300">Constituency:</label>
                    <input type="text" id="constituency" name="constituency" required 
                           class="w-full bg-gray-600 text-black rounded p-2 mt-1">
                </div>

                <div class="form-group">
                    <label for="party" class="text-gray-300">Party:</label>
                    <input type="text" id="party" name="party" required 
                           class="w-full bg-gray-600 text-black rounded p-2 mt-1">
                </div>

                <div class="form-group">
                    <label for="image" class="text-gray-300">Image:</label>
                    <input type="file" id="image" name="image" accept="image/*" required 
                           class="w-full bg-gray-600 text-black rounded p-2 mt-1">
                </div>

                <!-- Hidden state input -->
                <input type="hidden" id="state" name="state">
            </div>
<!--
            <div class="form-group mt-4">
                <label for="description" class="text-gray-300">Description:</label>
                <textarea id="description" name="description" rows="4" 
                          class="w-full bg-gray-600 text-white rounded p-2 mt-1"></textarea>
            </div>
-->
            <button type="submit" class="mt-4 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
                Add MLA
            </button>
        </form>
    </div>

    <!-- MLA List -->
    <div class="mla-list">
        <h2 class="text-xl font-semibold mb-4 text-white">Current MLAs</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% mlas.forEach(mla => { %>
                <div class="bg-gray-700 rounded-lg overflow-hidden shadow-lg">
                    <img src="<%= (typeof mla.thumbnail !== 'undefined' ? mla.thumbnail : mla.image) %>" 
                        alt="<%= mla.name %>" loading="lazy" decoding="async" class="w-full h-48 object-cover">
                    <div class="p-4">
                        <h3 class="text-lg font-semibold text-white"><%= mla.name %></h3>
                        <p class="text-gray-300">Party: <%= mla.party %></p>
                        <p class="text-gray-300">State: <%= mla.state %></p>
                        <p class="text-gray-300">Constituency: <%= mla.constituency %></p>
                        <div class="flex gap-2 mt-4">
                            <button onclick="editMla('<%= mla._id %>')" 
                                    class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
                                Edit
                            </button>
                            <button onclick="deleteMla('<%= mla._id %>')" 
                                    class="flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded">
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<script>
document.getElementById('selectedState').addEventListener('change', function() {
    const stateValue = this.value;
    const addMlaForm = document.getElementById('addMlaForm');
    const stateInput = document.getElementById('state');
    
    if (stateValue) {
        // Show the form and set the state value
        addMlaForm.style.display = 'block';
        stateInput.value = stateValue;
    } else {
        // Hide the form if no state is selected
        addMlaForm.style.display = 'none';
        stateInput.value = '';
    }
});

// Store state selection in localStorage
document.getElementById('selectedState').addEventListener('change', function() {
    localStorage.setItem('selectedState', this.value);
});

// Load state selection from localStorage on page load
document.addEventListener('DOMContentLoaded', function() {
    const savedState = localStorage.getItem('selectedState');
    if (savedState) {
        const stateSelect = document.getElementById('selectedState');
        stateSelect.value = savedState;
        // Trigger change event to show/hide form
        stateSelect.dispatchEvent(new Event('change'));
    }
});

function editMla(id) {
    window.location.href = `/admin/mlas/${id}/edit`;
}

function deleteMla(id) {
    if (confirm('Are you sure you want to delete this MLA?')) {
        fetch(`/admin/mlas/${id}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                window.location.reload();
            } else {
                alert('Error deleting MLA');
            }
        });
    }
}
</script>
</body>
</html> 