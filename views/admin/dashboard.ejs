<script>
// Admin topics/news client logic
async function loadAdminStates() {
    try {
        const res = await fetch('/admin/states');
        const data = await res.json();
        if (!data.success) return;
        const select = document.getElementById('adminStateSelect');
        select.innerHTML = '';
        data.states.forEach(s => {
            const opt = document.createElement('option'); opt.value = s._id; opt.textContent = s.name; select.appendChild(opt);
        });
        // set change handler
        select.addEventListener('change', () => { renderStateTopics(select.value); });
        // load first
        if (data.states.length) {
            select.value = data.states[0]._id;
            renderStateTopics(data.states[0]._id);
        } else {
            document.getElementById('stateTopicsContainer').innerHTML = '<p class="text-gray-400">No states available.</p>';
        }
    } catch (err) {
        console.error('Failed to load admin states', err);
        showNotification('Failed to load states', 'error');
    }
}

async function renderStateTopics(stateId) {
    if (!stateId) return;
    try {
        // fetch full state doc from the public route
        const res = await fetch('/states/' + stateId);
        // that route returns HTML; instead fetch admin JSON by calling admin/states and find the state
        const adminRes = await fetch('/admin/states');
        const data = await adminRes.json();
        if (!data.success) return;
        const state = data.states.find(s => s._id === stateId);
        if (!state) return;
        const topics = state.topics || [];
        const container = document.getElementById('stateTopicsContainer');
        container.innerHTML = '';

        const ul = document.createElement('ul');
        ul.className = 'space-y-3';

        // Admin-created topics
        topics.forEach(t => {
            const li = document.createElement('li');
            li.className = 'bg-gray-700 rounded p-3 flex justify-between items-center';
            li.innerHTML = `<div><strong class="text-white">${t.name}</strong><div class="text-xs text-gray-400">${(t.infos||[]).length} news items</div></div>`;
            const actions = document.createElement('div');
            actions.innerHTML = `
                <button class="bg-blue-600 text-white px-3 py-1 rounded mr-2" onclick="openAddNews('${stateId}','${t._id}')">Add News</button>
                <button class="bg-gray-600 text-white px-3 py-1 rounded mr-2" onclick="editTopic('${stateId}','${t._id}','${encodeURIComponent(t.name)}')">Edit</button>
                <button class="bg-red-600 text-white px-3 py-1 rounded" onclick="deleteTopic('${stateId}','${t._id}')">Delete</button>
            `;
            li.appendChild(actions);
            ul.appendChild(li);
        });

        // Defaults not managed by admin
        const defaults = ['Corruption', 'Spending on Work', 'Work Promises', 'Done'];
        defaults.forEach(d => {
            if (!topics.find(tt => tt.name.toLowerCase() === d.toLowerCase())) {
                const li = document.createElement('li');
                li.className = 'bg-gray-800 rounded p-3 flex justify-between items-center';
                li.innerHTML = `<div><strong class="text-gray-200">${d}</strong><div class="text-xs text-gray-400">Default topic</div></div>`;
                const actions = document.createElement('div');
                actions.innerHTML = `
                    <button class="bg-green-600 text-white px-3 py-1 rounded" onclick="openAddTopicModal('${stateId}','${d.replace(/'/g,'')}')">Add as Admin Topic</button>
                `;
                li.appendChild(actions);
                ul.appendChild(li);
            }
        });

        container.appendChild(ul);
    } catch (err) {
        console.error(err);
        showNotification('Error rendering topics', 'error');
    }
}

function openAddTopicModal(stateId, defaultName) {
    document.getElementById('addTopicStateId').value = stateId;
    document.getElementById('addTopicName').value = defaultName || '';
    document.getElementById('addTopicModal').classList.remove('hidden');
}

function closeAddTopicModal() { document.getElementById('addTopicModal').classList.add('hidden'); }

async function submitAddTopic() {
    const stateId = document.getElementById('addTopicStateId').value;
    const name = document.getElementById('addTopicName').value.trim();
    if (!stateId || !name) return showNotification('State and topic name required', 'error');
    try {
        const res = await fetch(`/admin/states/${stateId}/topics`, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ name }) });
        const data = await res.json();
        if (data.success) {
            showNotification('Topic added', 'success');
            closeAddTopicModal();
            await loadAdminStates();
        } else throw new Error(data.message || 'Failed');
    } catch (err) { console.error(err); showNotification(err.message || 'Error adding topic','error'); }
}

function openAddNews(stateId, topicId) {
    document.getElementById('addNewsStateId').value = stateId;
    document.getElementById('addNewsTopicId').value = topicId;
    document.getElementById('addNewsForm').reset();
    document.getElementById('addNewsModal').classList.remove('hidden');
}
function closeAddNewsModal() { document.getElementById('addNewsModal').classList.add('hidden'); }

async function submitAddNews() {
    const stateId = document.getElementById('addNewsStateId').value;
    const topicId = document.getElementById('addNewsTopicId').value;
    const title = document.getElementById('addNewsTitle').value.trim();
    const content = document.getElementById('addNewsContent').value.trim();
    const url = document.getElementById('addNewsUrl').value.trim();
    if (!stateId || !topicId || !title) return showNotification('State/topic/title required','error');
    try {
        const res = await fetch(`/admin/states/${stateId}/topics/${topicId}/news`, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ title, content, url }) });
        const data = await res.json();
        if (data.success) { showNotification('News added', 'success'); closeAddNewsModal(); await loadAdminStates(); }
        else throw new Error(data.message || 'Failed');
    } catch (err) { console.error(err); showNotification(err.message || 'Error adding news','error'); }
}

async function editTopic(stateId, topicId, currentNameEncoded) {
    const currentName = decodeURIComponent(currentNameEncoded);
    document.getElementById('addTopicStateId').value = stateId;
    document.getElementById('addTopicName').value = currentName;
    document.getElementById('addTopicModal').classList.remove('hidden');
    // reuse add modal; on submit detect presence of topicId
    // temporarily override submitAddTopic to update
    const originalSubmit = submitAddTopic;
    window.submitAddTopic = async function() {
        try {
            const name = document.getElementById('addTopicName').value.trim();
            const res = await fetch(`/admin/states/${stateId}/topics/${topicId}`, { method: 'PUT', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ name }) });
            const data = await res.json();
            if (data.success) { showNotification('Topic updated','success'); closeAddTopicModal(); await loadAdminStates(); }
            else throw new Error(data.message || 'Failed');
        } catch (err) { console.error(err); showNotification(err.message || 'Error updating topic','error'); }
        // restore
        window.submitAddTopic = originalSubmit;
    };
}

async function deleteTopic(stateId, topicId) {
    if (!confirm('Delete this topic?')) return;
    try {
        const res = await fetch(`/admin/states/${stateId}/topics/${topicId}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) { showNotification('Topic deleted','success'); await loadAdminStates(); }
        else throw new Error(data.message || 'Failed');
    } catch (err) { console.error(err); showNotification(err.message || 'Error deleting topic','error'); }
}

// wire refresh and add buttons
document.getElementById('refreshStatesBtn').addEventListener('click', loadAdminStates);
document.getElementById('openAddTopicBtn').addEventListener('click', () => { const s = document.getElementById('adminStateSelect').value; openAddTopicModal(s); });
document.getElementById('adminStateSelect').addEventListener('change', () => {
    const s = document.getElementById('adminStateSelect').value;
    const link = document.getElementById('openFullEditorLink');
    link.href = `/admin/states/${s}/topics`;
});

// initial load
loadAdminStates();
</script>

<!-- Notification function -->
<script>
function showNotification(message, type = 'info') {
    // Create notification element
    const notification = document.createElement('div');
    notification.className = `fixed top-4 right-4 p-4 rounded-lg shadow-lg z-50 ${type === 'success' ? 'bg-green-600' : type === 'error' ? 'bg-red-600' : 'bg-blue-600'} text-white`;
    notification.textContent = message;
    
    // Add to DOM
    document.body.appendChild(notification);
    
    // Remove after 3 seconds
    setTimeout(() => {
        notification.classList.add('opacity-0', 'transition-opacity', 'duration-500');
        setTimeout(() => notification.remove(), 500);
    }, 3000);
}

// Function to add constituency to election creation form
function addConstituencyToElection() {
    // Check if this function was triggered by an event listener
    const isEventTriggered = typeof event !== 'undefined' && event instanceof Event;
    
    // If it's an event and not a direct function call, prevent duplicate execution
    if (isEventTriggered && event.target._isProcessing) {
        return;
    }
    
    // Mark the button as processing if this is an event
    if (isEventTriggered) {
        event.target._isProcessing = true;
        // Reset the flag after a short delay
        setTimeout(() => {
            if (event && event.target) {
                event.target._isProcessing = false;
            }
        }, 500);
    }
    
    const container = document.getElementById('createElectionConstituencies');
    const constituencyId = Date.now(); // Unique ID for the constituency
    
    const constituencyHtml = `
        <div class="constituency-block bg-gray-700 p-4 rounded-lg" data-constituency-id="${constituencyId}">
            <div class="flex justify-between items-center mb-4">
                <div class="flex-1">
                    <label class="block text-gray-300 text-sm font-bold mb-2">Constituency Name</label>
                    <input type="text" name="constituencies[${constituencyId}][name]" required
                           class="bg-gray-600 border border-gray-500 text-white rounded p-2 w-full">
                </div>
                <button type="button" onclick="removeConstituencyFromElection(${constituencyId})"
                        class="ml-4 text-red-400 hover:text-red-300">Remove</button>
            </div>
            
            <!-- Candidates Section -->
            <div class="mt-4">
                <h5 class="text-md font-semibold text-white mb-2">Candidates</h5>
                <div class="candidates-container space-y-4" data-constituency-id="${constituencyId}"></div>
                <button type="button" onclick="addCandidateToConstituency(${constituencyId})"
                        class="mt-4 bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm">
                    Add Candidate
                </button>
            </div>
        </div>
    `;
    
    container.insertAdjacentHTML('beforeend', constituencyHtml);
}

// Function to remove constituency from election creation form
function removeConstituencyFromElection(constituencyId) {
    const constituency = document.querySelector(`[data-constituency-id="${constituencyId}"]`);
    if (constituency) {
        constituency.remove();
    }
}

