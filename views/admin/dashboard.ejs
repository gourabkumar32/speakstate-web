<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/style.css">

<style>
  .text-3xl{
    margin-left: 20px;
  }
  .edit{
    margin-bottom: 200px;
  }

</style>
<div class="mb-8">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-white">Admin Dashboard</h1>
        <div class="flex space-x-4">
            <button onclick="showCreateElectionModal()" 
                    class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded transition duration-200">
                Create New Election
            </button>
            <button onclick="showAddConstituencyModal()" 
                    class="bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded transition duration-200">
                Add New Constituency
            </button>
            <button onclick="showAddStateModal()" 
                    class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded transition duration-200">
                Add New State
            </button>
        </div>
    </div>

    <!-- Stats Overview -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <h3 class="text-lg font-semibold text-gray-400 mb-2">Total Elections</h3>
            <p class="text-3xl font-bold text-white"><%= elections.length %></p>
        </div>
        <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <h3 class="text-lg font-semibold text-gray-400 mb-2">Active Elections</h3>
            <p class="text-3xl font-bold text-white"><%= elections.filter(e => e.isActive).length %></p>
        </div>
        <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <h3 class="text-lg font-semibold text-gray-400 mb-2">Total Votes</h3>
            <p class="text-3xl font-bold text-white"><%= elections.reduce((sum, e) => sum + e.totalVotes, 0) %></p>
        </div>
    </div>

   

    <!-- Elections List -->
    <div class="space-y-6">
        <% elections.forEach(election => { %>
            <div class="bg-gray-900 rounded-lg shadow-lg overflow-hidden">
                <div class="p-6">
                    <div class="flex justify-between items-center mb-4">
                        <div>
                            <h3 class="text-2xl font-bold text-white"><%= election.title %></h3>
                            <p class="text-gray-400">State: <%= election.state %></p>
                        </div>
                        <div class="flex space-x-4">
                            <button onclick="toggleElectionStatus('<%= election._id %>')"
                                    class="px-4 py-2 rounded-lg <%= election.isActive ?'bg-green-600 hover:bg-green-700' : 'bg-red-600 hover:bg-red-700' %> text-white">
                                       <%= election.isActive ? 'Active' : 'Inactive' %> 
                                      

                            </button>
                           <button onclick="deleteElection('<%= election._id %>')"
                            


                                    class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg">
                                Delete
                            </button>
                        </div>
                    </div>

                    <!-- Constituencies Section -->
                    <% election.constituencies.forEach(constituency => { %>
                        <div class="mt-6 bg-gray-800 rounded-lg p-4">
                            <h4 class="text-xl font-semibold text-white mb-4">
                                Constituency: <%= constituency.name %>
                            </h4>
                            
                            <!-- Candidates Grid -->
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                                <% constituency.candidates.forEach(candidate => { %>
                                    <div class="bg-gray-700 rounded-lg border border-gray-600 p-4">
                                        <div class="flex items-start justify-between">
                                            <div>
                                                <h5 class="text-white font-semibold"><%= candidate.name %></h5>
                                                <p class="text-gray-400"><%= candidate.party %></p>
                                            </div>
                                            <div class="flex space-x-2">
                                                <button onclick="editCandidate('<%= candidate._id %>')"
                                                        class="text-blue-400 hover:text-blue-300">
                                                    Edit
                                                </button>
                                              <button onclick="deleteCandidate('<%= candidate._id %>')"  
                                                
                                                        class="text-red-400 hover:text-red-300">
                                                    Delete
                                                </button>
                                            </div>
                                        </div>
                                        <img src="/uploads/candidates/<%= candidate.image %>" 
                                             alt="<%= candidate.name %>" 
                                             class="w-full h-32 object-cover rounded mt-2">
                                        <div class="mt-2 text-gray-400">
                                            <p>Votes: <%= candidate.votes %></p>
                                            <p>Reviews: <%= candidate.reviews.length %></p>
                                              
                                            <!-- Manifesto Links -->
                                            <% if (candidate.manifesto && candidate.manifesto.length > 0) { %>
                                            <div class="mt-2">
                                                <p class="font-semibold">Manifesto:</p>
                                                <ul class="list-disc pl-5">
                                                    <% candidate.manifesto.forEach(item => { %>
                                                    <li>
                                                        <% if (item.startsWith('http')) { %>
                                                            <a href="<%= item %>" target="_blank" class="text-blue-400 hover:underline"><%= item %></a>
                                                        <% } else { %>
                                                            <%= item %>
                                                        <% } %>
                                                    </li>
                                                    <% }); %>
                                                </ul>
                                            </div>
                                            <% } %>
                                            
                                            <!-- Achievements Links -->
                                            <% if (candidate.achievements && candidate.achievements.length > 0) { %>
                                            <div class="mt-2">
                                                <p class="font-semibold">Achievements:</p>
                                                <ul class="list-disc pl-5">
                                                    <% candidate.achievements.forEach(item => { %>
                                                    <li>
                                                        <% if (item.startsWith('http')) { %>
                                                            <a href="<%= item %>" target="_blank" class="text-blue-400 hover:underline"><%= item %></a>
                                                        <% } else { %>
                                                            <%= item %>
                                                        <% } %>
                                                    </li>
                                                    <% }); %>
                                                </ul>
                                            </div>
                                            <% } %>
                                            
                                            <!-- Corruption Links section removed -->
                                        </div>
                                    </div>
                                <% }) %>
                            </div>

                            <!-- Add Candidate, Add Constituency, and Delete Constituency Buttons -->
                            <div class="mt-4 flex space-x-4">
                                <button onclick="showAddCandidateModal('<%= election._id %>', '<%= constituency.name %>')"
                                        class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg">
                                    Add Candidate
                                </button>
                                <button onclick="showAddConstituencyModal('<%= election._id %>')"
                                        class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg">
                                    Add Constituency
                                </button>
                                <button onclick="deleteConstituency('<%= election._id %>', '<%= constituency._id %>')"
                                        class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg">
                                    Delete Constituency
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<!-- Admin: Manage States/Topics/News (embedded panel) -->
<div class="mb-8 mt-8">
    <h2 class="text-2xl font-bold text-white mb-4">Manage States, Topics & News</h2>
    <div class="bg-gray-800 rounded-lg p-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-2">
            <!-- Create State -->
            <div>
                <label class="block text-gray-300 text-sm font-medium mb-1">New State</label>
                <input id="adminNewStateName" placeholder="State name" class="w-full bg-gray-700 text-white rounded px-3 py-2" />
                <div class="flex items-center space-x-2 mt-2">
                    <button id="adminCreateStateBtn" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">Create State</button>
                    <span id="adminCreateStateMsg" class="text-green-400"></span>
                </div>
            </div>

            <!-- Consolidated News Creation Form: State → Topic → Title/Content/Image -->
            <div>
                <label class="block text-gray-300 text-sm font-medium mb-1">State</label>
                <select id="adminNewsStateSelect" class="w-full bg-gray-700 text-white rounded px-3 py-2"></select>

                <label class="block text-gray-300 text-sm font-medium mt-3 mb-1">Topic</label>
                <div class="flex gap-2">
                    <select id="adminNewsTopicSelect" class="flex-1 bg-gray-700 text-white rounded px-3 py-2"></select>
                    <button id="adminCreateQuickTopicBtn" class="bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded whitespace-nowrap">+ New Topic</button>
                </div>

                <label class="block text-gray-300 text-sm font-medium mt-3 mb-1">Title</label>
                <input id="adminNewsTitle" placeholder="Short headline" class="w-full bg-gray-700 text-white rounded px-3 py-2" />

                <label class="block text-gray-300 text-sm font-medium mt-3 mb-1">Content</label>
                <textarea id="adminNewsContent" placeholder="Brief description or excerpt" class="w-full bg-gray-700 text-white rounded px-3 py-2"></textarea>

                <label class="block text-gray-300 text-sm font-medium mt-3 mb-1">URL (optional)</label>
                <input id="adminNewsUrl" placeholder="https://..." class="w-full bg-gray-700 text-white rounded px-3 py-2" />

                <label class="block text-gray-300 text-sm font-medium mt-3 mb-1">Image (optional)</label>
                <input id="adminNewsImage" type="file" accept="image/*,.webp,.avif,.svg" class="mt-1" />
                <div id="adminNewsImagePreview" class="mt-2"></div>

                <div class="flex items-center space-x-2 mt-3">
                    <button id="adminCreateNewsBtn" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded">Create News</button>
                    <span id="adminCreateNewsMsg" class="text-green-400"></span>
                </div>
                <div id="adminCreateNewsToast" class="hidden mt-3"></div>
            </div>

            <!-- Quick Topic Creation Modal -->
            <div id="quickTopicModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
                <div class="bg-gray-800 rounded-lg p-6 w-96">
                    <h3 class="text-xl font-bold text-white mb-4">Create New Topic</h3>
                    <input id="quickTopicName" placeholder="Topic name" class="w-full bg-gray-700 text-white rounded px-3 py-2 mb-3" />
                    <textarea id="quickTopicDescription" placeholder="Description (optional)" class="w-full bg-gray-700 text-white rounded px-3 py-2 mb-3 h-20"></textarea>
                    <label class="block text-gray-300 text-sm mb-1">Image (optional)</label>
                    <input id="quickTopicImage" type="file" accept="image/*,.webp,.avif,.svg" class="mb-3" />
                    <div class="flex justify-end gap-2">
                        <button id="quickTopicCancel" class="bg-gray-600 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded">Cancel</button>
                        <button id="quickTopicCreate" class="bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded">Create</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // reuse admin panel scripts
    async function fetchStatesForAdmin_dashboard() {
        try {
            const res = await fetch('/admin/states', { credentials: 'same-origin' });
            const json = await res.json().catch(() => null);
            if (json && json.success && Array.isArray(json.states)) return json.states;
            return [];
        } catch (err) { console.error('fetchStatesForAdmin error', err); return []; }
    }

    async function populateAdminSelects_dashboard() {
        const states = await fetchStatesForAdmin_dashboard();
        const newsStateSel = document.getElementById('adminNewsStateSelect');
        if (newsStateSel) {
            newsStateSel.innerHTML = '';
            const placeholder = document.createElement('option'); placeholder.value=''; placeholder.textContent='Select state'; newsStateSel.appendChild(placeholder);
            states.forEach(s => { const o = document.createElement('option'); o.value = s._id; o.textContent = s.name; newsStateSel.appendChild(o); });
        }
    }

    // When admin changes state selection, populate the topic dropdown
    document.getElementById('adminNewsStateSelect').addEventListener('change', async (e) => {
        const stateId = e.target.value;
        const topicSel = document.getElementById('adminNewsTopicSelect');
        topicSel.innerHTML = '';
        if (!stateId) {
            const placeholder = document.createElement('option'); placeholder.value=''; placeholder.textContent='Select a state first'; topicSel.appendChild(placeholder);
            return;
        }

        try {
            const res = await fetch(`/admin/states/${stateId}/json`, { credentials: 'same-origin' });
            const data = await res.json();
            if (data && data.state && Array.isArray(data.state.topics)) {
                if (data.state.topics.length === 0) {
                    const placeholder = document.createElement('option'); placeholder.value=''; placeholder.textContent='No topics. Create one first.'; topicSel.appendChild(placeholder);
                } else {
                    data.state.topics.forEach(t => {
                        const o = document.createElement('option'); o.value = t._id; o.textContent = t.name; topicSel.appendChild(o);
                    });
                }
            }
        } catch (err) { console.error('Failed loading topics', err); }
    });

    document.getElementById('adminCreateStateBtn').addEventListener('click', async () => {
        const name = document.getElementById('adminNewStateName').value.trim(); const msg = document.getElementById('adminCreateStateMsg'); if (msg) msg.textContent='';
        if (!name) return alert('State name required');
        try { const res = await fetch('/admin/states', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name }) }); const d = await res.json(); if (d && d.success) { if (msg) msg.textContent = 'Created'; document.getElementById('adminNewStateName').value = ''; await populateAdminSelects_dashboard(); } else { alert(d.message || 'Failed creating state'); } } catch (e) { console.error(e); alert('Error'); }
    });

    // Quick topic creation modal
    const quickTopicModal = document.getElementById('quickTopicModal');
    const quickTopicCancel = document.getElementById('quickTopicCancel');
    const quickTopicCreate = document.getElementById('quickTopicCreate');
    const adminCreateQuickTopicBtn = document.getElementById('adminCreateQuickTopicBtn');

    adminCreateQuickTopicBtn.addEventListener('click', () => {
        quickTopicModal.classList.remove('hidden');
    });

    quickTopicCancel.addEventListener('click', () => {
        quickTopicModal.classList.add('hidden');
    });

    quickTopicCreate.addEventListener('click', async () => {
        const stateId = document.getElementById('adminNewsStateSelect').value;
        if (!stateId) return alert('Select a state first');

        const name = document.getElementById('quickTopicName').value.trim();
        const description = document.getElementById('quickTopicDescription').value.trim();
        const fileEl = document.getElementById('quickTopicImage');
        if (!name) return alert('Topic name required');

        quickTopicCreate.disabled = true;
        const prevText = quickTopicCreate.textContent;
        quickTopicCreate.textContent = 'Creating...';

        try {
            const form = new FormData();
            form.append('name', name);
            form.append('description', description);
            if (fileEl && fileEl.files && fileEl.files[0]) form.append('image', fileEl.files[0]);

            const res = await fetch(`/admin/states/${stateId}/topics`, { method: 'POST', body: form, credentials: 'same-origin' });
            const j = await res.json();
            if (j && j.success) {
                document.getElementById('quickTopicName').value = '';
                document.getElementById('quickTopicDescription').value = '';
                if (fileEl) fileEl.value = '';
                quickTopicModal.classList.add('hidden');
                showToast('Topic created', 'success');
                // Refresh topic dropdown
                const stateChangeEvent = new Event('change');
                document.getElementById('adminNewsStateSelect').dispatchEvent(stateChangeEvent);
            } else {
                alert(j && j.message ? j.message : 'Failed creating topic');
            }
        } catch (err) { console.error('Create topic error', err); alert('Error creating topic'); }
        finally { quickTopicCreate.disabled = false; quickTopicCreate.textContent = prevText; }
    });

    document.getElementById('adminCreateNewsBtn').addEventListener('click', async () => {
        const stateId = document.getElementById('adminNewsStateSelect').value;
        const topicId = document.getElementById('adminNewsTopicSelect').value;
        const titleEl = document.getElementById('adminNewsTitle');
        const contentEl = document.getElementById('adminNewsContent');
        const urlEl = document.getElementById('adminNewsUrl');
        const fileEl = document.getElementById('adminNewsImage');
        const msg = document.getElementById('adminCreateNewsMsg');
        if (msg) msg.textContent = '';
        if (!stateId) return showToast('Select a state', 'error');
        if (!topicId) return showToast('Select or create a topic', 'error');
        if (!titleEl.value.trim()) return showToast('Title required', 'error');

        // Disable button and show loading
        const btn = document.getElementById('adminCreateNewsBtn');
        btn.disabled = true; btn.classList.add('opacity-70');
        const prevText = btn.textContent; btn.textContent = 'Creating...';

        try {
            const form = new FormData();
            form.append('title', titleEl.value.trim());
            form.append('content', contentEl.value.trim());
            form.append('url', urlEl.value.trim());
            if (fileEl && fileEl.files && fileEl.files[0]) form.append('image', fileEl.files[0]);

            const res = await fetch(`/admin/states/${stateId}/topics/${topicId}/news`, { method: 'POST', body: form, credentials: 'same-origin' });
            const d = await res.json();
            if (d && d.success) {
                if (msg) msg.textContent = 'Created';
                // Clear inputs
                titleEl.value = '';
                contentEl.value = '';
                urlEl.value = '';
                if (fileEl) { fileEl.value = ''; const preview = document.getElementById('adminNewsImagePreview'); if (preview) preview.innerHTML = ''; }
                showToast('News created', 'success');
                if (typeof loadAdminContent === 'function') await loadAdminContent();
                if (typeof populateAdminSelects_dashboard === 'function') await populateAdminSelects_dashboard();
                window.dispatchEvent(new CustomEvent('admin:news-created', { detail: d.news }));
            } else {
                showToast(d && d.message ? d.message : 'Failed creating news', 'error');
            }
        } catch (e) {
            console.error(e);
            showToast('Error creating news', 'error');
        } finally {
            btn.disabled = false; btn.classList.remove('opacity-70'); btn.textContent = prevText;
        }
    });

    // Image preview for Create News
    document.getElementById('adminNewsImage').addEventListener('change', (e) => {
        const preview = document.getElementById('adminNewsImagePreview'); preview.innerHTML = '';
        const f = e.target.files && e.target.files[0];
        if (!f) return;
        if (!f.type.startsWith('image/')) return;
        const img = document.createElement('img'); img.className = 'w-full h-36 object-cover rounded';
        img.src = URL.createObjectURL(f);
        preview.appendChild(img);
    });

    // Simple toast utility
    function showToast(message, type='info') {
        const toastEl = document.getElementById('adminCreateNewsToast');
        if (!toastEl) return alert(message);
        toastEl.className = '';
        toastEl.innerHTML = '';
        const bg = type === 'success' ? 'bg-green-600' : type === 'error' ? 'bg-red-600' : 'bg-gray-700';
        toastEl.classList.add(bg, 'text-white', 'p-2', 'rounded');
        toastEl.textContent = message;
        toastEl.classList.remove('hidden');
        setTimeout(() => { toastEl.classList.add('hidden'); }, 4000);
    }

    // initialize selects on load
    (function(){ populateAdminSelects_dashboard().catch(e => console.error(e)); })();

    // Close modal on outside click
    quickTopicModal.addEventListener('click', (e) => {
        if (e.target === quickTopicModal) quickTopicModal.classList.add('hidden');
    });
</script>

<!-- Existing content manager -->
<div class="mb-8 mt-6">
    <h2 class="text-2xl font-bold text-white mb-4">Existing States → Topics → News</h2>
    <div id="adminContentList" class="space-y-4">
        <div class="bg-gray-800 rounded-lg p-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div id="adminStatesCol" class="p-2">
                    <h3 class="text-sm text-gray-300 mb-2">States</h3>
                    <div id="adminStatesList" class="space-y-2"></div>
                </div>
                <div id="adminTopicsCol" class="p-2">
                    <h3 class="text-sm text-gray-300 mb-2">Topics</h3>
                    <div id="adminTopicsList" class="space-y-2"></div>
                </div>
                <div id="adminNewsCol" class="p-2">
                    <h3 class="text-sm text-gray-300 mb-2">News</h3>
                    <div id="adminNewsList" class="space-y-2"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Load and render existing states/topics/news for edit/delete
    async function loadAdminContent() {
        try {
            const res = await fetch('/admin/states', { credentials: 'same-origin' });
            const j = await res.json(); if (!j || !j.success) return;
            renderAdminContent(j.states || []);
        } catch (e) { console.error('loadAdminContent error', e); }
    }

    function renderAdminContent(states) {
        // Populate the three admin columns: states, topics, news
        const statesCol = document.getElementById('adminStatesList');
        const topicsCol = document.getElementById('adminTopicsList');
        const newsCol = document.getElementById('adminNewsList');
        statesCol.innerHTML = ''; topicsCol.innerHTML = ''; newsCol.innerHTML = '';

        if (!states || states.length === 0) { statesCol.innerHTML = '<div class="text-gray-400">No states created yet.</div>'; return; }

        states.forEach(state => {
            const wrapper = document.createElement('div'); wrapper.className = 'flex items-center justify-between p-2 rounded hover:bg-gray-700';
            const nameDiv = document.createElement('div'); nameDiv.className = 'cursor-pointer flex-1'; nameDiv.textContent = state.name; nameDiv.dataset.stateId = state._id;
            nameDiv.addEventListener('click', () => {
                // mark selected
                document.querySelectorAll('#adminStatesList .state-entry').forEach(d=>d.classList.remove('bg-gray-700','text-white'));
                wrapper.classList.add('bg-gray-700','text-white');
                renderAdminTopicsForState(state);
                // preselect state in create form
                const sel = document.getElementById('adminNewsStateSelect'); if (sel) { sel.value = state._id; }
            });

            // delete button
            const delBtn = document.createElement('button');
            delBtn.className = 'ml-2 text-sm bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded';
            delBtn.textContent = 'Delete';
            delBtn.addEventListener('click', async (ev) => {
                ev.stopPropagation();
                if (!confirm('Delete this state and all its constituencies and candidates?')) return;
                try {
                    const res = await fetch('/admin/states/' + state._id, { method: 'DELETE', credentials: 'same-origin' });
                    const d = await res.json();
                    if (d && d.success) {
                        await loadAdminContent();
                        await populateAdminSelects_dashboard();
                        showToast('State deleted', 'success');
                    } else {
                        alert(d && d.message ? d.message : 'Failed deleting state');
                    }
                } catch (err) { console.error(err); alert('Error deleting state'); }
            });

            wrapper.appendChild(nameDiv);
            wrapper.appendChild(delBtn);
            wrapper.classList.add('state-entry');
            statesCol.appendChild(wrapper);
        });

        // auto-select first state
        const firstState = states[0]; if (firstState) {
            const firstDiv = statesCol.querySelector('div'); if (firstDiv) { firstDiv.click(); }
        }
    }

    function renderAdminTopicsForState(state) {
        const topicsCol = document.getElementById('adminTopicsList'); topicsCol.innerHTML = '';
        const newsCol = document.getElementById('adminNewsList'); newsCol.innerHTML = '';
        if (!state.topics || state.topics.length === 0) { topicsCol.innerHTML = '<div class="text-gray-400">No topics</div>'; return; }
        state.topics.forEach(topic => {
            const wrapper = document.createElement('div'); wrapper.className='flex items-center justify-between p-2 rounded hover:bg-gray-700';
            const t = document.createElement('div'); t.className='cursor-pointer flex-1'; t.textContent = topic.name; t.dataset.topicId = topic._id;
            t.addEventListener('click', () => {
                // highlight
                document.querySelectorAll('#adminTopicsList .topic-entry').forEach(d=>d.classList.remove('bg-gray-700','text-white'));
                wrapper.classList.add('bg-gray-700','text-white');
                renderAdminNewsForTopic(state, topic);
            });
            const delBtn = document.createElement('button');
            delBtn.className = 'ml-2 text-sm bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded';
            delBtn.textContent = 'Delete';
            delBtn.addEventListener('click', async (ev) => {
                ev.stopPropagation();
                if (!confirm('Delete this topic and all its news?')) return;
                try {
                    const res = await fetch(`/admin/states/${state._id}/topics/${topic._id}`, { method: 'DELETE', credentials: 'same-origin' });
                    const d = await res.json();
                    if (d && d.success) {
                        await loadAdminContent();
                        showToast('Topic deleted', 'success');
                    } else {
                        alert(d && d.message ? d.message : 'Failed deleting topic');
                    }
                } catch (err) { console.error(err); alert('Error deleting topic'); }
            });
            wrapper.appendChild(t);
            wrapper.appendChild(delBtn);
            wrapper.classList.add('topic-entry');
            topicsCol.appendChild(wrapper);
        });
        // auto-select first topic
        const first = topicsCol.querySelector('.topic-entry'); if (first) { first.querySelector('div').click(); }
    }

    function renderAdminNewsForTopic(state, topic) {
        const newsCol = document.getElementById('adminNewsList'); newsCol.innerHTML = '';
        if (!topic.infos || topic.infos.length===0) { newsCol.innerHTML = '<div class="text-gray-400">No news</div>'; return; }
        topic.infos.forEach(info => {
            const n = document.createElement('div'); n.className='bg-gray-700 p-3 rounded mb-2 border border-gray-600';
            n.innerHTML = `<div class='flex justify-between items-start'><div class='flex-1'><strong class='text-white block'>${escapeHtml(info.title||'')}</strong><div class='text-gray-400 text-sm mt-1'>${escapeHtml(info.content||'').slice(0,120)}</div></div><div class='flex gap-1 ml-2'><button class='px-2 py-1 bg-blue-600 hover:bg-blue-700 text-white rounded text-xs whitespace-nowrap' data-role='edit-news'>Edit</button><button class='px-2 py-1 bg-red-600 hover:bg-red-700 text-white rounded text-xs whitespace-nowrap' data-role='delete-news'>Delete</button></div></div>`;
            const editBtn = n.querySelector('[data-role="edit-news"]'); 
            const delBtn = n.querySelector('[data-role="delete-news"]');
            if (editBtn) editBtn.addEventListener('click', ()=>openEditNewsModal(state._id, topic._id, info._id));
            if (delBtn) delBtn.addEventListener('click', async ()=>{ 
                if (!confirm('Delete this news item?')) return; 
                try { 
                    const res = await fetch(`/admin/states/${state._id}/topics/${topic._id}/news/${info._id}`, { method:'DELETE', credentials:'same-origin' }); 
                    const d = await res.json(); 
                    if (d && d.success) { 
                        await loadAdminContent(); 
                        showToast('News deleted', 'success');
                    } else {
                        alert(d.message||'Failed deleting news');
                    }
                } catch(e){
                    console.error(e); 
                    alert('Error deleting news');
                } 
            });
            newsCol.appendChild(n);
        });
    }

    // Simple modal for editing news (creates and reuses DOM node)
    let editNewsModal = null;
    function openEditNewsModal(stateId, topicId, newsId) {
        // fetch state json to find the news item
        fetch(`/admin/states/${stateId}/json`, { credentials: 'same-origin' }).then(r=>r.json()).then(j=>{
            if (!j || !j.success) return alert('Failed loading state');
            const state = j.state; const topic = (state.topics||[]).find(t=>t._id==topicId); if(!topic) return alert('Topic not found');
            const news = (topic.infos||[]).find(n=>n._id==newsId); if(!news) return alert('News not found');
            showNewsModal(stateId, topicId, news);
        }).catch(e=>{ console.error(e); alert('Error loading news'); });
    }

    function showNewsModal(stateId, topicId, news) {
        if (!editNewsModal) {
            editNewsModal = document.createElement('div'); editNewsModal.className='fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 p-4';
            editNewsModal.innerHTML = `
                <div class='bg-gray-800 rounded-lg p-4 w-full max-w-2xl'>
                    <h3 class='text-xl text-white mb-3'>Edit News</h3>
                    <input id='editNewsTitle' class='w-full bg-gray-700 text-white rounded px-2 py-1 mb-2' />
                    <textarea id='editNewsContent' class='w-full bg-gray-700 text-white rounded px-2 py-1 mb-2'></textarea>
                    <input id='editNewsUrl' class='w-full bg-gray-700 text-white rounded px-2 py-1 mb-2' />
                    <input id='editNewsImage' type='file' accept='image/*' class='mb-2' />
                    <div class='flex justify-end space-x-2'>
                        <button id='saveNewsBtn' class='px-3 py-1 bg-green-600 text-white rounded'>Save</button>
                        <button id='closeNewsBtn' class='px-3 py-1 bg-gray-600 text-white rounded'>Close</button>
                    </div>
                </div>
            `;
            document.body.appendChild(editNewsModal);
            editNewsModal.querySelector('#closeNewsBtn').addEventListener('click', () => { editNewsModal.style.display='none'; });
        }
        editNewsModal.style.display='flex';
        editNewsModal.querySelector('#editNewsTitle').value = news.title||'';
        editNewsModal.querySelector('#editNewsContent').value = news.content||'';
        editNewsModal.querySelector('#editNewsUrl').value = news.url||'';
        const saveBtn = editNewsModal.querySelector('#saveNewsBtn');
        saveBtn.onclick = async () => {
            const form = new FormData(); form.append('title', editNewsModal.querySelector('#editNewsTitle').value.trim()); form.append('content', editNewsModal.querySelector('#editNewsContent').value.trim()); form.append('url', editNewsModal.querySelector('#editNewsUrl').value.trim());
            const fileEl = editNewsModal.querySelector('#editNewsImage'); if (fileEl && fileEl.files && fileEl.files[0]) form.append('image', fileEl.files[0]);
            try {
                const res = await fetch(`/admin/states/${stateId}/topics/${topicId}/news/${news._id}`, { method: 'PUT', body: form, credentials: 'same-origin' });
                const d = await res.json(); if (d && d.success) { editNewsModal.style.display='none'; await loadAdminContent(); } else { alert(d.message || 'Failed updating news'); }
            } catch (e) { console.error(e); alert('Error'); }
        };
    }

    function escapeHtml(str) { return String(str||'').replace(/[&<>"]/g, s=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' })[s]); }

    // Initialize
    (function(){ loadAdminContent(); })();
</script>

