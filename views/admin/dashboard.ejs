<script>
    function showAddCandidateModal(electionId, constituency) {
        if (!electionId || !constituency) {
            showNotification('Election and constituency information is required', 'error');
            return;
        }
        document.getElementById('modalElectionId').value = electionId;
        document.getElementById('modalConstituency').value = constituency;
        document.getElementById('addCandidateForm').reset();
        document.getElementById('addCandidateModal').classList.remove('hidden');
    }

    function closeAddCandidateModal() {
        document.getElementById('addCandidateModal').classList.add('hidden');
        document.getElementById('addCandidateForm').reset();
    }

    // Add form submission handler for the add candidate form
    document.getElementById('addCandidateForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        try {
            const formData = new FormData(this);
            
            // Process manifesto, achievements, and corruption as arrays
            ['manifesto', 'achievements', 'corruption'].forEach(field => {
                const text = formData.get(field);
                if (text) {
                    const array = text.trim().split('\n').filter(item => item.trim() !== '');
                    formData.set(field, JSON.stringify(array));
                }
            });
            
            const response = await fetch('/admin/candidates', {
                method: 'POST',
                body: formData
            });
            
            const result = await response.json();
            
            if (result.success) {
                showNotification('Candidate added successfully', 'success');
                closeAddCandidateModal();
                setTimeout(() => window.location.reload(), 1000);
            } else {
                throw new Error(result.message || 'Failed to add candidate');
            }
        } catch (error) {
            console.error('Error:', error);
            showNotification(error.message || 'Error adding candidate', 'error');
        }
    });
</script>

