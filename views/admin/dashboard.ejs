<script>
async function showAddConstituencyModal(electionId) {
    if (electionId) {
        currentElectionId = electionId;
        document.getElementById('modalElectionIdForConstituency').value = electionId;
    }
    
    // Load states
    try {
        const response = await fetch('/admin/states');
        const data = await response.json();
        
        if (data.success) {
            const stateSelect = document.getElementById('stateSelect');
            stateSelect.innerHTML = '<option value="">Select State</option>';
            
            data.states.forEach(state => {
                const option = document.createElement('option');
                option.value = state._id;
                option.textContent = state.name;
                stateSelect.appendChild(option);
            });
        }
    } catch (error) {
        console.error('Error loading states:', error);
        showNotification('Error loading states', 'error');
    }
    
    document.getElementById('addConstituencyModal').classList.remove('hidden');
}

function closeAddConstituencyModal() {
    document.getElementById('addConstituencyModal').classList.add('hidden');
    document.getElementById('addConstituencyForm').reset();
}

function addConstituency() {
    const container = document.getElementById('constituenciesContainer');
    const template = document.getElementById('constituencyTemplate');
    const clone = template.content.cloneNode(true);
    container.appendChild(clone);
    updateFieldNames();
}

function removeConstituency(button) {
    button.closest('.constituency-block').remove();
    updateFieldNames();
}

function addCandidate(button) {
    const container = button.previousElementSibling;
    const template = document.getElementById('candidateTemplate');
    const clone = template.content.cloneNode(true);
    container.appendChild(clone);
    updateFieldNames();
}

function removeCandidate(button) {
    button.closest('.candidate-block').remove();
    updateFieldNames();
}

function updateFieldNames() {
    const constituencies = document.querySelectorAll('.constituency-block');
    constituencies.forEach((constituency, constituencyIndex) => {
        const constituencyInput = constituency.querySelector('input[name*="constituencies[][name]"]');
        constituencyInput.name = `constituencies[${constituencyIndex}][name]`;

        const candidates = constituency.querySelectorAll('.candidate-block');
        candidates.forEach((candidate, candidateIndex) => {
            const inputs = candidate.querySelectorAll('input');
            inputs.forEach(input => {
                const fieldName = input.name.match(/\[\]\[([^\]]+)\]$/)[1];
                input.name = `constituencies[${constituencyIndex}][candidates][${candidateIndex}][${fieldName}]`;
            });
        });
    });
}

document.getElementById('electionForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    try {
        const formData = new FormData();
        
        // Add basic election details
        formData.append('title', this.querySelector('[name="title"]').value);
        formData.append('state', this.querySelector('[name="state"]').value);
        formData.append('startDate', this.querySelector('[name="startDate"]').value);
        formData.append('endDate', this.querySelector('[name="endDate"]').value);

        // Process constituencies and candidates
        const constituencies = [];
        document.querySelectorAll('.constituency-block').forEach((constituency, constituencyIndex) => {
            const constituencyData = {
                name: constituency.querySelector('[name*="[name]"]').value,
                candidates: []
            };

            constituency.querySelectorAll('.candidate-block').forEach((candidate, candidateIndex) => {
                const candidateData = {
                    name: candidate.querySelector('[name="candidate_name"]').value,
                    party: candidate.querySelector('[name="candidate_party"]').value
                };
                
                // Add manifesto if present
                const manifestoInput = candidate.querySelector('[name="candidate_manifesto"]');
                if (manifestoInput && manifestoInput.value.trim()) {
                    candidateData.manifesto = manifestoInput.value.trim().split('\n').filter(item => item.trim() !== '');
                }
                
                // Add achievements if present
                const achievementsInput = candidate.querySelector('[name="candidate_achievements"]');
                if (achievementsInput && achievementsInput.value.trim()) {
                    candidateData.achievements = achievementsInput.value.trim().split('\n').filter(item => item.trim() !== '');
                }

                // Add corruption records if present
                const corruptionInput = candidate.querySelector('[name="candidate_corruption"]');
                if (corruptionInput && corruptionInput.value.trim()) {
                    candidateData.corruption = corruptionInput.value.trim().split('\n').filter(item => item.trim() !== '');
                }

                // Add image file if present
                const imageInput = candidate.querySelector('[name="candidate_image"]');
                if (imageInput && imageInput.files[0]) {
                    const fieldName = `candidate_image_${constituencyIndex}_${candidateIndex}`;
                    formData.append(fieldName, imageInput.files[0]);
                    candidateData.imageField = fieldName;
                }

                constituencyData.candidates.push(candidateData);
            });

            constituencies.push(constituencyData);
        });

        formData.append('constituencies', JSON.stringify(constituencies));

        const response = await fetch('/admin/elections', {
            method: 'POST',
            body: formData
        });

        const data = await response.json();
        
        if (!response.ok) {
            throw new Error(data.message || 'Error creating election');
        }

        if (data.success) {
            showNotification('Election created successfully', 'success');
            setTimeout(() => window.location.reload(), 1000);
        } else {
            throw new Error(data.message || 'Error creating election');
        }
    } catch (error) {
        console.error('Error:', error);
        showNotification(error.message || 'Error creating election', 'error');
    }
});

