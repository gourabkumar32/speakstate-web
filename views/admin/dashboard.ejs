        // Reset the flag after a short delay
        setTimeout(() => {
            if (event && event.target) {
                event.target._isProcessing = false;
            }
        }, 500);
    }
    
    const container = document.querySelector(`[data-constituency-id="${constituencyId}"] .candidates-container`);
    const candidateId = Date.now(); // Unique ID for the candidate
    
    const candidateHtml = `
        <div class="candidate-block bg-gray-600 p-3 rounded" data-candidate-id="${candidateId}">
            <div class="flex justify-between items-center mb-3">
                <h6 class="text-white font-medium">New Candidate</h6>
                <button type="button" onclick="removeCandidateFromConstituency(${candidateId})"
                        class="text-red-400 hover:text-red-300 text-sm">Remove</button>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-gray-300 text-sm mb-1">Name</label>
                    <input type="text" name="constituencies[${constituencyId}][candidates][${candidateId}][name]" required
                         class="w-full bg-gray-700 text-white rounded px-3 py-2">
                </div>
                <div>
                    <label class="block text-gray-300 text-sm mb-1">Party</label>
                    <input type="text" name="constituencies[${constituencyId}][candidates][${candidateId}][party]" required
                         class="w-full bg-gray-700 text-white rounded px-3 py-2">
                </div>
                <div class="md:col-span-2">
                   <label class="block text-gray-300 text-sm mb-1">Photo</label>
                   <input type="file" name="constituencies[${constituencyId}][candidates][${candidateId}][image]" accept="image/*"
                        class="w-full bg-gray-700 text-white rounded px-3 py-2">
                </div>
                <div class="md:col-span-2">
                    <label class="block text-gray-300 text-sm mb-1">Manifesto Points (one per line)</label>
                    <textarea name="constituencies[${constituencyId}][candidates][${candidateId}][manifesto]" rows="3"
                         class="w-full bg-gray-700 text-white rounded px-3 py-2" 
                         placeholder="Enter manifesto points, one per line"></textarea>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-gray-300 text-sm mb-1">Key Achievements (one per line)</label>
                    <textarea name="constituencies[${constituencyId}][candidates][${candidateId}][achievements]" rows="3"
                         class="w-full bg-gray-700 text-white rounded px-3 py-2"
                         placeholder="Enter key achievements, one per line"></textarea>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-gray-300 text-sm mb-1">Corruption Records (one per line)</label>
                    <textarea name="constituencies[${constituencyId}][candidates][${candidateId}][corruption]" rows="3"
                         class="w-full bg-gray-700 text-white rounded px-3 py-2"
                         placeholder="Enter corruption records, one per line"></textarea>
                </div>
            </div>
        </div>
    `;
    
    container.insertAdjacentHTML('beforeend', candidateHtml);
}

// Function to remove candidate from constituency in election creation form
function removeCandidateFromConstituency(candidateId) {
    const candidate = document.querySelector(`[data-candidate-id="${candidateId}"]`);
    if (candidate) {
        candidate.remove();
    }
}

// Update the createElectionForm submit handler to handle the new structure
document.getElementById('createElectionForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    try {
        const formData = new FormData();
        
        // Add basic election details
        formData.append('title', this.querySelector('[name="title"]').value);
        formData.append('state', this.querySelector('[name="state"]').value);
        formData.append('startDate', this.querySelector('[name="startDate"]').value);
        formData.append('endDate', this.querySelector('[name="endDate"]').value);

        // Process constituencies and candidates
        const constituencies = [];
        document.querySelectorAll('.constituency-block').forEach((constituency) => {
            const constituencyId = constituency.dataset.constituencyId;
            const constituencyData = {
                name: constituency.querySelector(`[name="constituencies[${constituencyId}][name]"]`).value,
                candidates: []
            };

            constituency.querySelectorAll('.candidate-block').forEach((candidate) => {
                const candidateId = candidate.dataset.candidateId;
                const candidateData = {
                    name: candidate.querySelector(`[name="constituencies[${constituencyId}][candidates][${candidateId}][name]"]`).value,
                    party: candidate.querySelector(`[name="constituencies[${constituencyId}][candidates][${candidateId}][party]"]`).value
                };

                // Process manifesto, achievements, and corruption
                const manifestoText = candidate.querySelector(`[name="constituencies[${constituencyId}][candidates][${candidateId}][manifesto]"]`).value;
                const achievementsText = candidate.querySelector(`[name="constituencies[${constituencyId}][candidates][${candidateId}][achievements]"]`).value;
                const corruptionText = candidate.querySelector(`[name="constituencies[${constituencyId}][candidates][${candidateId}][corruption]"]`).value;

                candidateData.manifesto = manifestoText.trim().split('\n').filter(item => item.trim());
                candidateData.achievements = achievementsText.trim().split('\n').filter(item => item.trim());
                candidateData.corruption = corruptionText.trim().split('\n').filter(item => item.trim());

                // Handle image file
                const imageFile = candidate.querySelector(`[name="constituencies[${constituencyId}][candidates][${candidateId}][image]"]`).files[0];
                if (imageFile) {
                    const fieldName = `candidate_image_${constituencyId}_${candidateId}`;
                    formData.append(fieldName, imageFile);
                    candidateData.imageField = fieldName;
                }

                constituencyData.candidates.push(candidateData);
            });

            constituencies.push(constituencyData);
        });

        formData.append('constituencies', JSON.stringify(constituencies));

        const response = await fetch('/admin/elections', {
            method: 'POST',
            body: formData
        });

        const result = await response.json();

        if (result.success) {
            showNotification('Election created successfully', 'success');
            setTimeout(() => window.location.reload(), 1000);
        } else {
            throw new Error(result.message || 'Failed to create election');
        }
    } catch (error) {
        console.error('Error:', error);
        showNotification(error.message || 'Error creating election', 'error');
    }
});
</script>

