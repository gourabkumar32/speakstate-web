      } catch (error) {
        console.error(error);
        showNotification('Error deleting candidate', 'error');
      }
    }
    
    function editCandidate(candidateId) {
      // Fetch candidate data and show edit modal
      fetch(`/admin/candidates/${candidateId}`)
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            const candidate = data.candidate;
            document.getElementById('editCandidateId').value = candidate._id;
            document.getElementById('editCandidateName').value = candidate.name;
            document.getElementById('editCandidateParty').value = candidate.party;
            
            // Format manifesto, achievements, and corruption as newline-separated text
            const manifestoText = Array.isArray(candidate.manifesto) ? candidate.manifesto.join('\n') : '';
            const achievementsText = Array.isArray(candidate.achievements) ? candidate.achievements.join('\n') : '';
            const corruptionText = Array.isArray(candidate.corruption) ? candidate.corruption.join('\n') : '';
            
            document.getElementById('editCandidateManifesto').value = manifestoText;
            document.getElementById('editCandidateAchievements').value = achievementsText;
            document.getElementById('editCandidateCorruption').value = corruptionText;
            
            // Show the modal
            document.getElementById('editCandidateModal').classList.remove('hidden');
          } else {
            showNotification('Failed to load candidate data', 'error');
          }
        })
        .catch(error => {
          console.error(error);
          showNotification('Error loading candidate data', 'error');
        });
    }
    
    function closeEditCandidateModal() {
      document.getElementById('editCandidateModal').classList.add('hidden');
      document.getElementById('editCandidateForm').reset();
    }
    
    // Edit Candidate Form Submission
    document.getElementById('editCandidateForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      try {
        const formData = new FormData(this);
        
        // Process manifesto, achievements, and corruption as arrays
        const manifestoText = document.getElementById('editCandidateManifesto').value;
        const achievementsText = document.getElementById('editCandidateAchievements').value;
        const corruptionText = document.getElementById('editCandidateCorruption').value;
        
        // Convert to arrays and add to formData
        const manifestoArray = manifestoText.trim().split('\n').filter(item => item.trim() !== '');
        const achievementsArray = achievementsText.trim().split('\n').filter(item => item.trim() !== '');
        const corruptionArray = corruptionText.trim().split('\n').filter(item => item.trim() !== '');
        
        const data = {
            name: formData.get('name'),
            party: formData.get('party'),
            manifesto: manifestoArray,
            achievements: achievementsArray,
            corruption: corruptionArray
        };

        // If there's an image, add it to formData
        if (formData.get('image') && formData.get('image').size > 0) {
            formData.append('image', formData.get('image'));
            const response = await fetch('/admin/candidates/' + formData.get('candidateId'), {
                method: 'PUT',
                body: formData
            });
            const result = await response.json();
            if (!result.success) throw new Error(result.message);
        } else {
            // If no image, send as JSON
            const response = await fetch('/admin/candidates/' + formData.get('candidateId'), {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });
            const result = await response.json();
            if (!result.success) throw new Error(result.message);
        }
        
        const response = await fetch('/admin/candidates/' + formData.get('candidateId'), {
          method: 'PUT',
          body: formData
        });
        
        const result = await response.json();
        
        if (result.success) {
          showNotification('Candidate updated successfully', 'success');
          closeEditCandidateModal();
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showNotification(result.message || 'Failed to update candidate', 'error');
        }
      } catch (error) {
        console.error(error);
        showNotification('Error updating candidate', 'error');
      }
    });






    //new js
    document.querySelectorAll('.edit-candidate-btn').forEach(btn => {
