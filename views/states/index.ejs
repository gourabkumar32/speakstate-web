<%- include('../partials/header') %>
<head>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8814468973632188"
     crossorigin="anonymous"></script>
</head>
<link rel="stylesheet" href="/css/style.css">

<main class="min-h-screen bg-slate-50 text-slate-900">
  <div class="max-w-3xl mx-auto px-4 py-8 space-y-6">

    <!-- Page title -->
    <header class="space-y-2 text-center">
      <h1 class="text-3xl font-semibold tracking-tight">Browse States &amp; Topics</h1>
      <p class="text-sm text-slate-600">
       Stay updated for upcoming state elections in this state
      </p>
    </header>

    <!-- STATES -->
    <section class="rounded-xl bg-white border border-slate-200 px-4 py-4 shadow-sm">
      <div class="text-xs font-medium uppercase tracking-wide text-slate-500 mb-2">States</div>
      <ul id="statesList" class="flex flex-wrap gap-3"></ul>
    </section>

   <!-- TOPICS -->
    <section class="rounded-xl bg-white border border-slate-200 px-4 py-4 shadow-sm">
       <div class="text-xs font-medium uppercase tracking-wide text-slate-500 mb-2">Topics</div>
      <div id="topicsRow" class="flex flex-wrap gap-3"></div>
    </section>

    <!-- NEWS (STACKED CARDS) -->
    <section class="space-y-4">
      <div id="stateNewsHeader" class="text-center"></div>
      <div id="stateNewsList" class="flex flex-col gap-6"></div>
    </section>

  </div>
</main>

<script>
  let currentState = null;
  // Server-provided flag: whether the current viewer is authenticated
  const IS_LOGGED_IN = <%- JSON.stringify(!!(typeof user !== 'undefined' && user)) %>;

  // Debug helper to surface errors on page
  function showClientError(message, details) {
    try {
      console.error('States SPA error:', message, details);
      const container = document.querySelector('.max-w-3xl') || document.querySelector('main') || document.body;
      const el = document.createElement('div');
      el.style.background = '#fee2e2';
      el.style.color = '#991b1b';
      el.style.padding = '12px';
      el.style.borderRadius = '6px';
      el.style.margin = '12px 0';
      el.textContent = 'Error loading States UI: ' + message;
      container.insertBefore(el, container.firstChild);
      if (details) {
        const pre = document.createElement('pre'); pre.style.whiteSpace = 'pre-wrap'; pre.style.color='#6b7280'; pre.textContent = String(details);
        container.insertBefore(pre, el.nextSibling);
      }
    } catch (e) { console.error('Failed to show client error', e); }
  }

  const pillClass =
    'px-4 py-1.5 rounded-full border border-slate-300 bg-white text-xs md:text-sm text-slate-800 ' +
    'hover:border-indigo-500 hover:bg-indigo-50 cursor-pointer transition';

  const pillActiveClass = ['bg-indigo-500','border-indigo-500','text-white','shadow'];

  // Load states
  async function loadStates() {
    try {
      const res = await fetch('/states/json');
      const j = await res.json().catch(() => null);
      if (!j) { showClientError('Invalid response from server when loading states'); return; }
      if (!j.success) { showClientError('Failed to load states', JSON.stringify(j)); return; }

      const list = document.getElementById('statesList');
      list.innerHTML = '';

      j.states.forEach(s => {
        const li = document.createElement('li');
        li.className = pillClass;
        li.textContent = s.name;
        li.onclick = () => selectState(s._id);
        list.appendChild(li);
      });

      if (j.states.length > 0) selectState(j.states[0]._id);
      else showClientError('No states found');
    } catch (err) {
      showClientError('Error loading states', err && err.stack ? err.stack : err);
    }
  }

  // Select state
  async function selectState(stateId) {
    const res = await fetch('/states/' + stateId + '/json');
    const j = await res.json();
    if (!j.success) return;

    currentState = j.state;

    // highlight active
    document.querySelectorAll('#statesList li').forEach(li => {
      if (li.textContent.trim() === currentState.name.trim()) {
        pillActiveClass.forEach(c => li.classList.add(c));
      } else {
        pillActiveClass.forEach(c => li.classList.remove(c));
      }
    });

    renderTopics(currentState);
  }

  // Render topics
  function renderTopics(state) {
    const row = document.getElementById('topicsRow');
    const headerEl = document.getElementById('stateNewsHeader');
    const listEl = document.getElementById('stateNewsList');

    row.innerHTML = '';
    listEl.innerHTML = '';

    const topics = state.topics || [];

    headerEl.innerHTML = `
      <div class="flex flex-col items-center">
        <span class="px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-xs font-medium">${state.name}</span>
        <span class="text-[11px] text-slate-400 mt-1">Select a topic to view news</span>
      </div>
    `;

    topics.forEach(t => {
      const btn = document.createElement('button');
      btn.className = pillClass;
      btn.textContent = t.name;
      btn.onclick = () => showTopic(t._id, btn);
      row.appendChild(btn);
    });

    if (topics.length > 0) row.querySelector('button').click();
  }

  // Small utility to escape HTML in client-side rendering
  function escapeHtml(str) { return String(str||'').replace(/[&<>\"]/g, s => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' })[s]); }

  // Redirect helper that preserves current page as returnTo
  function redirectToLogin() {
    try {
      const returnTo = window.location.pathname + window.location.search + window.location.hash;
      window.location = '/auth/login?returnTo=' + encodeURIComponent(returnTo);
    } catch (e) {
      window.location = '/auth/login';
    }
  }

  // Select topic
  function showTopic(topicId, button) {
    const topic = currentState.topics.find(t => t._id == topicId);

    document.querySelectorAll('#topicsRow button').forEach(b => {
      if (b === button) pillActiveClass.forEach(c => b.classList.add(c));
      else pillActiveClass.forEach(c => b.classList.remove(c));
    });

    const count = topic.infos.length;
    document.getElementById('stateNewsHeader').innerHTML = `
      <div class="flex flex-col items-center">
        <span class="px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-xs font-medium">
          ${currentState.name} — ${topic.name}
        </span>
        <span class="text-[11px] text-slate-400 mt-1">${count} stories</span>
      </div>
    `;

    renderTopicNews(topic);
  }

  // Render news cards (STACKED)
  function renderTopicNews(topic) {
    const listEl = document.getElementById('stateNewsList');
    listEl.innerHTML = '';

    const infos = topic.infos;

    infos.forEach(n => {
      const card = document.createElement('div');
      card.className =
        'rounded-xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col gap-3';
      // attach news id for realtime updates
      card.dataset.newsId = n._id;

      // Title
      const title = document.createElement('h4');
      title.className = 'text-lg font-semibold text-slate-900';
      title.textContent = n.title;
      card.appendChild(title);

      // Image
      if (n.image) {
        const img = document.createElement('img');
        img.src = '/uploads/news/' + n.image;
        img.className = 'w-full h-56 object-cover rounded-lg border';
        card.appendChild(img);
      }

      // Content
      const content = document.createElement('p');
      content.className = 'text-sm text-slate-700';
      content.textContent = n.content;
      card.appendChild(content);

      // Read more
      if (n.url) {
        const a = document.createElement('a');
        a.href = n.url;
        a.target = '_blank';
        a.className = 'text-sm font-semibold text-indigo-600 hover:text-indigo-500';
        a.textContent = 'Read more →';
        card.appendChild(a);
      }

      // Realtime interactions: likes and comments
      const actions = document.createElement('div');
      actions.className = 'flex items-center justify-between mt-2';

        const likeBtn = document.createElement('button');
        likeBtn.setAttribute('aria-label', 'Like this news');
        likeBtn.className = 'inline-flex items-center gap-2 px-3 py-1 rounded-full shadow-md transform transition duration-150 hover:scale-105';
        likeBtn.style.background = 'linear-gradient(90deg, #6366f1 0%, #06b6d4 100%)';
        likeBtn.style.color = '#ffffff';
        likeBtn.style.border = 'none';

        // Use a clear emoji thumbs-up for the like button (large, accessible)
        likeBtn.style.fontSize = '18px';
        likeBtn.style.lineHeight = '1';
        likeBtn.innerHTML = `
          <span class="like-emoji" role="img" aria-label="thumbs up" style="font-size:18px;display:inline-block;vertical-align:middle;">👍</span>
          <span class="like-count" style="font-weight:600;margin-left:6px">${n.likes || 0}</span>
        `;

        likeBtn.onclick = async () => {
          if (!IS_LOGGED_IN) { redirectToLogin(); return; }
          try {
            const res = await fetch(`/states/${currentState._id}/topics/${topic._id}/news/${n._id}/like`, { method: 'POST', credentials: 'same-origin' });
            if (res.status === 401) { redirectToLogin(); return; }
            const j = await res.json().catch(() => null);
            if (j && j.success) {
              // update count and show a brief pulse animation
              const countEl = likeBtn.querySelector('.like-count'); if (countEl) countEl.textContent = j.likes;
              likeBtn.animate([
                { transform: 'scale(1)' },
                { transform: 'scale(1.06)' },
                { transform: 'scale(1)' }
              ], { duration: 260 });
            }
          } catch (e) { console.error('Like error', e); }
        };

      const commentToggle = document.createElement('button');
      commentToggle.className = 'px-3 py-1 bg-gray-100 text-slate-800 rounded';
      commentToggle.textContent = `Comments (${(n.comments && n.comments.length) || 0})`;
      const commentsBox = document.createElement('div');
      commentsBox.className = 'mt-2 bg-slate-50 p-2 rounded hidden';

      commentToggle.onclick = () => {
        commentsBox.classList.toggle('hidden');
      };

      // Comments list
      const commentsList = document.createElement('div');
      commentsList.className = 'space-y-2';
      (n.comments || []).forEach(c => {
        const cdiv = document.createElement('div');
        cdiv.className = 'text-sm text-slate-700';
        cdiv.innerHTML = `<strong class='text-slate-900'>${escapeHtml(c.user||'Anonymous')}</strong>: ${escapeHtml(c.text)}`;
        commentsList.appendChild(cdiv);
      });

      // Add comment form
      const commentForm = document.createElement('div');
      commentForm.className = 'mt-2 flex gap-2 items-start';
      const commentInput = document.createElement('input');
      commentInput.type = 'text';
      commentInput.placeholder = 'Add a comment';
      commentInput.className = 'flex-1 p-2 border rounded';

      // Post button (paper-plane icon). Disabled until input has content.
      const commentBtn = document.createElement('button');
        commentBtn.className = 'px-3 py-2 h-10 bg-indigo-600 text-white rounded flex items-center gap-2 disabled:opacity-60';
      commentBtn.disabled = true;
      // Use a supported Font Awesome paper-plane icon (fallback)
      commentBtn.innerHTML = `
        <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
        <span class="sr-only">Send comment</span>
      `;

      // Enable/disable post button based on input
      commentInput.addEventListener('input', () => {
        commentBtn.disabled = commentInput.value.trim().length === 0;
      });

      if (!IS_LOGGED_IN) {
        // Logged-out: disable input and show a Login button instead
        commentInput.disabled = true;
        commentInput.placeholder = 'Login to comment';
        commentBtn.disabled = false;
          commentBtn.className = 'px-3 py-2 h-10 border border-indigo-600 text-indigo-600 rounded';
        commentBtn.textContent = 'Login';
        commentBtn.onclick = redirectToLogin;
      } else {
        // Logged-in: post comment
        commentBtn.addEventListener('click', async () => {
          const text = commentInput.value.trim();
          if (!text) return;
          try {
            const res = await fetch(`/states/${currentState._id}/topics/${topic._id}/news/${n._id}/comment`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'same-origin',
              body: JSON.stringify({ text })
            });
            if (res.status === 401) { redirectToLogin(); return; }
            const j = await res.json().catch(() => null);
            if (j && j.success) {
              commentInput.value = '';
              commentBtn.disabled = true;
            }
          } catch (e) {
            console.error('Comment error', e);
          }
        });
      }

      commentForm.appendChild(commentInput);
      commentForm.appendChild(commentBtn);
      commentsBox.appendChild(commentsList);
      commentsBox.appendChild(commentForm);

      actions.appendChild(likeBtn);
      actions.appendChild(commentToggle);
      card.appendChild(actions);
      card.appendChild(commentsBox);

      listEl.appendChild(card);
    });
  }

  // Defer startup to DOMContentLoaded and catch runtime errors so we can debug why nothing renders
  document.addEventListener('DOMContentLoaded', () => {
    try {
      console.log('States SPA starting', { IS_LOGGED_IN });
      loadStates();

      // Socket.IO realtime updates
      (function initRealtime(){
    try {
      const script = document.createElement('script');
      script.src = '/socket.io/socket.io.js';
      script.onload = () => {
        const socket = io();
        socket.on('news:like', (payload) => {
          // find matching card and update like count
          const { stateId, topicId, newsId, likes } = payload;
          if (!currentState || currentState._id != stateId) return;
          if (!document.querySelector) return;
          document.querySelectorAll('#stateNewsList .rounded-xl').forEach(card => {
            if (card.dataset && card.dataset.newsId == newsId) {
              const lc = card.querySelector('.like-count'); if (lc) lc.textContent = likes;
            }
          });
        });

        socket.on('news:comment', (payload) => {
          const { stateId, topicId, newsId, comment } = payload;
          if (!currentState || currentState._id != stateId) return;
          document.querySelectorAll('#stateNewsList .rounded-xl').forEach(card => {
            if (card.dataset && card.dataset.newsId == newsId) {
              const commentsList = card.querySelector('.space-y-2');
              if (commentsList) {
                const cdiv = document.createElement('div');
                cdiv.className = 'text-sm text-slate-700';
                cdiv.innerHTML = `<strong class='text-slate-900'>${escapeHtml(comment.user||'Anonymous')}</strong>: ${escapeHtml(comment.text)}`;
                commentsList.appendChild(cdiv);
                const toggle = card.querySelector('button'); // rough
                const commentToggle = card.querySelector('button:nth-of-type(2)');
                if (commentToggle) {
                  const m = commentToggle.textContent.match(/Comments \((\d+)\)/);
                  const num = m ? parseInt(m[1],10)+1 : (commentsList.children.length);
                  commentToggle.textContent = `Comments (${num})`;
                }
              }
            }
          });
        });
      };
      document.head.appendChild(script);
    } catch (e) { console.warn('Realtime init failed', e); }
      })();
    } catch (err) {
      showClientError('Unhandled SPA error', err && err.stack ? err.stack : err);
    }
  });
</script>

<%- include('../partials/footer') %>




