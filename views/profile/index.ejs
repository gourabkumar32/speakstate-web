<%- include('../partials/header', { title: 'Profile' }) %>

    <head>
        <script async
            src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8814468973632188"
            crossorigin="anonymous"></script>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    </head>

    <% const displayName=user && user.anonName ? user.anonName : (user && user.name ? user.name : 'User' ); %>
        <% const isAnon=!!(user && user.anonName); %>

            <style>
                /* Custom Scrollbar for Comment Section */
                .comments-list-container::-webkit-scrollbar {
                    width: 5px;
                }

                .comments-list-container::-webkit-scrollbar-track {
                    background: #f8fafc;
                }

                .comments-list-container::-webkit-scrollbar-thumb {
                    background: #cbd5e1;
                    border-radius: 10px;
                }

                .tab-content {
                    display: none;
                    transition: opacity 0.3s ease;
                }

                .tab-content.active {
                    display: block;
                    opacity: 1;
                }

                .glass-effect {
                    background: rgba(255, 255, 255, 0.95);
                    backdrop-filter: blur(8px);
                }
            </style>

            <div class="bg-slate-50 min-h-screen pb-12">
                <!-- Flash Messages -->
                <% if (typeof error !=='undefined' && error && error.length> 0) { %>
                    <div class="max-w-7xl mx-auto px-4 pt-6">
                        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-sm flex items-center"
                            role="alert">
                            <i class="fas fa-exclamation-circle mr-3"></i>
                            <p class="font-medium">
                                <%= error %>
                            </p>
                        </div>
                    </div>
                    <% } %>
                        <!-- Success Message -->
                        <% if (typeof success !=='undefined' && success && success.length> 0) { %>
                            <div class="max-w-7xl mx-auto px-4 pt-6">
                                <div id="flash-success-message"
                                    class="bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg shadow-sm flex items-center"
                                    role="alert">
                                    <i class="fas fa-check-circle mr-3"></i>
                                    <p class="font-medium">
                                        <%= success %>
                                    </p>
                                </div>
                            </div>
                            <% } %>

                                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
                                    <div class="flex flex-col lg:flex-row gap-8">

                                        <!-- LEFT COLUMN: PROFILE CARD -->
                                        <aside class="w-full lg:w-1/3 xl:w-1/4">
                                            <div class="lg:sticky lg:top-24">
                                                <!-- View Mode Card -->
                                                <div id="viewMode"
                                                    class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden transform transition-all">
                                                    <!-- Banner -->
                                                    <div
                                                        class="h-32 bg-gradient-to-r from-blue-600 to-indigo-600 relative">
                                                        <div class="absolute -bottom-12 left-1/2 -translate-x-1/2">
                                                            <div
                                                                class="w-24 h-24 rounded-2xl overflow-hidden border-4 border-white shadow-xl bg-slate-100">
                                                                <% const avatarTweet={ isAnonymous: isAnon,
                                                                    displayProfilePicture: user && user.profilePicture ?
                                                                    `/uploads/profiles/${user.profilePicture}`
                                                                    : '/img/default-avatar.png' , displayName:
                                                                    displayName }; %>
                                                                    <%- include('../partials/avatar', { tweet:
                                                                        avatarTweet, sizeClass: 'w-full h-full' ,
                                                                        showAnonymousImage: false }) %>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- User Info -->
                                                    <div class="pt-16 pb-6 px-6 text-center">
                                                        <h1 class="text-xl font-bold text-slate-900 truncate">
                                                            <%= displayName %>
                                                        </h1>
                                                        <div
                                                            class="flex items-center justify-center mt-1 text-slate-500 text-sm">
                                                            <i class="fas fa-map-marker-alt mr-1.5 text-blue-500"></i>
                                                            <span>
                                                                <%= user.state %>
                                                            </span>
                                                            <% if (user.constituency) { %>
                                                                <span class="mx-1.5 opacity-30">|</span>
                                                                <span>
                                                                    <%= user.constituency %>
                                                                </span>
                                                                <% } %>
                                                        </div>

                                                        <!-- Modern Stats Grid -->
                                                        <div
                                                            class="grid grid-cols-2 gap-2 mt-8 py-4 border-y border-slate-100">
                                                            <div class="text-center border-r border-slate-100">
                                                                <div class="text-lg font-bold text-slate-900">
                                                                    <%= tweets.length %>
                                                                </div>
                                                                <div
                                                                    class="text-[10px] uppercase tracking-wider font-semibold text-slate-400">
                                                                    Posts</div>
                                                            </div>
                                                            <div class="text-center">
                                                                <div class="text-lg font-bold text-slate-900">
                                                                    <%= typeof userReviews !=='undefined' ?
                                                                        userReviews.length : 0 %>
                                                                </div>
                                                                <div
                                                                    class="text-[10px] uppercase tracking-wider font-semibold text-slate-400">
                                                                    Reviews</div>
                                                            </div>
                                                        </div>

                                                        <button onclick="toggleEditMode()"
                                                            class="w-full mt-6 bg-slate-900 hover:bg-black text-white py-3 rounded-2xl font-bold text-sm transition-all duration-200 shadow-lg shadow-slate-200">
                                                            <i class="fas fa-user-edit mr-2 text-xs"></i>Edit
                                                            Profile
                                                        </button>
                                                    </div>
                                                </div>

                                                <!-- Edit Mode Form -->
                                                <form id="editMode" action="/profile/update" method="POST"
                                                    enctype="multipart/form-data"
                                                    class="hidden glass-effect rounded-3xl shadow-2xl border border-slate-200 p-6 space-y-4">
                                                    <h2 class="text-lg font-bold text-slate-900">Update Profile</h2>

                                                    <div class="space-y-4">
                                                        <div>
                                                            <label
                                                                class="block text-xs font-bold text-slate-500 uppercase mb-1">Display
                                                                Name</label>
                                                            <input type="text" name="anonName"
                                                                value="<%= user.anonName || '' %>"
                                                                placeholder="Anonymous handle"
                                                                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                                                        </div>

                                                        <div>
                                                            <label
                                                                class="block text-xs font-bold text-slate-500 uppercase mb-1">Profile
                                                                Photo</label>
                                                            <div class="relative group">
                                                                <input type="file" name="profilePicture"
                                                                    accept="image/*"
                                                                    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                                                <div
                                                                    class="w-full border-2 border-dashed border-slate-200 rounded-xl py-4 text-center text-slate-400 group-hover:border-blue-400 transition-colors">
                                                                    <i class="fas fa-camera mb-1"></i>
                                                                    <p class="text-[10px]">Click to upload</p>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div>
                                                            <label
                                                                class="block text-xs font-bold text-slate-500 uppercase mb-1">State</label>
                                                            <select name="state" required
                                                                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                                                                <% ['Andhra Pradesh', 'Arunachal Pradesh' , 'Assam'
                                                                    , 'Bihar' , 'Chhattisgarh' , 'Goa' , 'Gujarat'
                                                                    , 'Haryana' , 'Himachal Pradesh' , 'Jharkhand'
                                                                    , 'Karnataka' , 'Kerala' , 'Madhya Pradesh'
                                                                    , 'Maharashtra' , 'Manipur' , 'Meghalaya'
                                                                    , 'Mizoram' , 'Nagaland' , 'Odisha' , 'Punjab'
                                                                    , 'Rajasthan' , 'Sikkim' , 'Tamil Nadu'
                                                                    , 'Telangana' , 'Tripura' , 'Uttar Pradesh'
                                                                    , 'Uttarakhand' , 'West Bengal'
                                                                    ].forEach(function(state) { %>
                                                                    <option value="<%= state %>" <%=user.state===state
                                                                        ? 'selected' : '' %>>
                                                                        <%= state %>
                                                                    </option>
                                                                    <% }); %>
                                                            </select>
                                                        </div>

                                                        <div>
                                                            <label
                                                                class="block text-xs font-bold text-slate-500 uppercase mb-1">Constituency</label>
                                                            <input type="text" name="constituency"
                                                                value="<%= user.constituency || '' %>"
                                                                placeholder="Your constituency"
                                                                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                                                        </div>
                                                    </div>

                                                    <div class="flex gap-2 pt-2">
                                                        <button type="button" onclick="toggleEditMode()"
                                                            class="flex-1 bg-slate-100 text-slate-600 font-bold py-2.5 rounded-xl text-sm">Cancel</button>
                                                        <button type="submit"
                                                            class="flex-1 bg-blue-600 text-white font-bold py-2.5 rounded-xl text-sm shadow-md shadow-blue-100">Save</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </aside>

                                        <!-- RIGHT COLUMN: FEED -->
                                        <main class="flex-1 max-w-3xl">
                                            <!-- Composer Entry -->
                                            <div
                                                class="bg-white rounded-3xl shadow-sm border border-slate-200 p-4 mb-6">
                                                <div class="flex items-center gap-4">
                                                    <div
                                                        class="w-10 h-10 rounded-xl overflow-hidden shadow-sm flex-shrink-0">
                                                        <% const writerAvatar={ displayName: displayName,
                                                            displayProfilePicture: user && user.profilePicture ?
                                                            `/uploads/profiles/${user.profilePicture}`
                                                            : '/img/default-avatar.png' , isAnonymous: !!user.anonName
                                                            }; %>
                                                            <%- include('../partials/avatar', { tweet: writerAvatar,
                                                                sizeClass: 'w-full h-full' , showAnonymousImage: false
                                                                }) %>
                                                    </div>
                                                    <button onclick="openCreateTweetModal()"
                                                        class="flex-1 bg-slate-50 hover:bg-slate-100 text-slate-500 rounded-2xl py-3 px-5 text-left text-sm font-medium transition-all border border-slate-100">
                                                        What's the latest update, <%= displayName.split(' ')[0] %>?
                        </button>
                    </div>
                </div>

                <!-- Tabs & Content -->
                <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
                    <!-- Tab Header -->
                    <div class="flex px-2 border-b border-slate-100">
                        <button onclick="switchTab(event, ' posts')"
                                                            class="tab-button flex-1 py-4 text-sm font-bold border-b-2 border-blue-600 text-blue-600 transition-all">
                                                            My Posts
                                                    </button>
                                                    <button onclick="switchTab(event, 'reviews')"
                                                        class="tab-button flex-1 py-4 text-sm font-bold border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all">
                                                        Reviews
                                                    </button>
                                                </div>

                                                <!-- Posts Tab -->
                                                <section id="posts" class="tab-content active">
                                                    <% if (typeof tweets !=='undefined' && tweets.length> 0) { %>
                                                        <div class="divide-y divide-slate-100">
                                                            <% tweets.forEach(function(tweet) { %>
                                                                <div class="p-6 hover:bg-slate-50/50 transition-colors relative"
                                                                    data-tweet-id="<%= tweet._id %>">
                                                                    <div class="flex items-start gap-4">
                                                                        <div
                                                                            class="w-10 h-10 rounded-xl overflow-hidden flex-shrink-0 shadow-sm">
                                                                            <%- include('../partials/avatar', { tweet:
                                                                                tweet, showAnonymousImage: false }) %>
                                                                        </div>
                                                                        <div class="flex-1 min-w-0">
                                                                            <div
                                                                                class="flex justify-between items-start">
                                                                                <div>
                                                                                    <span
                                                                                        class="font-bold text-slate-900">
                                                                                        <%= tweet.isAnonymous ?
                                                                                            (tweet.displayName
                                                                                            || 'Anonymous' ) :
                                                                                            (tweet.displayName
                                                                                            || 'Unknown' ) %>
                                                                                    </span>
                                                                                    <span
                                                                                        class="tweet-time text-[11px] text-slate-400 ml-2"
                                                                                        data-timestamp="<%= tweet.createdAt %>"></span>
                                                                                </div>

                                                                                <% if (currentUser &&
                                                                                    tweet.user._id.toString()===currentUser._id.toString())
                                                                                    { %>
                                                                                    <div class="relative">
                                                                                        <button
                                                                                            onclick="toggleTweetMenu(this)"
                                                                                            class="p-1.5 text-slate-400 hover:text-slate-900 hover:bg-white rounded-lg transition-all">
                                                                                            <i
                                                                                                class="fas fa-ellipsis-h text-sm"></i>
                                                                                        </button>
                                                                                        <div
                                                                                            class="tweet-menu hidden absolute right-0 mt-2 w-36 glass-effect rounded-2xl shadow-xl z-20 border border-slate-200 overflow-hidden">
                                                                                            <button
                                                                                                onclick="editTweet('<%= tweet._id %>')"
                                                                                                class="w-full text-left px-4 py-2.5 text-xs font-bold text-slate-700 hover:bg-slate-50 border-b border-slate-50">
                                                                                                <i
                                                                                                    class="far fa-edit mr-2"></i>Edit
                                                                                            </button>
                                                                                            <button
                                                                                                onclick="deleteTweet('<%= tweet._id %>')"
                                                                                                class="w-full text-left px-4 py-2.5 text-xs font-bold text-red-600 hover:bg-red-50">
                                                                                                <i
                                                                                                    class="far fa-trash-alt mr-2"></i>Delete
                                                                                            </button>
                                                                                        </div>
                                                                                    </div>
                                                                                    <% } %>
                                                                            </div>

                                                                            <div
                                                                                class="mt-2 text-slate-700 text-sm leading-relaxed whitespace-pre-line">
                                                                                <%- tweet.enrichedContent ||
                                                                                    tweet.content %>
                                                                            </div>

                                                                            <% if (tweet.location) { %>
                                                                                <div
                                                                                    class="mt-2 inline-flex items-center text-[10px] font-bold text-blue-500 bg-blue-50 px-2 py-0.5 rounded-md">
                                                                                    <i
                                                                                        class="fas fa-map-marker-alt mr-1.5"></i>
                                                                                    <%= tweet.location %>
                                                                                </div>
                                                                                <% } %>

                                                                                    <% if (tweet.media &&
                                                                                        tweet.media.length> 0)
                                                                                        { %>
                                                                                        <div
                                                                                            class="mt-4 grid gap-2 rounded-2xl overflow-hidden <%= tweet.media.length === 1 ? '' : 'grid-cols-2' %>">
                                                                                            <% tweet.media.forEach(function(mediaItem)
                                                                                                { %>
                                                                                                <img src="/uploads/tweets/<%= mediaItem %>"
                                                                                                    class="w-full h-48 object-cover cursor-zoom-in hover:scale-105 transition-transform duration-500"
                                                                                                    onclick="showImageModal(this.src)"
                                                                                                    onerror="this.src='/images/placeholder.png';">
                                                                                                <% }); %>
                                                                                        </div>
                                                                                        <% } %>

                                                                                            <!-- Engagement -->
                                                                                            <div
                                                                                                class="flex gap-6 mt-5 pt-4 border-t border-slate-50">
                                                                                                <button
                                                                                                    onclick="handleLike(event, '<%= tweet._id %>', true)"
                                                                                                    class="flex items-center gap-1.5 group">
                                                                                                    <div
                                                                                                        class="w-8 h-8 rounded-full flex items-center justify-center transition-all <%= tweet.isLiked ? 'text-red-500 bg-red-50' : 'text-slate-400 group-hover:text-red-500 group-hover:bg-red-50' %>">
                                                                                                        <i
                                                                                                            class="<%= tweet.isLiked ? 'fas' : 'far' %> fa-heart"></i>
                                                                                                    </div>
                                                                                                    <span
                                                                                                        class="text-xs font-bold text-slate-500">
                                                                                                        <%= tweet.likes
                                                                                                            ?
                                                                                                            tweet.likes.length
                                                                                                            : 0 %>
                                                                                                    </span>
                                                                                                </button>
                                                                                                <button
                                                                                                    onclick="handleComment(event, '<%= tweet._id %>')"
                                                                                                    class="flex items-center gap-1.5 group">
                                                                                                    <div
                                                                                                        class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 group-hover:text-blue-500 group-hover:bg-blue-50 transition-all">
                                                                                                        <i
                                                                                                            class="far fa-comment"></i>
                                                                                                    </div>
                                                                                                    <span
                                                                                                        class="text-xs font-bold text-slate-500">
                                                                                                        <%= tweet.comments
                                                                                                            ?
                                                                                                            tweet.comments.length
                                                                                                            : 0 %>
                                                                                                    </span>
                                                                                                </button>
                                                                                            </div>

                                                                                            <!-- Comment Section -->
                                                                                            <div id="comments-section-<%= tweet._id %>"
                                                                                                class="hidden mt-4 pt-4 border-t border-slate-50">
                                                                                                <% if (currentUser) { %>
                                                                                                    <form
                                                                                                        class="comment-form flex gap-3 mb-4"
                                                                                                        data-tweet-id="<%= tweet._id %>">
                                                                                                        <input
                                                                                                            type="text"
                                                                                                            class="flex-1 bg-slate-50 border-none rounded-xl px-4 py-2 text-sm focus:ring-1 focus:ring-blue-500 outline-none"
                                                                                                            placeholder="Write a comment...">
                                                                                                        <button
                                                                                                            type="submit"
                                                                                                            class="bg-blue-600 text-white w-10 h-10 rounded-xl flex items-center justify-center shadow-sm"><i
                                                                                                                class="fas fa-paper-plane text-sm"></i></button>
                                                                                                    </form>
                                                                                                    <% } %>
                                                                                                        <div id="comments-list-<%= tweet._id %>"
                                                                                                            class="comments-list-container max-h-60 overflow-y-auto space-y-3 pr-2">
                                                                                                            <!-- Comments injected here -->
                                                                                                        </div>
                                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <% }); %>
                                                        </div>
                                                        <% } else { %>
                                                            <div class="py-20 text-center">
                                                                <div
                                                                    class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4">
                                                                    <i class="far fa-edit text-slate-300 text-2xl"></i>
                                                                </div>
                                                                <p class="text-slate-400 font-medium">You haven't
                                                                    posted
                                                                    anything yet.</p>
                                                            </div>
                                                            <% } %>
                                                </section>

                                                <!-- Reviews Tab -->
                                                <section id="reviews" class="tab-content">
                                                    <% if (typeof userReviews !=='undefined' && userReviews.length>
                                                        0) { %>
                                                        <div class="divide-y divide-slate-100">
                                                            <% userReviews.forEach(function(item) { %>
                                                                <div class="p-6 hover:bg-slate-50 transition-colors">
                                                                    <div class="flex items-center justify-between mb-3">
                                                                        <div class="flex items-center gap-3">
                                                                            <div
                                                                                class="px-2 py-0.5 rounded bg-slate-900 text-[9px] font-black text-white uppercase">
                                                                                <%= item.leaderType %>
                                                                            </div>
                                                                            <h4
                                                                                class="font-bold text-slate-900 text-sm">
                                                                                <%= item.leaderName %>
                                                                            </h4>
                                                                        </div>
                                                                        <div class="relative">
                                                                            <button onclick="toggleReviewMenu(this)"
                                                                                class="p-1.5 text-slate-400 hover:text-slate-900 hover:bg-white rounded-lg transition-all">
                                                                                <i
                                                                                    class="fas fa-ellipsis-h text-sm"></i>
                                                                            </button>
                                                                            <div
                                                                                class="review-menu hidden absolute right-0 mt-2 w-36 glass-effect rounded-2xl shadow-xl z-20 border border-slate-200 overflow-hidden">
                                                                                <button
                                                                                    onclick="prepareProfileEditReview(this)"
                                                                                    data-review-id="<%= item.review._id %>"
                                                                                    data-leader-id="<%= item.leaderId %>"
                                                                                    data-leader-type="<%= item.leaderType %>"
                                                                                    data-rating="<%= item.review.rating %>"
                                                                                    data-comment="<%= item.review.comment %>"
                                                                                    class="w-full text-left px-4 py-2.5 text-xs font-bold text-slate-700 hover:bg-slate-50 border-b border-slate-50">
                                                                                    <i class="far fa-edit mr-2"></i>Edit
                                                                                </button>
                                                                                <button
                                                                                    onclick="deleteProfileReview('<%= item.review._id %>', '<%= item.leaderId %>', '<%= item.leaderType %>')"
                                                                                    class="w-full text-left px-4 py-2.5 text-xs font-bold text-red-600 hover:bg-red-50">
                                                                                    <i
                                                                                        class="far fa-trash-alt mr-2"></i>Delete
                                                                                </button>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="flex text-yellow-400 gap-0.5 mb-2">
                                                                        <% for(let i=1; i<=5; i++) { %>
                                                                            <i
                                                                                class="<%= i <= item.review.rating ? 'fas' : 'far' %> fa-star text-[10px]"></i>
                                                                            <% } %>
                                                                    </div>
                                                                    <p class="text-slate-600 text-sm italic">"<%=
                                                                            item.review.comment %>"</p>
                                                                    <div
                                                                        class="mt-4 flex justify-between items-center text-[10px] font-bold text-slate-400 uppercase tracking-tighter">
                                                                        <span>
                                                                            <%= new
                                                                                Date(item.review.createdAt).toLocaleDateString()
                                                                                %>
                                                                        </span>
                                                                        <a href="/<%= item.leaderType %>s/<%= item.leaderId %>/reviews"
                                                                            class="text-slate-500 hover:underline ml-2">View
                                                                            Profile</a>
                                                                    </div>
                                                                </div>
                                                                <% }); %>
                                                        </div>
                                                        <% } else { %>
                                                            <div class="py-20 text-center">
                                                                <p class="text-slate-400 font-medium">You haven't
                                                                    submitted any
                                                                    reviews.</p>
                                                            </div>
                                                            <% } %>
                                                </section>
                                            </div>
                                        </main>
                                    </div>
                                </div>
            </div>

            <!-- Review Edit Modal -->
            <div id="profileReviewModal"
                class="fixed inset-0 bg-gray-600 bg-opacity-50 flex items-center justify-center hidden z-[100]">
                <div class="bg-white rounded-lg p-6 w-full max-w-lg shadow-2xl">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-xl font-semibold">Edit Review</h3>
                        <button onclick="closeProfileReviewModal()" class="text-gray-500 hover:text-gray-700">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                    <form id="profileReviewForm" class="space-y-4">
                        <input type="hidden" id="editReviewId">
                        <input type="hidden" id="editLeaderId">
                        <input type="hidden" id="editLeaderType">

                        <div>
                            <label class="block text-sm font-medium text-gray-700">Rating</label>
                            <div class="flex gap-2 mt-1" id="profileRatingStars">
                                <% for(var i=1; i <=5; i++) { %>
                                    <button type="button"
                                        onclick="setProfileRating(this.querySelector('svg').dataset.rating)"
                                        class="profile-star-button p-1 focus:outline-none">
                                        <svg class="h-8 w-8" viewBox="0 0 20 20" data-rating="<%= i %>">
                                            <path fill="#D1D5DB"
