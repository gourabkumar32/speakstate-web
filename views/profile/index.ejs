            <script>
                // Profile Review Logic
                let currentProfileRating = 0;

                function toggleReviewMenu(btn) {
                    // Close other open menus first
                    document.querySelectorAll('.review-menu').forEach(menu => {
                        if (menu !== btn.nextElementSibling) {
                            menu.classList.add('hidden');
                        }
                    });

                    const menu = btn.nextElementSibling;
                    menu.classList.toggle('hidden');
                }

                // Close menus when clicking outside
                document.addEventListener('click', function (e) {
                    if (!e.target.closest('.relative')) {
                        document.querySelectorAll('.review-menu').forEach(menu => {
                            menu.classList.add('hidden');
                        });
                    }
                });

                function setProfileRating(rating) {
                    currentProfileRating = rating;
                    document.getElementById('profileRating').value = rating;
                    const stars = document.querySelectorAll('.profile-star-button svg path');
                    stars.forEach((star) => {
                        const starRating = parseInt(star.closest('svg').dataset.rating);
                        star.setAttribute('fill', starRating <= rating ? '#F59E0B' : '#D1D5DB');
                    });
                }

                function prepareProfileEditReview(btn) {
                    const reviewId = btn.dataset.reviewId;
                    const leaderId = btn.dataset.leaderId;
                    const leaderType = btn.dataset.leaderType;
                    const rating = parseInt(btn.dataset.rating);
                    const comment = btn.dataset.comment;

                    showEditReviewModal(reviewId, leaderId, leaderType, rating, comment);
                }

                function showEditReviewModal(reviewId, leaderId, leaderType, rating, comment) {
                    document.getElementById('editReviewId').value = reviewId;
                    document.getElementById('editLeaderId').value = leaderId;
                    document.getElementById('editLeaderType').value = leaderType;

                    document.getElementById('profileReviewModal').classList.remove('hidden');
                    setProfileRating(rating);
                    document.getElementById('profileComment').value = comment;
                }

                function closeProfileReviewModal() {
                    document.getElementById('profileReviewModal').classList.add('hidden');
                }

                async function deleteProfileReview(reviewId, leaderId, leaderType) {
                    if (!confirm('Are you sure you want to delete this review?')) return;

                    const endpoint = leaderType === 'mla' ? 'mlas' : 'mps';

                    try {
                        const response = await fetch(`/${endpoint}/${leaderId}/reviews/${reviewId}`, {
                            method: 'DELETE'
                        });
                        const result = await response.json();

                        if (result.success) {
                            window.location.href = window.location.pathname + '?tab=reviews';
                        } else {
                            alert(result.message || 'Failed to delete review');
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        alert('Error deleting review');
                    }
                }

                document.getElementById('profileReviewForm').addEventListener('submit', function (e) {
                    e.preventDefault();
                    const rating = document.getElementById('profileRating').value;
                    const comment = document.getElementById('profileComment').value;
                    const reviewId = document.getElementById('editReviewId').value;
                    const leaderId = document.getElementById('editLeaderId').value;
                    const leaderType = document.getElementById('editLeaderType').value;

                    if (!rating) {
                        alert('Please select a rating');
                        return;
                    }

                    const endpoint = leaderType === 'mla' ? 'mlas' : 'mps';

                    fetch(`/${endpoint}/${leaderId}/reviews/${reviewId}`, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ rating, comment })
                    })
                        .then(async response => {
                            if (response.status === 401) {
                                window.location.reload();
                                return;
                            }
                            const result = await response.json();
                            if (result.success) {
                                closeProfileReviewModal();
                                window.location.href = window.location.pathname + '?tab=reviews';
                            } else {
                                alert(result.message || 'Failed to update review');
                            }
                        })
                        .catch((err) => {
                            console.error(err);
                            alert('Error updating review');
                        });
                });
            </script>

