            <script>
                // Tab Logic
                function switchTab(event, tabName) {
                    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                    document.getElementById(tabName.trim()).classList.add('active');

                    // Update URL params
                    const url = new URL(window.location);
                    url.searchParams.set('tab', tabName.trim());
                    window.history.pushState({}, '', url);

                    // Update button styles
                    document.querySelectorAll('.tab-button').forEach(btn => {
                        if (btn.textContent.trim().toLowerCase().includes(tabName.trim())) {
                            btn.classList.add('border-blue-600', 'text-blue-600');
                            btn.classList.remove('border-transparent', 'text-slate-400');
                        } else {
                            btn.classList.remove('border-blue-600', 'text-blue-600');
                            btn.classList.add('border-transparent', 'text-slate-400');
                        }
                    });
                }

                // On load, check tab param
                const urlParams = new URLSearchParams(window.location.search);
                const tab = urlParams.get('tab');
                if (tab) {
                    switchTab(null, tab);
                }

                // Initialize tab from URL (legacy check)
                document.addEventListener('DOMContentLoaded', () => {
                    const params = new URLSearchParams(window.location.search);
                    if (params.get('tab') === 'reviews') {
                        const reviewsBtn = document.querySelector('button[onclick*="\'reviews\'"]');
                        if (reviewsBtn) {
                            switchTab(reviewsBtn, 'reviews');
                        }
                    }
                });

                // Word counter helper
                function setupTweetWordCounter(textareaId, remainingId, errorId, formId) {
                    const ta = document.getElementById(textareaId);
                    const remainingEl = document.getElementById(remainingId);
                    const errorEl = document.getElementById(errorId);
                    const form = document.getElementById(formId);
                    if (!ta || !remainingEl) return;

                    function update() {
                        const words = ta.value.trim().split(/\s+/).filter(Boolean).length;
                        const remaining = 300 - words;
                        remainingEl.textContent = `${Math.abs(remaining)} WORDS ${remaining < 0 ? 'OVER' : 'LEFT'}`;
                        if (remaining < 0) {
                            remainingEl.classList.add('bg-red-100', 'text-red-600');
                            errorEl?.classList.remove('hidden');
                        } else {
                            remainingEl.classList.remove('bg-red-100', 'text-red-600');
                            errorEl?.classList.add('hidden');
                        }
                    }
                    ta.addEventListener('input', update);
                    update();
                }

                // Modal Helpers 
                function toggleEditMode() {
                    const view = document.getElementById('viewMode');
                    const edit = document.getElementById('editMode');
                    view.classList.toggle('hidden');
                    edit.classList.toggle('hidden');
                }

                function openCreateTweetModal() {
                    document.getElementById('createTweetModal').classList.remove('hidden');
                    document.body.classList.add('overflow-hidden');
                }

                function closeCreateTweetModal() {
                    document.getElementById('createTweetModal').classList.add('hidden');
                    document.body.classList.remove('overflow-hidden');
                }

                function openEditTweetModal() {
                    document.getElementById('editTweetModal').classList.remove('hidden');
                    document.body.classList.add('overflow-hidden');
                }

                function closeEditTweetModal() {
                    document.getElementById('editTweetModal').classList.add('hidden');
                    document.body.classList.remove('overflow-hidden');
                }

                function showImageModal(src) {
                    document.getElementById('modalImage').src = src;
                    document.getElementById('imageModal').classList.remove('hidden');
                }

                function closeImageModal() {
                    document.getElementById('imageModal').classList.add('hidden');
                }

                function toggleTweetMenu(button) {
                    const menu = button.nextElementSibling;
                    const allMenus = document.querySelectorAll('.tweet-menu');
                    allMenus.forEach(m => { if (m !== menu) m.classList.add('hidden'); });
                    menu.classList.toggle('hidden');
                }

                // Time Formatting
                function timeAgo(date) {
                    const now = new Date();
                    const diffSecs = Math.round((now - date) / 1000);
                    const diffMins = Math.round(diffSecs / 60);
                    const diffHours = Math.round(diffMins / 60);
                    if (diffSecs < 60) return 'Just now';
                    if (diffMins < 60) return `${diffMins}m`;
                    if (diffHours < 24) return `${diffHours}h`;
                    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                }

                document.addEventListener('DOMContentLoaded', () => {
                    document.querySelectorAll('.tweet-time').forEach(el => {
                        const ts = el.getAttribute('data-timestamp');
                        if (ts) el.textContent = `· ${timeAgo(new Date(ts))}`;
                    });

                    setupTweetWordCounter('createTweetContent', 'createTweetRemaining', 'createTweetError', 'createTweetForm');
                    setupTweetWordCounter('editTweetContent', 'editTweetRemaining', 'editTweetError', 'editTweetForm');

                    // Media count logic
                    const mediaInput = document.getElementById('createTweetMedia');
                    const mediaLabel = document.getElementById('mediaCountLabel');
                    if (mediaInput && mediaLabel) {
                        mediaInput.addEventListener('change', function () {
                            const count = this.files.length;
                            if (count > 0) {
                                mediaLabel.innerHTML = `<i class="fas fa-check mr-2 text-green-500"></i>${count} file${count === 1 ? '' : 's'} selected`;
                                mediaLabel.classList.add('text-slate-900', 'font-medium');
                            } else {
                                mediaLabel.innerHTML = `<i class="far fa-image mr-2"></i>Select files`;
                                mediaLabel.classList.remove('text-slate-900', 'font-medium');
                            }
                        });
                    }
                });

                // Close menus/modals on background click
                window.onclick = function (event) {
                    if (event.target.classList.contains('fixed')) {
                        closeCreateTweetModal();
                        closeEditTweetModal();
                        closeImageModal();
                    }
                }
            </script>

