<!-- Edit Work Modal -->
<div id="editWorkModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-lg w-full max-w-4xl mx-4 max-h-[85vh] overflow-y-auto">
        <div class="p-4 border-b">
            <div class="flex justify-between items-center">
                <h3 class="text-xl font-semibold">Edit Work Detail</h3>
                <button onclick="closeEditWorkModal()" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>

        <form id="editWorkForm" class="p-6" enctype="multipart/form-data">
            <input type="hidden" id="editWorkId" name="workId">
            <input type="hidden" id="editLeaderId" name="leaderId">
            <input type="hidden" id="editLeaderType" name="leaderType">

            <div class="space-y-6">
                <!-- Title -->
                <div>
                    <label for="editWorkTitle" class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                    <input type="text" id="editWorkTitle" name="title"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>

                <!-- Description -->
                <div>
                    <label for="editWorkDescription"
                        class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                    <textarea id="editWorkDescription" name="description" rows="3"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                </div>

                <!-- Status -->
                <div>
                    <label for="editWorkStatus" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select id="editWorkStatus" name="status"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="Needed">Needed</option>
                        <option value="Planned">Planned</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Delayed">Delayed</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                        <option value="On Hold">On Hold</option>
                    </select>
                </div>

                <!-- Location -->
                <div>
                    <label for="editWorkLocation" class="block text-sm font-medium text-gray-700 mb-1">Location</label>
                    <input type="text" id="editWorkLocation" name="location"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>

                <!-- Current Images -->
                <div id="currentWorkImages" class="space-y-4">
                    <label class="block text-sm font-medium text-gray-700">Current Images</label>
                    <div id="currentWorkImagesGrid" class="grid grid-cols-2 sm:grid-cols-3 gap-4"></div>
                </div>

                <!-- New Images -->
                <div>
                    <label class="block text-sm font-medium text-gray-700">Add New Images (Up to 5)</label>
                    <div
                        class="mt-2 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg hover:border-blue-400 transition-all duration-200">
                        <div class="space-y-1 text-center">
                            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none"
                                viewBox="0 0 48 48" aria-hidden="true">
                                <path
                                    d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <div class="flex text-sm text-gray-600">
                                <label for="editWorkImages"
                                    class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-blue-500">
                                    <span>Upload files</span>
                                    <input id="editWorkImages" name="images" type="file" class="sr-only" multiple
                                        accept="image/*" onchange="previewWorkImages(this)">
                                </label>
                                <p class="pl-1">or drag and drop</p>
                            </div>
                            <p class="text-xs text-gray-500">PNG, JPG, GIF up to 10MB</p>
                        </div>
                    </div>
                    <div id="editWorkImagePreview" class="mt-4 grid grid-cols-2 sm:grid-cols-3 gap-4 hidden"></div>
                </div>
            </div>

            <div class="mt-6 flex justify-end space-x-3">
                <button type="button" onclick="closeEditWorkModal()"
                    class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition duration-200">
                    Cancel
                </button>
                <button type="submit"
                    class="px-4 py-2 text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition duration-200">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function previewWorkImages(input) {
        const preview = document.getElementById('editWorkImagePreview');
        preview.innerHTML = '';

        if (input.files && input.files.length > 0) {
            if (input.files.length > 5) {
                alert('Maximum 5 images allowed');
                input.value = '';
                return;
            }

            preview.classList.remove('hidden');
            Array.from(input.files).forEach(file => {
                const reader = new FileReader();
                const imgContainer = document.createElement('div');
                imgContainer.className = 'relative group';

                reader.onload = function (e) {
                    imgContainer.innerHTML = `
                    <img src="${e.target.result}" class="w-full h-24 object-cover rounded-lg">
                    <button type="button" class="absolute top-2 right-2 bg-red-500 text-white rounded-full p-1 hidden group-hover:block hover:bg-red-600"
                            onclick="this.parentElement.remove();">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                `;
                };

                preview.appendChild(imgContainer);
                reader.readAsDataURL(file);
            });
        } else {
            preview.classList.add('hidden');
        }
    }

    // Global function to populate images in the edit modal
    window.populateEditWorkImages = function (images) {
        const currentImagesGrid = document.getElementById('currentWorkImagesGrid');
        const currentImagesSection = document.getElementById('currentWorkImages');

        if (!currentImagesGrid || !currentImagesSection) return;

        currentImagesGrid.innerHTML = '';

        if (images && images.length > 0) {
            images.forEach(image => {
                const imgContainer = document.createElement('div');
                imgContainer.className = 'relative group';
                imgContainer.innerHTML = `
                <img src="${image.startsWith('/') ? image : '/uploads/work/' + image}" 
                     class="w-full h-32 object-cover rounded-lg">
                <button type="button" class="absolute top-2 right-2 bg-red-500 text-white rounded-full p-1 hidden group-hover:block hover:bg-red-600"
                        onclick="removeWorkImage(this, '${image}')">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
                <input type="hidden" name="existingImages" value="${image}">
            `;
                currentImagesGrid.appendChild(imgContainer);
            });
            currentImagesSection.classList.remove('hidden');
        } else {
            currentImagesSection.classList.add('hidden');
        }
    };

    function populateEditWorkModal(workId, leaderId, leaderType) {
        // Legacy support or internal use
        const work = workDetails.find(w => w.workDetail._id === workId);
        if (!work) return;

        document.getElementById('editWorkId').value = workId;
        document.getElementById('editLeaderId').value = leaderId;
        document.getElementById('editLeaderType').value = leaderType || 'mla'; // default
        document.getElementById('editWorkTitle').value = work.workDetail.title;
        document.getElementById('editWorkDescription').value = work.workDetail.description;
        document.getElementById('editWorkStatus').value = work.workDetail.status;
        document.getElementById('editWorkLocation').value = work.workDetail.location;

        populateEditWorkImages(work.workDetail.images);

        // Show modal
        const modal = document.getElementById('editWorkModal');
        modal.classList.remove('hidden');
    }

    function closeEditWorkModal() {
        const modal = document.getElementById('editWorkModal');
        modal.classList.add('hidden');
        document.getElementById('editWorkForm').reset();
        document.getElementById('editWorkImagePreview').innerHTML = '';
        document.getElementById('editWorkImagePreview').classList.add('hidden');
    }

    function removeWorkImage(button, imageName) {
        const container = button.parentElement;
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'removeImages';
        input.value = imageName;
        document.getElementById('editWorkForm').appendChild(input);
        container.remove();

        if (document.getElementById('currentWorkImagesGrid').children.length === 0) {
            document.getElementById('currentWorkImages').classList.add('hidden');
        }
    }

</script>