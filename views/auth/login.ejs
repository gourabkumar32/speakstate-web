<!DOCTYPE html>
<html>

<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C77SZWTGLY"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'G-C77SZWTGLY');
    </script>
    <title>Login</title>
    <!-- Add Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Neo-Brutalism Theme */
        body {
            background-color: #f3f0ff; /* Soft Violet Background */
            background-image: radial-gradient(#dcd6f7 2px, transparent 2px);
            background-size: 30px 30px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            font-family: 'Verdana', sans-serif;
            color: #000;
        }

        .main-wrapper {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px; /* Reduced padding for mobile */
        }

        /* Pop Card Styling */
        .login-card {
            background: #ffffff;
            border: 3px solid #000000;
            border-radius: 15px;
            /* Hard Shadow */
            box-shadow: 10px 10px 0px #000000;
            padding: 3rem;
            position: relative;
            transition: transform 0.2s;
        }
        
        /* Mobile adjustment for card padding */
        @media (max-width: 576px) {
            .login-card {
                padding: 2rem 1.5rem;
                box-shadow: 6px 6px 0px #000000;
            }
        }

        .login-card:hover {
            transform: translate(-2px, -2px);
            box-shadow: 12px 12px 0px #000000;
        }

        /* Header Styling */
        .login-header h1 {
            color: #000;
            font-weight: 900;
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        .login-header p {
            color: #555;
            font-weight: 500;
            font-size: 1rem;
            border-bottom: 2px solid #000;
            display: inline-block;
            padding-bottom: 5px;
        }

        /* Form Controls */
        .form-floating > .form-control {
            background: #fff;
            border: 3px solid #000;
            border-radius: 10px;
            color: #000;
            font-weight: 600;
            /* Mobile fix: Ensure adequate height and font size */
            height: calc(3.5rem + 6px); 
            font-size: 16px; /* Prevents iOS zoom */
        }

        .form-floating > .form-control:focus {
            background: #fff;
            border-color: #000;
            box-shadow: 5px 5px 0px #d4b3ff; /* Pastel accent shadow */
            transform: translate(-2px, -2px);
        }

        .form-floating > label {
            color: #555;
            font-weight: 600;
            padding-top: 0.8rem; /* Center label vertically */
        }

        /* Primary Button - Vibrant Purple/Pink */
        .btn-primary {
            background-color: #a855f7;
            color: #fff;
            border: 3px solid #000;
            padding: 14px;
            font-weight: 800;
            border-radius: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 1rem;
            box-shadow: 5px 5px 0px #000;
            transition: all 0.2s;
            position: relative;
        }

        .btn-primary:hover {
            background-color: #9333ea;
            color: #fff;
            transform: translate(2px, 2px); /* Press effect */
            box-shadow: 2px 2px 0px #000;
        }
        
        .btn-primary:active {
            transform: translate(5px, 5px);
            box-shadow: 0px 0px 0px #000;
        }

        /* Google Button */
        .btn-google {
            background: #fff;
            border: 3px solid #000;
            color: #000;
            padding: 12px;
            border-radius: 10px;
            font-weight: 700;
            box-shadow: 5px 5px 0px #000;
            transition: all 0.2s;
        }

        .btn-google:hover {
            background: #fdfdfd;
            border-color: #000;
            transform: translate(2px, 2px);
            box-shadow: 2px 2px 0px #000;
        }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: #000;
            margin: 1.5rem 0;
            font-weight: 700;
            font-size: 0.9rem;
            text-transform: uppercase;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 3px solid #000;
        }

        .divider::before { margin-right: 1em; }
        .divider::after { margin-left: 1em; }

        /* Alerts */
        .custom-alert {
            padding: 1rem;
            border-radius: 10px;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            font-size: 0.9rem;
            font-weight: 700;
            border: 3px solid #000;
            box-shadow: 4px 4px 0px rgba(0,0,0,0.2);
        }

        .custom-alert.danger {
            background: #ffc9c9;
            color: #000;
        }

        .custom-alert.success {
            background: #bbf7d0;
            color: #000;
        }

        /* Footer Links */
        .login-footer p {
            font-weight: 600;
            color: #555;
        }

        .login-footer a {
            color: #a855f7;
            text-decoration: none;
            font-weight: 800;
            background-color: #fff;
            padding: 4px 8px; /* Larger hit area */
            border: 2px solid transparent;
            border-radius: 6px;
            transition: all 0.2s;
            display: inline-block; /* Fix for layout stability */
            margin-left: 5px;
        }

        .login-footer a:hover {
            background-color: #000;
            color: #fff;
            border: 2px solid #000;
            text-decoration: none;
            transform: rotate(-2deg);
        }
    </style>
</head>

<body>
    <%- include('../partials/header', { title: 'Login' }) %>

    <div class="main-wrapper">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-7 col-lg-5 col-xl-4">
                    <div class="login-card">
                        
                        <!-- Header -->
                        <div class="login-header text-center mb-4">
                            <h1>Welcome</h1>
                            <p>Let's get you back in!</p>
                        </div>

                        <!-- Flash Messages -->
                        <% if (error && error.length > 0) { %>
                            <div class="custom-alert danger">
                                <i class="material-icons me-2" style="font-size: 24px;">error</i>
                                <span><%= error %></span>
                            </div>
                        <% } %>

                        <% if (success && success.length > 0) { %>
                            <div class="custom-alert success">
                                <i class="material-icons me-2" style="font-size: 24px;">check_circle</i>
                                <span><%= success %></span>
                            </div>
                        <% } %>

                        <!-- Login Form -->
                        <form action="/auth/login" method="POST">
                            <% if (typeof returnTo !=='undefined' && returnTo) { %>
                                <input type="hidden" name="returnTo" value="<%= returnTo %>">
                            <% } %>

                            <div class="form-floating mb-3">
                                <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com" required>
                                <label for="email">Email address</label>
                            </div>

                            <div class="form-floating mb-4">
                                <input type="password" class="form-control" id="password" name="password" placeholder="Password" required>
                                <label for="password">Password</label>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 mb-4">
                                Sign In
                            </button>
                        </form>

                        <!-- Social Login -->
                        <div class="divider">Or</div>

                        <a href="/auth/google<%= (typeof returnTo !== 'undefined' && returnTo) ? '?returnTo=' + encodeURIComponent(returnTo) : '' %>"
                           class="btn btn-google w-100 d-flex align-items-center justify-content-center mb-4">
                            <img src="/google.png" alt="Google" width="20" height="20" class="me-2">
                            <span>Google Account</span>
                        </a>

                        <!-- Footer -->
                        <div class="login-footer text-center">
                            <p class="mb-0">
                                No account? 
                                <a href="/auth/register">Create One</a>
                            </p>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // --- Hamburger Menu Logic ---
            const hamburger = document.getElementById('hamburger');
            const mobileMenu = document.getElementById('mobileMenu');
            const menuClose = document.getElementById('menuClose');

            if (hamburger && mobileMenu && menuClose) {
                hamburger.addEventListener('click', () => {
                    mobileMenu.classList.remove('translate-x-full');
                });

                menuClose.addEventListener('click', () => {
                    mobileMenu.classList.add('translate-x-full');
                });
            }

            // --- Alert Auto-dismiss Logic ---
            const alerts = document.querySelectorAll('.custom-alert, .alert');
            
            if (alerts.length > 0) {
                alerts.forEach(alert => {
                    setTimeout(() => {
                        alert.style.transition = "opacity 0.5s ease";
                        alert.style.opacity = '0';
                        setTimeout(() => alert.remove(), 500);
                    }, 5000);
                });
            }
        });
    </script>
</body>

</html>