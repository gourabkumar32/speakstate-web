<%- include('../partials/header', { title: 'Edit Work Detail' }) %>

<div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-4xl mx-auto px-4 mt-6">
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            <div class="p-6">
                <div class="flex items-center justify-between mb-6">
                    <h1 class="text-2xl font-bold text-gray-900">Edit Work Detail</h1>
                    <h2 class="text-lg text-gray-600">MLA: <%= mla.name %></h2>
                </div>

                <form id="editWorkForm" action="/mlas/<%= mla._id %>/work/<%= workDetail._id %>?_method=PUT" 
                      method="POST" enctype="multipart/form-data" class="space-y-6">
            <!-- Title -->
            <div>
                <label for="title" class="block text-lg font-medium text-gray-700 mb-2">Title</label>
                <input type="text" id="title" name="title" value="<%= workDetail.title %>"
                    class="w-full px-4 py-3 rounded-lg border-2 border-gray-300 focus:border-blue-500 focus:ring focus:ring-blue-200 transition-colors"
                    placeholder="Enter work title (Optional)">
            </div>

            <!-- Description -->
            <div>
                <label for="description" class="block text-lg font-medium text-gray-700 mb-2">Description</label>
                <textarea id="description" name="description" rows="4"
                    class="w-full px-4 py-3 rounded-lg border-2 border-gray-300 focus:border-blue-500 focus:ring focus:ring-blue-200 transition-colors"
                    placeholder="Enter work description (Optional)"><%= workDetail.description %></textarea>
            </div>

            <!-- Status -->
            <div>
                <label for="status" class="block text-lg font-medium text-gray-700 mb-2">Status</label>
                <select id="status" name="status"
                    class="w-full px-4 py-3 rounded-lg border-2 border-gray-300 focus:border-blue-500 focus:ring focus:ring-blue-200 transition-colors">
                    <option value="">Select status (Optional)</option>
                    <% ['Needed', 'Planned', 'In Progress', 'Delayed', 'Completed', 'Cancelled', 'On Hold'].forEach(function(status) { %>
                        <option value="<%= status %>" <%= workDetail.status === status ? 'selected' : '' %>><%= status %></option>
                    <% }); %>
                </select>
            </div>

            <!-- Location -->
            <div>
                <label for="location" class="block text-lg font-medium text-gray-700 mb-2">Location</label>
                <input type="text" id="location" name="location" value="<%= workDetail.location || '' %>"
                    class="w-full px-4 py-3 rounded-lg border-2 border-gray-300 focus:border-blue-500 focus:ring focus:ring-blue-200 transition-colors"
                    placeholder="Enter work location (Optional)">
            </div>

            <!-- Current Images -->
            <div class="space-y-4">
                <label class="block text-lg font-medium text-gray-700">Current Images</label>
                <% if (workDetail.images && workDetail.images.length > 0) { %>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4" id="currentImages">
                        <% workDetail.images.forEach((image, index) => { %>
                            <div class="relative group">
                                <img src="<%= image.startsWith('/') ? image : `/uploads/work/${image}` %>"
                                     alt="Work image <%= index + 1 %>"
                                     class="w-full h-40 object-cover rounded-lg shadow-md">
                                <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-50 transition-opacity duration-200 rounded-lg"></div>
                                <button type="button"
                                        onclick="removeImage(this, '<%= image %>')"
                                        class="absolute top-2 right-2 bg-red-500 text-white rounded-full p-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 hover:bg-red-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                    </svg>
                                </button>
                                <input type="hidden" name="existingImages" value="<%= image %>">
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <p class="text-gray-500">No images currently uploaded</p>
                <% } %>
            </div>

            <!-- New Images -->
            <div>
                <label class="block text-lg font-medium text-gray-700 mb-2">Add New Images</label>
                <div class="mt-2 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg hover:border-blue-500 transition-all duration-200">
                    <div class="space-y-1 text-center">
                        <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" 
                                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <div class="flex text-sm text-gray-600">
                            <label for="images" class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500">
                                <span>Upload new images</span>
                                <input id="images" name="images" type="file" class="sr-only" multiple accept="image/*" onchange="previewImages(this)">
                            </label>
                        </div>
                        <p class="text-xs text-gray-500">PNG, JPG, GIF up to 5MB each</p>
                    </div>
                </div>
                <div id="imagePreview" class="mt-4 grid grid-cols-2 sm:grid-cols-3 gap-4 hidden"></div>
            </div>

            <!-- Form Buttons -->
            <div class="flex justify-end space-x-4 mt-8">
                <a href="/profile" class="px-6 py-3 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">
                    Cancel
                </a>
                <button type="submit" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function previewImages(input) {
    const preview = document.getElementById('imagePreview');
    preview.innerHTML = '';
    
    if (input.files) {
        const fileArray = Array.from(input.files);
        if (fileArray.length > 5) {
            alert('You can only upload up to 5 images');
            input.value = '';
            return;
        }

        let validFiles = true;
        fileArray.forEach(file => {
            if (file.size > 5 * 1024 * 1024) {
                alert('Each file must be less than 5MB');
                validFiles = false;
                input.value = '';
                return;
            }
            if (!file.type.startsWith('image/')) {
                alert('Only image files are allowed');
                validFiles = false;
                input.value = '';
                return;
            }
        });

        if (!validFiles) return;

        preview.classList.remove('hidden');
        fileArray.forEach(file => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const div = document.createElement('div');
                div.className = 'relative group';
                div.innerHTML = `
                    <img src="${e.target.result}" class="w-full h-40 object-cover rounded-lg shadow-md">
                    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-50 transition-opacity duration-200 rounded-lg"></div>
                    <button type="button" class="absolute top-2 right-2 bg-red-500 text-white rounded-full p-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 hover:bg-red-600"
                            onclick="removeNewImage(this)">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                `;
                preview.appendChild(div);
            };
            reader.readAsDataURL(file);
        });
    }
}

function removeImage(button, imageName) {
    const container = button.closest('.relative');
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'removeImages';
    input.value = imageName;
    document.getElementById('editWorkForm').appendChild(input);
    container.remove();
}

function removeNewImage(button) {
    const container = button.closest('.relative');
    container.remove();
    
    // If no more previews, hide the preview container
    const preview = document.getElementById('imagePreview');
    if (!preview.hasChildNodes()) {
        preview.classList.add('hidden');
    }
}
</script>
                </div>
                </div>
            </div>

        </form>
    </div>
</div>

<script>
function handleImagePreviews(input) {
    const preview = document.getElementById('imagePreview');
    preview.innerHTML = '';
    
    if (input.files) {
        const fileArray = Array.from(input.files);
        if (fileArray.length > 5) {
            alert('You can only upload up to 5 images');
            input.value = '';
            return;
        }

        let validFiles = true;
        fileArray.forEach(file => {
            if (file.size > 5 * 1024 * 1024) {
                alert('Each file must be less than 5MB');
                validFiles = false;
                input.value = '';
                return;
            }
            if (!file.type.startsWith('image/')) {
                alert('Only image files are allowed');
                validFiles = false;
                input.value = '';
                return;
            }
        });

        if (!validFiles) return;

        preview.classList.remove('hidden');
        fileArray.forEach(file => {
            const reader = new FileReader();
            const div = document.createElement('div');
            div.className = 'relative group';
            
            reader.onload = function(e) {
                div.innerHTML = `
                    <img src="${e.target.result}" class="w-full h-40 object-cover rounded-lg shadow-md">
                    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-50 transition-opacity duration-200 rounded-lg"></div>
                    <button type="button" onclick="this.closest('.relative').remove()" 
                            class="absolute top-2 right-2 bg-red-500 text-white rounded-full p-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 hover:bg-red-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                `;
            };
            
            preview.appendChild(div);
            reader.readAsDataURL(file);
        });
    } else {
        preview.classList.add('hidden');
    }
}

function handleImageRemoval(button, imageName) {
    const container = button.closest('.relative');
    if (container) {
        // Add a hidden input to track removed images
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'removeImages';
        input.value = imageName;
        document.querySelector('form').appendChild(input);
        
        // Remove the image container
        container.remove();
        
        // Hide the grid if no images left
        const grid = document.getElementById('currentImagesGrid');
        if (grid.children.length === 0) {
            grid.closest('.mt-4').classList.add('hidden');
        }
    }
}

// Function to show message
function showMessage(message, isError = false) {
    const messageDiv = document.createElement('div');
    messageDiv.className = `fixed top-4 right-4 ${isError ? 'bg-red-500' : 'bg-green-500'} text-white px-6 py-3 rounded shadow-lg z-50 animate-fade-out`;
    messageDiv.textContent = message;
    document.body.appendChild(messageDiv);
    
    if (isError) {
        setTimeout(() => messageDiv.remove(), 3000);
    }
    
    return messageDiv;
}

// Handle form submission
const editWorkForm = document.getElementById('editWorkForm');
if (editWorkForm) {
    editWorkForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        // Show loading state
        const submitBtn = this.querySelector('button[type="submit"]');
        if (!submitBtn) return;
        
        const originalText = submitBtn.textContent;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Saving...';
        
        try {
            const formData = new FormData(this);
            formData.delete('_method'); // Remove _method from FormData
            
            // Create a loading message
            const loadingMessage = showMessage('Saving changes...', false);
            
            // Send the form data
            const response = await fetch(this.action.replace('?_method=PUT', ''), {
                method: 'PUT',
                body: formData
            });
            
            // Remove loading message
            loadingMessage.remove();
            
            if (response.ok) {
                // Show success message and redirect
                showMessage('Work detail updated successfully');
                this.style.opacity = '0.5';
                this.style.pointerEvents = 'none';
                
                // Redirect after a brief delay
                setTimeout(() => {
                    window.location.href = '/profile';
                }, 800);
            } else {
                // Handle errors
                const error = await response.json();
                throw new Error(error.message || 'Failed to save work detail');
            }
        } catch (error) {
            console.error('Error:', error);
            showMessage(error.message || 'Error saving work detail. Please try again.', true);
        } finally {
            // Reset submit button state
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
        }
    });
}
</script>

<%- include('../partials/footer') %>
