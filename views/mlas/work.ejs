                    </div>

                    <!-- Add Work Modal -->
                    <% if (user) { %>
                        <div id="workModal" class="hidden fixed inset-0 bg-black bg-opacity-50" style="z-index:99999;">
                            <div class="flex items-center justify-center min-h-screen p-4">
                                <div class="w-full max-w-4xl bg-white rounded-2xl shadow-lg overflow-hidden">
                                    <div class="relative flex flex-col">
                                        <!-- Modal header -->
                                        <div
                                            class="px-8 sm:px-10 md:px-12 py-6 border-b border-gray-200 flex justify-between items-center bg-white">
                                            <h3 class="text-2xl sm:text-3xl md:text-4xl font-semibold text-gray-800"
                                                id="modalTitle">Add Work Detail</h3>
                                            <button onclick="closeWorkModal()"
                                                class="text-gray-400 hover:text-gray-500">
                                                <svg class="h-6 w-6" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                                </svg>
                                            </button>
                                        </div>

                                        <!-- Modal body with form -->
                                        <div
                                            class="px-8 sm:px-10 md:px-12 py-8 overflow-y-auto max-h-[calc(100vh-200px)]">
                                            <form id="workForm" method="POST" action="/mlas/<%= mla._id %>/work"
                                                enctype="multipart/form-data" class="space-y-8">
                                                <div class="space-y-8">
                                                    <!-- Title Field -->
                                                    <div class="mb-8">
                                                        <label class="block text-xl font-semibold text-gray-700 mb-3"
                                                            for="title">Title<span class="text-red-500">*</span></label>
                                                        <input type="text" id="title" name="title" required
                                                            class="mt-2 block w-full rounded-xl border-2 border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg p-4"
                                                            placeholder="Enter work title">
                                                    </div>

                                                    <!-- Description Field -->
                                                    <div class="mb-8">
                                                        <label class="block text-xl font-semibold text-gray-700 mb-3"
                                                            for="description">Description</label>
                                                        <textarea id="description" name="description" rows="5"
                                                            class="mt-2 block w-full rounded-xl border-2 border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg p-4"
                                                            placeholder="Enter work description (Optional)"></textarea>
                                                    </div>

                                                    <!-- Status Field -->
                                                    <div class="mb-8">
                                                        <label class="block text-xl font-semibold text-gray-700 mb-3"
                                                            for="status">Status</label>
                                                        <select id="status" name="status"
                                                            class="mt-2 block w-full rounded-xl border-2 border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg p-4">
                                                            <option value="">Select status (Optional)</option>
                                                            <option value="Needed">Needed</option>
                                                            <option value="Planned">Planned</option>
                                                            <option value="In Progress">In Progress</option>
                                                            <option value="Delayed">Delayed</option>
                                                            <option value="Completed">Completed</option>
                                                            <option value="Cancelled">Cancelled</option>
                                                            <option value="On Hold">On Hold</option>
                                                        </select>
                                                    </div>

                                                    <!-- Location Field -->
                                                    <div class="mb-8">
                                                        <label class="block text-xl font-semibold text-gray-700 mb-3"
                                                            for="location">Location</label>
                                                        <input type="text" id="location" name="location"
                                                            class="mt-2 block w-full rounded-xl border-2 border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg p-4"
                                                            placeholder="Enter work location (Optional)">
                                                    </div>

                                                    <!-- Images Field -->
                                                    <div class="mb-8 w-full">
                                                        <label class="block text-xl font-semibold text-gray-700 mb-3"
                                                            for="images">Images (Up to 5)</label>
                                                        <div
                                                            class="mt-2 flex justify-center w-full px-8 py-10 border-2 border-gray-300 border-dashed rounded-xl hover:border-blue-400 transition-all duration-300">
                                                            <div class="space-y-4 text-center w-full">
                                                                <svg class="mx-auto h-20 w-20 text-gray-400"
                                                                    stroke="currentColor" fill="none"
                                                                    viewBox="0 0 48 48" aria-hidden="true">
                                                                    <path
                                                                        d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02"
                                                                        stroke-width="2" stroke-linecap="round"
                                                                        stroke-linejoin="round" />
                                                                </svg>
                                                                <div class="flex flex-col items-center space-y-4">
                                                                    <label for="images" class="relative cursor-pointer">
                                                                        <span
                                                                            class="px-6 py-3 text-lg font-semibold text-white bg-blue-600 rounded-xl hover:bg-blue-700 transition-all duration-200 inline-block">Choose
                                                                            Images</span>
                                                                        <input id="images" name="images" type="file"
                                                                            class="sr-only" multiple accept="image/*"
                                                                            onchange="validateAndPreviewImages(this)">
                                                                    </label>
                                                                    <p class="text-lg text-gray-600">or drag and drop
                                                                        your images here</p>
                                                                </div>
                                                                <p class="text-base text-gray-500 mt-4">Supported
                                                                    formats: PNG, JPG, GIF</p>
                                                            </div>
                                                        </div>
                                                        <div id="imagePreview"
                                                            class="mt-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 hidden">
                                                        </div>
                                                    </div>

                                                    <!-- Current Images (for edit mode) -->
                                                    <div id="currentImages" class="hidden space-y-4">
                                                        <div>
                                                            <label
                                                                class="block text-base font-medium text-gray-700 mb-2">Current
                                                                Images</label>
                                                            <p class="text-sm text-gray-500 mb-4">Previously uploaded
                                                                images</p>
                                                        </div>
                                                        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"
                                                            id="currentImagesGrid"></div>
                                                    </div>
                                                </div>

                                                <!-- Footer with centered buttons -->
                                                <div
                                                    class="px-4 sm:px-6 md:px-6 py-3 bg-gray-50 border-t border-gray-200">
                                                    <div class="flex justify-center gap-6">
                                                        <button type="button" onclick="closeWorkModal()"
                                                            class="px-4 py-2 text-lg font-medium text-gray-700 bg-white border border-gray-300 rounded-xl hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200">Cancel</button>
                                                        <button type="submit" form="workForm"
                                                            class="px-4 py-2 text-lg font-medium text-white bg-blue-600 border border-transparent rounded-xl hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200">Save</button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <script>

                            // Make functions globally available immediately
                            window.showAddWorkModal = function () {
                                console.log('Opening Add Work Modal');
                                const modal = document.getElementById('workModal');
                                if (!modal) { console.error('Modal not found'); return; }

                                const form = document.getElementById('workForm');
                                if (form) {
                                    form.reset();
                                    // Use dataset or variable if available, fallback to safely finding it
                                    const mlaId = document.getElementById('mlaIdContainer')?.dataset.id || '<%= mla._id %>';
                                    form.action = `/mlas/${mlaId}/work`;

                                    const preview = document.getElementById('imagePreview');
                                    if (preview) {
                                        preview.innerHTML = '';
                                        preview.classList.add('hidden');
                                    }
                                    const currentImages = document.getElementById('currentImages');
                                    if (currentImages) {
                                        currentImages.classList.add('hidden');
                                        const grid = currentImages.querySelector('#currentImagesGrid');
                                        if (grid) grid.innerHTML = '';
                                    }
                                }
                                window.editingWorkId = null;
                                modal.classList.remove('hidden');
                                modal.style.display = 'flex';
                                const modalTitle = document.getElementById('modalTitle');
                                if (modalTitle) modalTitle.textContent = 'Add Work Detail';
                            };

                            window.closeWorkModal = function () {
                                const modal = document.getElementById('workModal');
                                if (modal) {
                                    modal.classList.add('hidden');
                                    modal.style.display = 'none';
                                }
                            };

                            window.validateAndPreviewImages = function (input) {
                                if (input.files.length > 5) {
                                    alert('Maximum 5 images are allowed');
                                    input.value = '';
                                    return;
                                }
                                const preview = document.getElementById('imagePreview');
                                if (!preview) return;
                                preview.innerHTML = '';

                                if (input.files && input.files.length > 0) {
                                    preview.classList.remove('hidden');
                                    Array.from(input.files).forEach(file => {
                                        const reader = new FileReader();
                                        const imgContainer = document.createElement('div');
                                        const img = document.createElement('img');
                                        img.classList.add('w-full', 'h-32', 'object-cover', 'rounded-lg');
                                        reader.onload = function (e) {
                                            img.src = e.target.result;
                                        };
                                        imgContainer.appendChild(img);
                                        preview.appendChild(imgContainer);
                                        reader.readAsDataURL(file);
                                    });
                                } else {
                                    preview.classList.add('hidden');
                                }
                            };

                            document.addEventListener('DOMContentLoaded', function () {
                                console.log('MLA Work script loaded');

                                // Safety check for workDetails
                                let workDetails = [];
                                try {
                                    workDetails = <% - JSON.stringify(mla.workDetails || []) || '[]' %>;
                                } catch (e) {
                                    console.error('Failed to parse workDetails', e);
                                }

                                const mlaId = '<%= mla._id %>';

                                const container = document.createElement('div');
                                container.id = 'mlaIdContainer';
                                container.dataset.id = mlaId;
                                container.style.display = 'none';
                                document.body.appendChild(container);

                                window.editingWorkId = null;

                                window.deleteWorkImage = async function (workId, imageName) {
                                    if (!confirm('Are you sure you want to delete this image?')) return;
                                    try {
                                        const response = await fetch(`/mlas/${mlaId}/work/${workId}/image/${imageName}`, { method: 'DELETE' });
                                        const result = await response.json();
                                        if (result.success) window.location.reload();
                                        else alert(result.message || 'Failed to delete image');
                                    } catch (error) {
                                        console.error('Error deleting image:', error);
                                        alert('Error deleting image. Please try again.');
                                    }
                                };

                                window.editWork = function (workId) {
                                    console.log('Editing work:', workId);
                                    window.editingWorkId = workId;
                                    const work = workDetails.find(w => w._id === workId);
                                    if (work) {
                                        const modal = document.getElementById('workModal');
                                        modal.classList.remove('hidden');
                                        modal.style.display = 'flex';
                                        document.querySelector('#workModal h3').textContent = 'Edit Work Detail';

                                        const form = document.getElementById('workForm');
                                        if (form) {
                                            form.action = `/mlas/${mlaId}/work/${workId}`;
                                        }

                                        document.getElementById('title').value = work.title || '';
                                        document.getElementById('description').value = work.description || '';

                                        const statusSelect = document.getElementById('status');
                                        if (statusSelect) statusSelect.value = work.status || 'Planned';

                                        document.getElementById('location').value = work.location || '';

                                        const currentImagesSection = document.getElementById('currentImages');
                                        const currentImagesGrid = document.getElementById('currentImagesGrid');
                                        if (currentImagesGrid) currentImagesGrid.innerHTML = '';

                                        if (work.images && work.images.length > 0 && currentImagesSection && currentImagesGrid) {
                                            currentImagesSection.classList.remove('hidden');
                                            work.images.forEach(image => {
                                                const imgContainer = document.createElement('div');
                                                imgContainer.className = 'relative group';
                                                const imgSrc = image.startsWith('/') ? image : '/uploads/work/' + image;
                                                imgContainer.innerHTML = `
                <img src="${imgSrc}" class="w-full h-24 object-cover rounded-lg">
                <button type="button" onclick="deleteWorkImage('${work._id}', '${image}')" class="absolute top-0 right-0 bg-red-500 text-white rounded-full p-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
            `;
                                                currentImagesGrid.appendChild(imgContainer);
                                            });
                                        }
                                    }
                                };

                                const form = document.getElementById('workForm');
                                if (form) {
                                    form.addEventListener('submit', async function (e) {
                                        e.preventDefault();
                                        const formData = new FormData(this);

                                        try {
                                            const url = window.editingWorkId
                                                ? `/mlas/${mlaId}/work/${window.editingWorkId}`
                                                : `/mlas/${mlaId}/work`;

                                            const method = window.editingWorkId ? 'PUT' : 'POST';
                                            console.log('Submitting to:', url, method);

                                            const response = await fetch(url, {
                                                method: method,
                                                body: formData
                                            });

                                            const result = await response.json();
                                            if (result.success) {
                                                window.location.reload();
                                            } else {
                                                alert(result.message || 'Error saving work');
                                            }
                                        } catch (err) {
                                            console.error('Submit error:', err);
                                            alert('Error saving work. Please try again.');
                                        }
                                    });
                                }

                                window.deleteWork = function (workId) {
                                    if (!confirm('Are you sure?')) return;
                                    fetch(`/mlas/${mlaId}/work/${workId}`, { method: 'DELETE' })
                                        .then(r => r.json())
                                        .then(data => {
                                            if (data.success) window.location.reload();
                                            else alert(data.message);
                                        })
                                        .catch(e => {
                                            console.error(e);
                                            alert('Error deleting work');
                                        });
                                }
                            });

                            // Needed global for onclick
                            function deleteWork(workId) {
                                if (!confirm('Are you sure?')) return;
                                fetch(`/mlas/<%= mla._id %>/work/${workId}`, { method: 'DELETE' })
                                    .then(r => r.json())
                                    .then(data => {
                                        if (data.success) window.location.reload();
                                        else alert(data.message);
                                    });
                            }
                        </script>
                        <% } %>-->

        </div>
    </div>
    <%- include('../partials/footer') %>