<%- include('../partials/header') %>

    <head>
        <script async
            src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8814468973632188"
            crossorigin="anonymous"></script>
    </head>
    <style>
        .form {
            width: 90%;
            max-width: 1200px;
        }

        @media (max-width: 768px) {
            .form {
                width: 95%;
                margin-left: 60px;
            }
        }

        .container {
            margin-bottom: 60px;
            margin-top: -35px;
        }

        /* Enhanced Scrollbar Styling */
        #workModal .overflow-y-auto::-webkit-scrollbar {
            width: 10px;
        }

        #workModal .overflow-y-auto::-webkit-scrollbar-track {
            background: #f8fafc;
            border-radius: 8px;
        }

        #workModal .overflow-y-auto::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 8px;
            border: 2px solid #f8fafc;
        }

        #workModal .overflow-y-auto::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Enhanced Image Preview Grid */
        #imagePreview {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 2rem;
            padding: 1.5rem;
        }

        #imagePreview img {
            width: 100%;
            height: 250px;
            object-fit: cover;
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #imagePreview img:hover {
            transform: scale(1.05) translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        /* Input Field Enhancements */
        input[type="text"],
        textarea,
        select {
            transition: all 0.3s ease;
        }

        input[type="text"]:hover,
        textarea:hover,
        select:hover {
            border-color: #60a5fa;
        }

        input[type="text"]:focus,
        textarea:focus,
        select:focus {
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            border-color: #3b82f6;
        }

        /* Drag & Drop Zone Enhancement */
        .drag-zone {
            position: relative;
            overflow: hidden;
            background: linear-gradient(to bottom right, #f8fafc, #f1f5f9);
            transition: all 0.3s ease;
        }

        .drag-zone:hover {
            background: linear-gradient(to bottom right, #eff6ff, #f8fafc);
            transform: translateY(-2px);
        }
    </style>

    <div class="container mx-auto px-4 py-8">
        <div class="p-1">
            <%- include('../partials/leader-profile', { leader: mla }) %>
                <%- include('../partials/leader-tabs', { type: 'mla' , leader: mla, activeTab: activeTab }) %>

                    <!--<div class="mb-8">
                        <div class="flex justify-between items-center mb-4">
