
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Indian Political News | Wekend.in</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .loader {
            border: 4px solid #f3f3f3;
            border-radius: 50%;
            border-top: 4px solid #3b82f6;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .trending-tag.active-tag {
            background-color: #3b82f6; /* blue-500 */
            color: white;
            font-weight: 600;
        }
    </style>
</head>



<body class="bg-gray-50 text-gray-800">


<%- include('./partials/header', { title: 'news' }) %>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
       <!--<header class="text-center mb-8">
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900">Indian Politics News Feed</h1>
            <p class="text-base sm:text-lg text-gray-600 mt-2">Tracking the latest in Indian politics for <a href="https://wekend.in" class="text-blue-600 hover:underline">Wekend.in</a></p>
        </header>-->
        <!-- Search Bar Section -->
        <div class="max-w-xl mx-auto mb-10">
            <form id="search-form" class="flex items-center" onsubmit="return false;">
                <input id="search-input" type="text" placeholder="Search for any topic..." class="w-full px-4 py-3 text-gray-700 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition-shadow">
            </form>
        </div>

        <!-- Trending Topics Section -->
        <div class="mb-8 text-center">
            <h2 class="text-xl font-semibold mb-4 text-gray-800">Today's Trending Topics</h2>
            <div id="trending-tags" class="flex flex-wrap justify-center gap-2 sm:gap-3">
                <% if (trendingTopics && trendingTopics.length > 0) { %>
                    <% trendingTopics.forEach(topic => { %>
                        <button data-topic="<%= topic.toLowerCase() %>" class="trending-tag bg-gray-200 text-gray-700 px-4 py-2 rounded-full text-sm font-medium hover:bg-blue-500 hover:text-white transition-colors duration-200"><%= topic %></button>
                    <% }) %>
                <% } %>
                <button data-topic="India politics" class="trending-tag px-4 py-2 rounded-full text-sm font-medium hover:bg-blue-600 transition-colors duration-200 active-tag">All Politics</button>
            </div>
        </div>

        <% if (error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg relative text-center" role="alert">
                <strong class="font-bold">Error:</strong>
                <span class="block sm:inline"><%= error %></span>
            </div>
        <% } %>

        <div id="news-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% articles.forEach(article => { %>
                <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 flex flex-col">
                    <% if (article.image_url) { %>
                        <img src="<%= article.image_url %>" alt="Article image" class="w-full h-48 object-cover" onerror="this.style.display='none'">
                    <% } %>
                    <div class="p-6 flex flex-col flex-grow">
                        <h2 class="text-lg md:text-xl font-bold mb-3 text-gray-900"><%= article.title %></h2>
                        <p class="text-gray-600 mb-4 flex-grow line-clamp-4"><%= article.description || 'No description available.' %></p>
                        <div class="mt-auto pt-4 border-t border-gray-200">
                             <a href="<%= article.link %>" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 font-semibold transition-colors duration-200">Read More &rarr;</a>
                             <p class="text-sm text-gray-500 mt-2">Source: <%= article.source_id || 'N/A' %></p>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
        
        <div id="loader" class="flex justify-center items-center py-8" style="display: none;">
             <div class="loader"></div>
        </div>
    </div>

    <script>
        const newsContainer = document.getElementById('news-container');
        const loader = document.getElementById('loader');
        const trendingTagsContainer = document.getElementById('trending-tags');
        const searchForm = document.getElementById('search-form');
        const searchInput = document.getElementById('search-input');

        let nextPage = "<%= nextPage %>";
        let currentTopic = "India politics";
        let isLoading = false;

        function createArticleCard(article) {
            const imageHtml = article.image_url ? `<img src="${article.image_url}" alt="Article image" class="w-full h-48 object-cover" onerror="this.style.display='none'">` : '';
            return `
                <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 flex flex-col">
                    ${imageHtml}
                    <div class="p-6 flex flex-col flex-grow">
                        <h2 class="text-lg md:text-xl font-bold mb-3 text-gray-900">${article.title}</h2>
                        <p class="text-gray-600 mb-4 flex-grow line-clamp-4">${article.description || 'No description available.'}</p>
                        <div class="mt-auto pt-4 border-t border-gray-200">
                             <a href="${article.link}" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 font-semibold transition-colors duration-200">Read More &rarr;</a>
                             <p class="text-sm text-gray-500 mt-2">Source: ${article.source_id || 'N/A'}</p>
                        </div>
                    </div>
                </div>`;
        }

        async function getNews(topic, pageToken) {
            if (isLoading) return;
            isLoading = true;
            loader.style.display = 'flex';
            
            if (!pageToken) {
                newsContainer.innerHTML = '';
            }

            try {
                let apiUrl = `/api/news?topic=${encodeURIComponent(topic)}`;
                if (pageToken) {
                    apiUrl += `&page=${pageToken}`;
                }

                const response = await fetch(apiUrl);
                if (!response.ok) throw new Error(`API request failed with status ${response.status}`);
                const data = await response.json();

                if (data.articles && data.articles.length > 0) {
                    data.articles.forEach(article => newsContainer.insertAdjacentHTML('beforeend', createArticleCard(article)));
                    nextPage = data.nextPage;
                } else {
                    nextPage = null; 
                    if (!pageToken) newsContainer.innerHTML = '<p class="text-center text-gray-500 col-span-full">No articles found for this topic.</p>';
                }
            } catch (error) {
                console.error('Failed to load articles:', error);
                if (!pageToken) newsContainer.innerHTML = `<p class="text-center text-red-500 col-span-full">Error: Could not load news.</p>`;
            } finally {
                isLoading = false;
                if (!nextPage) {
                    loader.style.display = 'none';
                }
            }
        }
        
        // --- NEW REAL-TIME SEARCH LOGIC ---

        // A function to handle the actual search logic
        function performSearch(searchTerm) {
            if (searchTerm && searchTerm.toLowerCase() !== currentTopic.toLowerCase()) {
                currentTopic = searchTerm;
                // De-select any active trending tags
                trendingTagsContainer.querySelectorAll('.trending-tag').forEach(tag => tag.classList.remove('active-tag'));
                // Fetch news for the new search term
                getNews(currentTopic, null);
            }
        }

        // Debounce helper function to prevent API calls on every keystroke
        function debounce(func, delay = 500) {
            let timeoutId;
            return (...args) => {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(() => {
                    func.apply(this, args);
                }, delay);
            };
        }

        // Create a debounced version of the search function
        const debouncedPerformSearch = debounce(performSearch);

        // Event listener for real-time typing in the search bar
        searchInput.addEventListener('input', () => {
            const searchTerm = searchInput.value.trim();
            // Use the debounced function for real-time search
            debouncedPerformSearch(searchTerm);
        });

        // Event listener for form submission (pressing Enter)
        searchForm.addEventListener('submit', (event) => {
            event.preventDefault(); // Prevent page reload
            const searchTerm = searchInput.value.trim();
            // Perform the search immediately on submit
            performSearch(searchTerm);
        });


        // Event listener for the trending topic tags
        trendingTagsContainer.addEventListener('click', (event) => {
            const clickedTag = event.target.closest('.trending-tag');
            if (!clickedTag) return;

            const newTopic = clickedTag.dataset.topic;
            if (newTopic === currentTopic && newsContainer.children.length > 0) return;

            currentTopic = newTopic;
            searchInput.value = ''; // Clear search bar when a tag is clicked
            trendingTagsContainer.querySelectorAll('.trending-tag').forEach(tag => tag.classList.remove('active-tag'));
            clickedTag.classList.add('active-tag');
            
            getNews(currentTopic, null);
        });

        // Event listener for infinite scroll
        window.addEventListener('scroll', () => {
            if (isLoading || !nextPage || nextPage === 'null') return;
            
            if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 500) {
                getNews(currentTopic, nextPage);
            }
        });
    </script>
</body>
<%- include('./partials/footer') %>

</html>