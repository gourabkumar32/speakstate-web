<%- include('../partials/header', { title: 'Public Issues' }) %>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    html {
      font-family: 'Inter', sans-serif;
      scroll-behavior: smooth;
    }

    /* Refined scrollbar */
    .custom-scrollbar::-webkit-scrollbar {
      width: 5px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
      background-color: #cbd5e1;
      border-radius: 20px;
    }

    .dark .custom-scrollbar::-webkit-scrollbar-thumb {
      background-color: #475569;
    }

    /* Hide scrollbar for clean modal look but allow scroll */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script>
    if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark')
    } else {
      document.documentElement.classList.remove('dark')
    }

    function toggleDarkMode() {
      if (document.documentElement.classList.contains('dark')) {
        document.documentElement.classList.remove('dark');
        localStorage.theme = 'light';
      } else {
        document.documentElement.classList.add('dark');
        localStorage.theme = 'dark';
      }
    }
  </script>

  <main class="w-full min-h-screen bg-slate-50 dark:bg-slate-950 pt-6 pb-20">
    <div class="max-w-[600px] mx-auto px-4">

      <!-- Flash Messages -->
      <div class="space-y-4 mb-6">
        <% if (error && error.length> 0) { %>
          <div
            class="flex items-center p-4 text-sm text-red-800 border border-red-200 rounded-xl bg-red-50 dark:bg-red-900/30 dark:text-red-300 dark:border-red-800"
            role="alert">
            <svg class="flex-shrink-0 inline w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd"
                d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"
                clip-rule="evenodd"></path>
            </svg>
            <span class="font-medium">
              <%= error %>
            </span>
          </div>
          <% } %>
            <% if (success && success.length> 0) { %>
              <div id="flash-success-message"
                class="flex items-center p-4 text-sm text-emerald-800 border border-emerald-200 rounded-xl bg-emerald-50 dark:bg-emerald-900/30 dark:text-emerald-300 dark:border-emerald-800"
                role="alert">
                <svg class="flex-shrink-0 inline w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                <span class="font-medium">
                  <%= success %>
                </span>
              </div>
              <% } %>
      </div>

      <!-- Feed Container -->
      <div class="tweets-container space-y-4">
        <% if (tweets && tweets.length> 0) { %>
          <% tweets.forEach(function(tweet) { %>
            <article id="tweet-<%= tweet._id %>"
              class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden"
              data-tweet-id="<%= tweet._id %>">

              <div class="p-5">
                <div class="flex gap-4">
                  <!-- Avatar Column -->
                  <div class="flex-shrink-0">
                    <div class="relative group cursor-pointer">
                      <%- include('../partials/avatar', { tweet: tweet,
                        sizeClass: 'w-12 h-12 rounded-full ring-2 ring-white dark:ring-slate-800' }) %>
                    </div>
                  </div>

                  <!-- Content Column -->
                  <div class="flex-1 min-w-0">
                    <!-- Header: Name & Time -->
                    <div class="flex items-baseline justify-between">
                      <div class="flex flex-row items-baseline gap-2 truncate">
                        <h3
                          class="font-bold text-[16px] text-slate-900 dark:text-slate-100 hover:underline decoration-2 cursor-pointer truncate">
                          <%= tweet.displayName %>
                        </h3>
                        <% if (tweet.isVerified) { %>
                          <span class="text-blue-500 text-sm" title="Verified"><i
                              class="fas fa-check-circle"></i></span>
                          <% } %>
                            <span class="text-slate-400 dark:text-slate-500 text-xs">•</span>
                            <time class="tweet-time text-sm text-slate-500 dark:text-slate-400 font-medium"
                              datetime="<%= tweet.createdAt %>" data-timestamp="<%= tweet.createdAt %>">
                              <%= new Date(tweet.createdAt).toLocaleString() %>
                            </time>
                      </div>
                    </div>

                    <!-- Metadata Badges (Modern Look) -->
                    <% if (tweet.representative || tweet.constituency || tweet.location) { %>
                      <div class="flex flex-wrap gap-2 mt-1.5 mb-2">
                        <% if (tweet.representative) { %>
                          <span
                            class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-100 dark:border-blue-800/50">
                            <i class="fas fa-user-tie mr-1.5 text-[10px] opacity-70"></i>
                            <%= tweet.representative %>
                          </span>
                          <% } %>
                            <% if (tweet.constituency) { %>
                              <span
                                class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300 border border-slate-200 dark:border-slate-700">
                                <i class="fas fa-landmark mr-1.5 text-[10px] opacity-70"></i>
                                <%= tweet.constituency %>
                              </span>
                              <% } %>
                                <% if (tweet.location) { %>
                                  <span
                                    class="inline-flex items-center text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                                    <i class="fas fa-map-marker-alt mr-1"></i>
                                    <%= tweet.location %>
                                  </span>
                                  <% } %>
                      </div>
                      <% } %>

                        <!-- Tweet Body -->
                        <div class="tweet-content mt-1">
                          <p
                            class="text-[15px] leading-relaxed text-slate-800 dark:text-slate-200 whitespace-pre-line tweet-body-text break-words">
                            <%- tweet.enrichedContent || tweet.content %>
                          </p>

                          <!-- Media Grid -->
                          <% if (tweet.media && tweet.media.length> 0) { %>
                            <div
                              class="mt-3 grid gap-1.5 rounded-xl overflow-hidden border border-slate-100 dark:border-slate-800 <%= tweet.media.length === 1 ? '' : 'grid-cols-2' %>">
                              <% tweet.media.forEach(function(file, index) { const
                                ext=file.split('.').pop().toLowerCase(); const isVideo=['mp4', 'webm' , 'ogg' , 'mov'
                                , 'qt' , 'avi' , 'mkv' ].includes(ext); %>
                                <% if (isVideo) { %>
                                  <video src="/uploads/tweets/<%= file %>" controls
                                    class="w-full aspect-video object-cover bg-black">
                                    Your browser does not support the video tag.
                                  </video>
                                  <% } else { %>
                                    <div
                                      class="relative overflow-hidden <%= tweet.media.length === 1 ? 'aspect-auto max-h-[500px]' : 'aspect-square' %> bg-slate-100 dark:bg-slate-800">
                                      <img src="/uploads/tweets/<%= file %>" alt="Media"
                                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                                        onclick="showImageModal(this.src)"
                                        onerror="this.onerror=null; this.src='/images/placeholder.png';">
                                    </div>
                                    <% } %>
                                      <% }) %>
                            </div>
                            <% } %>
                        </div>

                        <!-- Action Bar -->
                        <div
                          class="flex items-center justify-between mt-4 pt-3 border-t border-slate-100 dark:border-slate-800 max-w-md">
                          <button
                            class="group flex items-center space-x-2 text-slate-500 dark:text-slate-400 hover:text-blue-500 dark:hover:text-blue-400 transition-colors focus:outline-none"
                            data-auth="<%= !!currentUser %>" onclick="handleComment(event, '<%= tweet._id %>')"
                            title="Comment">
                            <div
                              class="p-2 rounded-full group-hover:bg-blue-50 dark:group-hover:bg-blue-900/30 transition-colors">
                              <i class="far fa-comment text-lg"></i>
                            </div>
                            <span class="text-sm font-medium">
                              <%= tweet.comments.length || '' %>
                            </span>
                          </button>

                          <button
                            class="group flex items-center space-x-2 text-slate-500 dark:text-slate-400 hover:text-pink-500 dark:hover:text-pink-400 transition-colors focus:outline-none"
                            data-tweet-id="<%= tweet._id %>" data-auth="<%= !!currentUser %>"
                            onclick="handleLike(event, '<%= tweet._id %>', true)" title="Like">
                            <div
                              class="p-2 rounded-full group-hover:bg-pink-50 dark:group-hover:bg-pink-900/30 transition-colors">
                              <i
                                class="<%= tweet.isLiked ? 'fas text-pink-500' : 'far' %> fa-heart text-lg <%= tweet.isLiked ? 'animate-pulse-once' : '' %>"></i>
                            </div>
                            <span class="like-count text-sm font-medium <%= tweet.isLiked ? 'text-pink-500' : '' %>">
                              <%= tweet.likes.length || '' %>
                            </span>
                          </button>

                          <button
                            class="group flex items-center space-x-2 text-slate-500 dark:text-slate-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors focus:outline-none"
                            onclick="handleShare(event, '<%= tweet._id %>')" title="Share">
                            <div
                              class="p-2 rounded-full group-hover:bg-emerald-50 dark:group-hover:bg-emerald-900/30 transition-colors">
                              <i class="fas fa-share-alt text-lg"></i>
                            </div>
                          </button>
                        </div>

                  </div> <!-- End Content Column -->
                </div>
              </div>

              <!-- Comments Section -->
              <div id="comments-section-<%= tweet._id %>"
                class="hidden bg-slate-50 dark:bg-slate-900/50 border-t border-slate-100 dark:border-slate-800">
                <div class="p-5">
                  <% if (currentUser) { %>
                    <div id="comment-form-<%= tweet._id %>" class="mb-6 flex gap-3">
                      <div class="flex-shrink-0 pt-1">
                        <!-- Tiny Avatar for user -->
                        <div
                          class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center overflow-hidden">
                          <i class="fas fa-user text-slate-400 text-sm"></i>
                        </div>
                      </div>
                      <div class="flex-1">
                        <form class="comment-form" data-tweet-id="<%= tweet._id %>">
                          <textarea
                            class="w-full px-4 py-3 text-sm text-slate-900 dark:text-white placeholder-slate-500 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none custom-scrollbar"
                            placeholder="Post your reply..." rows="1" style="min-height: 46px;"></textarea>
                          <div class="flex justify-end mt-2">
                            <button type="submit"
                              class="px-4 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-full transition-colors shadow-sm disabled:opacity-50">
                              Reply
                            </button>
                          </div>
                        </form>
                      </div>
                    </div>
                    <% } %>

                      <div class="comments-list-container custom-scrollbar max-h-[400px] overflow-y-auto pr-2">
                        <div id="comments-list-<%= tweet._id %>" class="space-y-4">
                          <% tweet.comments.slice().sort(function(a, b) { return new Date(b.createdAt) - new
                            Date(a.createdAt); }).forEach(function(comment) { %>
                            <div class="group flex gap-3">
                              <div class="flex-shrink-0">
                                <%- include('../partials/avatar', { tweet: { displayName: comment.displayName,
                                  displayProfilePicture: comment.displayProfilePicture, isAnonymous: !!comment.anonymous
                                  }, sizeClass: 'w-8 h-8 rounded-full' , showAnonymousImage: false }) %>
                              </div>
                              <div class="flex-1">
                                <div
                                  class="bg-white dark:bg-slate-800 rounded-2xl rounded-tl-none px-4 py-3 shadow-sm inline-block min-w-[200px]">
                                  <div class="flex items-center justify-between mb-1">
                                    <span class="font-semibold text-sm text-slate-900 dark:text-slate-100">
                                      <%= comment.displayName %>
                                    </span>
                                    <span class="text-[11px] text-slate-400 comment-time"
                                      data-timestamp="<%= comment.createdAt %>">
                                      <%= new Date(comment.createdAt).toLocaleString() %>
                                    </span>
                                  </div>
                                  <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">
                                    <%= comment.content %>
                                  </p>
                                </div>
                              </div>
                            </div>
                            <% }) %>
                        </div>
                      </div>
                </div>
              </div>

            </article>
            <% }) %>
              <% } else { %>
                <!-- Empty State -->
                <div
                  class="flex flex-col items-center justify-center py-20 bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm text-center px-4">
                  <div
                    class="w-16 h-16 bg-slate-100 dark:bg-slate-800 rounded-full flex items-center justify-center mb-4">
                    <i class="fas fa-wind text-2xl text-slate-400"></i>
                  </div>
                  <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">It's quiet here</h3>
                  <p class="text-slate-500 dark:text-slate-400 text-sm max-w-xs mx-auto">Be the first to raise an issue
                    or share an update with your community.</p>
                </div>
                <% } %>
      </div>
    </div>
  </main>

  <!-- Image Modal (Refined) -->
  <div id="imageModal"
    class="fixed inset-0 bg-slate-950/95 backdrop-blur-sm flex items-center justify-center z-50 hidden transition-opacity duration-300"
    onclick="hideImageModal()">
    <div class="relative max-w-5xl w-full h-full p-4 flex items-center justify-center">
      <img id="modalImage" src="" alt="Full size" class="max-w-full max-h-full object-contain rounded-md shadow-2xl"
        onclick="event.stopPropagation()">
      <button onclick="hideImageModal()"
        class="absolute top-6 right-6 text-white/70 hover:text-white bg-black/20 hover:bg-black/40 rounded-full w-10 h-10 flex items-center justify-center transition-colors">
        <i class="fas fa-times text-xl"></i>
      </button>
    </div>
  </div>

  <!-- FAB: Create Post (Modern) -->
  <button onclick="openPostModal()"
    class="fixed bottom-10 right-10 bg-blue-600 hover:bg-blue-700 text-white rounded-full w-14 h-14 flex items-center justify-center shadow-lg hover:shadow-blue-500/30 transform hover:-translate-y-1 transition-all duration-300 z-40 focus:outline-none focus:ring-4 focus:ring-blue-500/30">
    <i class="fas fa-plus text-xl"></i>
  </button>

  <!-- Create Post Modal -->
  <div id="postModal"
    class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-50 hidden p-4"
    onclick="closePostModal()">
    <div
      class="bg-white dark:bg-slate-900 w-full rounded-2xl shadow-2xl max-w-lg h-auto max-h-[85vh] flex flex-col overflow-hidden"
      onclick="event.stopPropagation()">

      <!-- Modal Header -->
      <div class="flex justify-between items-center px-4 py-3 border-b border-slate-900 dark:border-slate-700">
        <button onclick="closePostModal()"
          class="text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-white transition-colors">
          <span class="text-sm font-medium">Cancel</span>
        </button>
        <h3 class="font-semibold text-slate-900 dark:text-white">New Issue</h3>
        <!-- Submit Trigger (handled by JS effectively, but visual anchor) -->
        <div class="w-10"></div>
      </div>

      <div class="p-0 overflow-y-auto flex-1 custom-scrollbar">
        <form id="createTweetForm" action="/tweets" method="POST" enctype="multipart/form-data"
          class="flex flex-col h-full" data-is-logged-in="<%= !!currentUser %>">

          <div class="p-4 space-y-4">
            <!-- Text Area -->
            <div class="relative">
              <textarea name="content" id="createTweetContent"
                class="w-full p-0 text-lg bg-transparent border-none focus:ring-0 text-slate-900 dark:text-white placeholder-slate-400 min-h-[150px] resize-none caret-black dark:caret-white"
                placeholder="What is the issue? Use @Name to tag representatives..." required></textarea>

              <div id="autocomplete-list"
                class="hidden absolute left-0 right-0 top-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg shadow-xl z-50 max-h-60 overflow-y-auto">
              </div>
            </div>

            <!-- Media Preview Container (Dynamic via JS usually, visual placeholder) -->

            <!-- Location Input -->
            <div
              class="flex items-center space-x-2 text-slate-500 dark:text-slate-400 border-t border-slate-300 dark:border-slate-700 pt-4">
              <i class="fas fa-map-marker-alt text-blue-500"></i>
              <input type="text" name="location" placeholder="Add location (e.g. Patna)"
                class="bg-transparent border-none focus:ring-0 text-sm w-full text-slate-800 dark:text-slate-200 placeholder-slate-400">
            </div>

            <!-- File Input Styled -->
            <div class="pt-2">
              <label for="createTweetMedia"
                class="flex items-center space-x-2 cursor-pointer w-max text-blue-600 dark:text-blue-400 hover:text-blue-700 transition-colors">
                <div class="w-8 h-8 rounded-full bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center">
                  <i class="fas fa-image"></i>
                </div>
                <span class="text-sm font-medium">Add Photos/Video</span>
              </label>
              <input type="file" id="createTweetMedia" name="media" accept="image/*,video/*" multiple class="hidden">
            </div>

            <!-- Counters/Errors -->
            <div class="flex items-center justify-between text-xs text-slate-400 pt-2">
              <div id="createTweetError" class="text-red-500 hidden font-medium"></div>
              <div class="ml-auto">
                <span id="createTweetRemaining"
                  class="font-mono font-medium text-slate-600 dark:text-slate-300">300</span> words
              </div>
            </div>
          </div>

          <!-- Footer Actions -->
          <div
            class="p-4 border-t border-slate-300 dark:border-slate-700 flex justify-end bg-slate-50 dark:bg-slate-950/50 mt-0">
            <button type="submit" id="submitTweetBtn"
              class="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-full font-bold shadow-md hover:shadow-lg transition-all transform hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
              Post Issue
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Share Modal -->
  <div id="shareModal"
    class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-50 hidden p-4"
    onclick="closeShareModal()">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-sm transform transition-all scale-100"
      onclick="event.stopPropagation()">
      <div class="p-4 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center">
        <h3 class="font-bold text-slate-900 dark:text-white">Share via</h3>
        <button onclick="closeShareModal()"
          class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 transition-colors">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-4 gap-4">
          <button onclick="shareToPlatform('whatsapp')" class="flex flex-col items-center gap-2 group">
            <div
              class="w-12 h-12 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-green-600 dark:text-green-400 group-hover:scale-110 transition-transform">
              <i class="fab fa-whatsapp text-2xl"></i>
            </div>
            <span class="text-xs text-slate-600 dark:text-slate-400">WhatsApp</span>
          </button>
          <button onclick="shareToPlatform('twitter')" class="flex flex-col items-center gap-2 group">
            <div
              class="w-12 h-12 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-500 dark:text-blue-400 group-hover:scale-110 transition-transform">
              <i class="fab fa-twitter text-2xl"></i>
            </div>
            <span class="text-xs text-slate-600 dark:text-slate-400">X</span>
          </button>
          <button onclick="shareToPlatform('facebook')" class="flex flex-col items-center gap-2 group">
            <div
              class="w-12 h-12 rounded-full bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center text-indigo-600 dark:text-indigo-400 group-hover:scale-110 transition-transform">
              <i class="fab fa-facebook-f text-xl"></i>
            </div>
            <span class="text-xs text-slate-600 dark:text-slate-400">Facebook</span>
          </button>
          <button onclick="shareToPlatform('copy')" class="flex flex-col items-center gap-2 group">
            <div
              class="w-12 h-12 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 group-hover:scale-110 transition-transform">
              <i class="fas fa-link text-xl"></i>
            </div>
            <span class="text-xs text-slate-600 dark:text-slate-400">Copy</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="toast"
    class="fixed bottom-6 left-1/2 transform -translate-x-1/2 bg-slate-900 text-white px-6 py-3 rounded-full shadow-xl hidden transition-opacity duration-300 z-[60] font-medium text-sm flex items-center gap-2">
    <i class="fas fa-check-circle text-green-400"></i> Link copied to clipboard
  </div>

  <script src="/js/image-modal.js"></script>
  <script src="/js/tweet-interactions.js"></script>
  <script src="/js/autocomplete.js"></script>
  <script>
    // --- Helper Functions ---
    function countWords(text) {
      if (!text) return 0;
      return text.trim().split(/\s+/).filter(Boolean).length;
    }

    function setupTweetWordCounter(textareaId, remainingId, errorId, formId, submitButtonId) {
      const ta = document.getElementById(textareaId);
      const remainingEl = document.getElementById(remainingId);
      const errorEl = document.getElementById(errorId);
      const form = document.getElementById(formId);
      const submitBtn = document.getElementById(submitButtonId);

      if (!ta || !remainingEl) return;

      function update() {
        const words = countWords(ta.value);
        const remaining = 300 - words;
        remainingEl.textContent = remaining;

        if (remaining < 0) {
          remainingEl.classList.add('text-red-600', 'dark:text-red-400');
          if (submitBtn) submitBtn.disabled = true;
          if (submitBtn) submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
          if (errorEl) {
            errorEl.textContent = `Please remove ${Math.abs(remaining)} word${Math.abs(remaining) === 1 ? '' : 's'}.`;
            errorEl.classList.remove('hidden');
          }
        } else {
          remainingEl.classList.remove('text-red-600', 'dark:text-red-400');
          if (submitBtn) submitBtn.disabled = false;
          if (submitBtn) submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          if (errorEl) {
            errorEl.textContent = '';
            errorEl.classList.add('hidden');
          }
        }
      }

      ta.addEventListener('input', update);
      // Initial check
      update();

      if (form) {
        form.addEventListener('submit', function (e) {
          const words = countWords(ta.value);
          if (words > 300) {
            e.preventDefault();
            update();
          }
        });
      }
    }

    // --- Modal Logic ---
    const postModal = document.getElementById('postModal');

    function openPostModal() {
      postModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }

    function closePostModal() {
      postModal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    // --- Formatting Logic ---
    function formatRelativeTime(timestamp) {
      const now = new Date();
      const date = new Date(timestamp);
      const seconds = Math.floor((now - date) / 1000);

      let interval = seconds / 31536000;
      if (interval > 1) return Math.floor(interval) + "y";
      interval = seconds / 2592000;
      if (interval > 1) return Math.floor(interval) + "mo";
      interval = seconds / 86400;
      if (interval > 1) return Math.floor(interval) + "d";
      interval = seconds / 3600;
      if (interval > 1) return Math.floor(interval) + "h";
      interval = seconds / 60;
      if (interval > 1) return Math.floor(interval) + "m";
      return "Just now";
    }

    function parseTweetContent() {
      document.querySelectorAll('.tweet-body-text').forEach(el => {
        let content = el.innerHTML;
        // Make hashtags blue/clickable
        content = content.replace(/(?<!\w)(#\w+)/g, '<span class="text-blue-500 font-medium hover:underline cursor-pointer">$1</span>');
        el.innerHTML = content;
      });
    }

    document.addEventListener('DOMContentLoaded', function () {
      if (typeof initTweetInteractions === 'function') {
        initTweetInteractions();
      }

      document.querySelectorAll('.tweet-time, .comment-time').forEach(el => {
        el.textContent = formatRelativeTime(el.dataset.timestamp);
      });
      parseTweetContent();

      setupAutocomplete('createTweetContent', 'autocomplete-list');
      setupTweetWordCounter('createTweetContent', 'createTweetRemaining', 'createTweetError', 'createTweetForm', 'submitTweetBtn');
    });
  </script>
