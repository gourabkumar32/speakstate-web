<%- include('../partials/header') %>

<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto bg-white rounded-lg shadow-lg p-6">
        <h1 class="text-2xl font-bold mb-6">Create New Post</h1>

        <% if (error && error.length > 0) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6" role="alert">
                <span class="block sm:inline"><%= error %></span>
            </div>
        <% } %>

        <form action="/tweets" method="POST" enctype="multipart/form-data" class="space-y-6" id="newTweetForm">
            <!-- Content -->
            <div>
                <label for="content" class="block text-sm font-medium text-gray-700 mb-2">
                    Content <span class="text-red-500">*</span>
                </label>
                <textarea
                    id="content"
                    name="content"
                    rows="4"
                    required
                    class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500"
                    placeholder="What's happening?"
                ></textarea>
                <div class="flex items-center justify-between text-sm text-slate-500 mt-1">
                    <span id="newTweetRemaining" class="font-mono">300</span>
                    <span></span>
                 </div>
                <div id="newTweetError" class="text-sm text-red-600 mt-1 hidden"></div>
            </div>

            <!-- Location -->
            <div>
                <label for="location" class="block text-sm font-medium text-gray-700 mb-2">
                    Location
                </label>
                <input
                    type="text"
                    id="location"
                    name="location"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500"
                    placeholder="Location"
                >
            </div>

            <!-- Institution 
            <div>
                <label for="institution" class="block text-sm font-medium text-gray-700 mb-2">
                    Institution/Organization
                </label>
                <input
                    type="text"
                    id="institution"
                    name="institution"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500"
                    placeholder="Related institution or organization"
                >
            </div>-->

            <!-- Media Upload -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    Media (Images/Videos)
                </label>
                <label for="media" class="block cursor-pointer">
                    <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md hover:border-blue-400 hover:bg-blue-50 transition-all duration-200">
                        <div class="space-y-1 text-center">
                            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
                                <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <div class="flex justify-center text-sm text-gray-600">
                                <span class="text-blue-600 font-medium hover:text-blue-500">Upload files</span>
                                <span class="pl-1">or drag and drop</span>
                            </div>
                            <p class="text-xs text-gray-500">PNG, JPG, GIF up to 10MB</p>
                            <input id="media" name="media" type="file" class="hidden" multiple accept="image/*">
                        </div>
                    </div>
                </label>
                <div id="preview" class="mt-4 grid grid-cols-2 gap-4"></div>
            </div>

            <!-- Submit Button -->
            <div class="flex items-center justify-end">
                <div class="flex justify-end">
                    <button
                        type="submit"
                        class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
                    >
                        Post
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    // Autocomplete functionality for @mentions
    const tweetInput = document.getElementById('content');
    let autocompleteList = null;

    // Create autocomplete dropdown
    function createAutocompleteList() {
        if (!autocompleteList) {
            autocompleteList = document.createElement('div');
            autocompleteList.className = 'absolute z-50 bg-white border border-gray-300 rounded-md shadow-lg max-h-60 overflow-y-auto w-64';
            autocompleteList.style.display = 'none';
            document.body.appendChild(autocompleteList);
        }
    }

    // Position autocomplete list
    function positionAutocompleteList(atIndex) {
        const rect = tweetInput.getBoundingClientRect();
        const text = tweetInput.value.substring(0, atIndex);
        const lines = text.split('\n');
        const currentLine = lines[lines.length - 1];
        
        // Approximate position (this is a simple approximation)
        const lineHeight = 24; // approximate line height
        const top = rect.top + (lines.length - 1) * lineHeight + 30;
        const left = rect.left + 20; // approximate for @ position
        
        autocompleteList.style.top = top + 'px';
        autocompleteList.style.left = left + 'px';
        autocompleteList.style.display = 'block';
    }

    // Handle input events
    tweetInput.addEventListener('input', function(e) {
        const val = this.value;
        const cursorPos = this.selectionStart;
        
        // Find the @ before cursor
        const beforeCursor = val.substring(0, cursorPos);
        const atIndex = beforeCursor.lastIndexOf('@');
        
        if (atIndex !== -1) {
            const afterAt = beforeCursor.substring(atIndex + 1);
            if (afterAt.indexOf(' ') === -1 && afterAt.length > 0) {
                // We have @something, show suggestions
                createAutocompleteList();
                positionAutocompleteList(atIndex);
                fetchSuggestions(afterAt, atIndex);
            } else {
                if (autocompleteList) autocompleteList.style.display = 'none';
            }
        } else {
            if (autocompleteList) autocompleteList.style.display = 'none';
        }
    });

    // Handle keydown for navigation
    tweetInput.addEventListener('keydown', function(e) {
        if (autocompleteList && autocompleteList.style.display !== 'none') {
            if (e.key === 'Escape') {
                autocompleteList.style.display = 'none';
                e.preventDefault();
                return;
            }
        }
    });

    async function fetchSuggestions(query, atIndex) {
        try {
            const res = await fetch(`/mlas/search/json?q=${encodeURIComponent(query)}`);
            const results = await res.json();

            if (results.length > 0) {
                renderSuggestions(results, atIndex);
            } else {
                autocompleteList.style.display = 'none';
            }
        } catch (err) {
            console.error('Error fetching suggestions', err);
            autocompleteList.style.display = 'none';
        }
    }

    function renderSuggestions(results, atIndex) {
        autocompleteList.innerHTML = '';
        
        results.forEach(item => {
            const div = document.createElement('div');
            div.className = 'p-3 hover:bg-gray-100 cursor-pointer flex items-center space-x-3 border-b last:border-0';
            div.innerHTML = `
                <img src="${item.image && !item.image.includes('default') ? '/uploads/candidates/' + item.image : '/images/default-avatar.png'}" 
                     class="w-10 h-10 rounded-full object-cover">
                <div>
                    <p class="font-semibold text-sm">${item.name}</p>
                    <p class="text-xs text-gray-500">${item.type} • ${item.subtext}</p>
                </div>
            `;

            div.onclick = () => {
                const val = tweetInput.value;
                const before = val.substring(0, atIndex);
                const after = val.substring(tweetInput.selectionStart);
                
                // Insert name
                const newText = before + '@' + item.name + ' ' + after;
                tweetInput.value = newText;
                autocompleteList.style.display = 'none';
                tweetInput.focus();
            };

            autocompleteList.appendChild(div);
        });
    }

    // Close autocomplete on click outside
    document.addEventListener('click', function(e) {
        if (autocompleteList && !tweetInput.contains(e.target) && !autocompleteList.contains(e.target)) {
            autocompleteList.style.display = 'none';
        }
    });
</script>

<script>
        // Handle form submission
    document.getElementById('newTweetForm').addEventListener('submit', function(event) {
        // Word count guard (server also enforces limit)
        const content = document.getElementById('content').value || '';
        const words = content.trim().split(/\s+/).filter(Boolean).length;
        const remaining = 300 - words;
        if (remaining < 0) {
            event.preventDefault();
            const err = document.getElementById('newTweetError');
            err.textContent = `Please remove ${Math.abs(remaining)} word${Math.abs(remaining) === 1 ? '' : 's'} to meet the 300-word limit.`;
            err.classList.remove('hidden');
            return;
        }

        // Let the form submit normally, no need to prevent default
        const submitButton = this.querySelector('button[type="submit"]');
        submitButton.disabled = true;
        submitButton.innerHTML = 'Posting...';
    });

    // Live word counter for new tweet form
    document.getElementById('content').addEventListener('input', function () {
        const words = (this.value || '').trim().split(/\s+/).filter(Boolean).length;
        const remaining = 300 - words;
        const el = document.getElementById('newTweetRemaining');
        el.textContent = remaining;
        if (remaining < 0) el.classList.add('text-red-600'); else el.classList.remove('text-red-600');
        const err = document.getElementById('newTweetError');
        if (remaining < 0) { err.textContent = `Please remove ${Math.abs(remaining)} word${Math.abs(remaining) === 1 ? '' : 's'} to meet the 300-word limit.`; err.classList.remove('hidden'); } else { err.textContent = ''; err.classList.add('hidden'); }
        const submitButton = document.querySelector('#newTweetForm button[type="submit"]');
        if (submitButton) submitButton.disabled = remaining < 0;
    });

    // Preview uploaded images
    document.getElementById('media').addEventListener('change', function(event) {
        const preview = document.getElementById('preview');
        preview.innerHTML = '';
        
        // Only show first 5 images in preview
        Array.from(event.target.files).slice(0, 5).forEach(file => {
            if (file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'relative';
                    div.innerHTML = `
                        <img src="${e.target.result}" class="w-full h-48 object-cover rounded-lg">
                        <button type="button" class="absolute top-2 right-2 bg-red-500 text-white rounded-full p-1 hover:bg-red-600">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    `;
                    preview.appendChild(div);

                    // Add click handler to remove button
                    div.querySelector('button').addEventListener('click', function() {
                        div.remove();
                        // Create a new FileList without this file
                        const dt = new DataTransfer();
                        const input = document.getElementById('media');
                        const { files } = input;
                        
                        for (let i = 0; i < files.length; i++) {
                            const f = files[i];
                            if (f !== file) dt.items.add(f);
                        }
                        
                        input.files = dt.files;
                    });
                };
                reader.readAsDataURL(file);
            }
        });
    });
</script>

<%- include('../partials/footer') %>
