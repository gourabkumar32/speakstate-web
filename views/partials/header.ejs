<body class="bg-gray-50 text-gray-800">

  <header class="bg-[#0f172a] text-white fixed w-full z-50 shadow-lg h-16 md:h-18 flex items-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between w-full">

      <a href="/" class="flex items-center gap-2">
        <!--<div
          class="h-8 w-8 rounded-xl bg-gradient-to-br from-sky-400 to-indigo-500 flex items-center justify-center text-xs font-bold text-slate-950">
          SS</div>-->
        <span class="text-xl sm:text-2xl font-extrabold tracking-tight text-white">
          speak<span class="text-sky-400">state</span>
        </span>
      </a>

      <button id="hamburger" class="md:hidden text-gray-200 hover:text-sky-400 transition-colors"
        onclick="toggleMobileMenu()">
        <i data-lucide="menu" class="w-7 h-7"></i>
      </button>

      <nav class="hidden md:flex gap-4 items-center">
