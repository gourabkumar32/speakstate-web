    </div>

    <div id="mobileMenu"
      class="fixed inset-0 bg-white text-white z-40 transform translate-x-full transition-transform duration-300 md:hidden">
      <div class="flex justify-between items-center px-4 sm:px-6 h-16 md:h-18 border-b border-grey-700">

        <a href="/" class="flex items-center  text-2xl font-semibold tracking-tight text-black-50">

          Speak<span class="text-sky-400">State</span>
        </a>

        <button id="menuClose" class="text-black-200 hover:text-sky-400 transition-colors">
          <i data-lucide="x" class="w-8 h-8"></i>
        </button>
      </div>

      <div class="side p-6 space-y-4 text-lg">
        <% if (typeof user !=='undefined' && user) { %>
          <a href="/" class="block text-black-200 hover:text-sky-400 transition-colors py-3 font-medium">Home</a>
          <a href="/mlas" class="block text-black-200 hover:text-sky-400 transition-colors py-3 font-medium">Mla</a>
          <a href="/mps" class="block text-black-200 hover:text-sky-400 transition-colors py-3 font-medium">Mp</a>
          <a href="/tweets"
            class="block text-black-200 hover:text-sky-400 transition-colors py-3 font-medium">Issues</a>
          <!--<a href="/states"
            class="block text-black-200 hover:text-sky-400 transition-colors py-3 font-medium">Information</a>-->
          <a href="/profile"
            class="block text-black-200 hover:text-sky-400 transition-colors py-3 font-medium">Profile</a>

          <% if (user.isAdmin) { %>
            <div class="border-t border-gray-700 pt-4 space-y-4">
              <a href="/admin/dashboard"
                class="block text-gray-200 hover:text-sky-400 transition-colors py-3 font-medium flex items-center gap-3">
                <i class="fas fa-tachometer-alt"></i>Admin Dashboard
              </a>
              <a href="/admin/mlas"
                class="block text-gray-200 hover:text-sky-400 transition-colors py-3 font-medium flex items-center gap-3">
                <i class="fas fa-cog"></i>Manage MLAs
              </a>
              <a href="/admin/mps"
                class="block text-gray-200 hover:text-sky-400 transition-colors py-3 font-medium flex items-center gap-3">
                <i class="fas fa-cog"></i>Manage MPs
              </a>
            </div>
            <% } %>

              <form action="/auth/logout" method="POST" class="pt-4">
                <button type="submit"
                  class="block w-full text-center bg-sky-400 text-white hover:bg-sky-500 transition-colors duration-200 px-4 py-3 rounded-md font-medium">
                  Logout
                </button>
              </form>

              <% } else { %>

                <a href="/auth/login<%= (typeof currentPath !== 'undefined' && currentPath && !currentPath.startsWith('/auth')) ? '?returnTo=' + encodeURIComponent(currentPath) : '' %>"
                  class="block w-full text-center bg-sky-400 text-white hover:bg-sky-500 transition-colors duration-200 px-4 py-3 rounded-md font-medium">Login</a>
                <a href="/auth/register"
                  class="block w-full text-center bg-sky-400 text-white hover:bg-sky-500 transition-colors duration-200 px-4 py-3 rounded-md font-medium">Sign
                  Up</a>

                <% } %>
      </div>
    </div>
  </header>

  <div class="h-16 md:h-18"></div>

  <script>
    let isMenuOpen = false;

    function toggleMobileMenu() {
      const mobileMenu = document.getElementById('mobileMenu');
      isMenuOpen = !isMenuOpen;
      mobileMenu.classList.toggle('translate-x-full');
    }

    document.addEventListener('DOMContentLoaded', function () {
      // Call this function to render all lucide icons
      lucide.createIcons();

      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobileMenu');
      const menuClose = document.getElementById('menuClose');

      // Event listener for close button
      menuClose.addEventListener('click', toggleMobileMenu);

      // Close menu when clicking outside
      document.addEventListener('click', function (e) {
        // Check if hamburger is not null before checking contains
        const isHamburgerClick = hamburger && hamburger.contains(e.target);
        if (isMenuOpen && !mobileMenu.contains(e.target) && !isHamburgerClick) {
          toggleMobileMenu();
        }
      });

      // Close menu when pressing escape key
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && isMenuOpen) {
          toggleMobileMenu();
        }
      });
    });
  </script>

