          <a href="/tweets" class="block text-gray-200 hover:text-sky-400 transition-colors py-3 font-medium">Issues</a>
          <!--<a href="/states"
            class="text-gray-200 hover:text-sky-400 transition-colors duration-200 px-3 py-2 rounded-md text-sm font-medium">Information</a>-->
          <a href="/profile"
            class="text-gray-200 hover:text-sky-400 transition-colors duration-200 px-3 py-2 rounded-md text-sm font-medium">Profile</a>

          <% if (user.isAdmin) { %>
            <a href="/admin/dashboard"
              class="text-gray-200 hover:text-sky-400 transition-colors duration-200 px-3 py-2 rounded-md text-sm font-medium flex items-center gap-2">
              <i class="fas fa-tachometer-alt"></i>Admin
            </a>
            <a href="/admin/mlas"
              class="text-gray-200 hover:text-sky-400 transition-colors duration-200 px-3 py-2 rounded-md text-sm font-medium flex items-center gap-2">
              <i class="fas fa-cog"></i>Manage MLAs
            </a>
            <a href="/admin/mps"
              class="text-gray-200 hover:text-sky-400 transition-colors duration-200 px-3 py-2 rounded-md text-sm font-medium flex items-center gap-2">
              <i class="fas fa-cog"></i>Manage MPs
            </a>
            <% } %>

              <form action="/auth/logout" method="POST" class="ml-2">
                <button type="submit"
                  class="text-sky-400 border border-sky-400 hover:bg-sky-400 hover:text-white transition-colors duration-200 px-4 py-2 rounded-md text-sm font-medium">
                  Logout
                </button>
              </form>

              <% } else { %>

                <a href="/auth/login"
                  class="text-gray-200 hover:text-white bg-black transition-colors duration-200 px-3 py-2 rounded-md text-sm font-medium">Login</a>
                <a href="/auth/register"
                  class="bg-sky-400 text-white hover:bg-sky-500 transition-colors duration-200 px-4 py-2 rounded-md text-sm font-medium">Sign
                  Up</a>

                <% } %>
