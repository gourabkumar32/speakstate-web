<style>
    .block{
        margin-left: 20px;
        margin-right: 20px;
       /* background:white;
        color: white;*/
       
       box-shadow: 2px;
        
    }
    .text-3xl{
        font-size: 20px;
        padding-left: 20px;
        text-align: center;
        color: rgb(2, 2, 2);
        font-weight: 700;
        font-size: 22px;
        margin-top: 20px;
    }
   .w-full{
   margin-top: 0px;
