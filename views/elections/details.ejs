                <p class="text-lg text-black"><%= new Date(election.endDate).toLocaleDateString() %></p>
            </div>
        </div>
    </div>
-->


    <% election.constituencies.forEach(constituency => { %>
        <div class="constituency-section bg-white rounded-lg p-6" data-constituency="<%= constituency.name.toLowerCase() %>">
            <h2 class="text-xl font-bold text-black mb-4">Will he be able to win the next election from  <%= constituency.name %> constituency</h2>
            
