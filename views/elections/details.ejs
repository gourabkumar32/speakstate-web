                                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/50 to-transparent p-4">
                                        <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded-full text-sm font-semibold">
                                            <%= candidate.party %>
                                        </span>
                                    </div>
                                </div>
                                <h3 class="text-xl font-bold text-black p-4 pb-0 text-center"><%= candidate.name %></h3>
                                <div class="p-4">
                                    <div class="space-y-4">
                                       <!--<div class="flex justify-between text-sm text-gray-600">
                                            <span class="votes-count">Votes: <%= candidate.votes %></span>
                                            <span class="text-blue-600">
                                                <%= ((candidate.votes / election.totalVotes) * 100 || 0).toFixed(1) %>%
                                            </span>
                                        </div>--> 

                                <div class="space-y-2">
                                <% if (!isAuthenticated) { %>
                                    <button onclick="showLoginMessage()"
                                            class="vote-button w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg transition duration-200">
                                        Vote for <%= candidate.name %>
                                    </button>
                                <% } else if (hasVoted) { %>
                                    <div class="mt-2 flex justify-between text-sm font-bold">
                                        <span class="yes-votes text-green-600">Yes: <%= candidate.yesVotes || 0 %></span>
                                        <span class="no-votes text-red-600">No: <%= candidate.noVotes || 0 %></span>
                                    </div>
                                    <% if (userVote && userVote.candidate && userVote.candidate.toString() === candidate._id.toString()) { %>
                                    <div class="mt-2 text-center text-sm text-gray-600">
                                        You voted: <span class="<%= userVote.voteType === 'yes' ? 'text-green-600 font-bold' : 'text-red-600 font-bold' %>"><%= userVote.voteType === 'yes' ? 'Yes' : 'No' %></span>
                                    </div>
                                    <% } %>
                                <% } else if (!hasVotedInState) { %>
                                    <div class="flex space-x-2 w-full">
                                        <button onclick="voteYesNo('<%= election._id %>', '<%= candidate._id %>', '<%= constituency.name %>', 'yes')"
                                                class="vote-button flex-1 bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-lg transition duration-200">
                                            Yes
                                        </button>
                                        <button onclick="voteYesNo('<%= election._id %>', '<%= candidate._id %>', '<%= constituency.name %>', 'no')"
                                                class="vote-button flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-lg transition duration-200">
                                            No
                                        </button>
                                    </div>
                                    <div class="mt-2 flex justify-between text-sm font-bold">
                                        <span class="yes-votes text-green-600">Yes: <%= candidate.yesVotes || 0 %></span>
                                        <span class="no-votes text-red-600">No: <%= candidate.noVotes || 0 %></span>
                                    </div>
                                <% } else { %>
                                    <div class="mt-2 flex justify-between text-sm font-bold">
                                        <span class="yes-votes text-green-600">Yes: <%= candidate.yesVotes || 0 %></span>
                                        <span class="no-votes text-red-600">No: <%= candidate.noVotes || 0 %></span>
                                    </div>
                                    <div class="mt-2 text-center text-xs text-gray-500">
                                        (Already voted in this state)
                                    </div>
                                <% } %>
                                </div>
                             <!--
                                <button onclick="<%= isAuthenticated ? `showReviews('${candidate._id}')` : 'showLoginMessage()' %>"
                                        class="w-full mt-2 bg-gray-100 hover:bg-gray-200 text-black-800 font-bold py-2 px-4 rounded-lg transition duration-200">
                                    Reviews
                                </button>
                                -->  
                                
                                <% if (user) { %>
                                    <a href="/elections/candidate/<%= candidate._id %>" 
                                       class="block w-full mt-2 bg-purple-100 hover:bg-purple-200 text-purple-800 font-bold py-2 px-4 rounded-lg transition duration-200 text-center">
                                        View Details
                                    </a>
                                <% } else { %>
                                    <a href="/auth/login?returnTo=/elections/candidate/<%= candidate._id %>" 
