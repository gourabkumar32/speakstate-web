                                        View Details
                                    </a>
                                <% } %>
                                <% if (constituency.mla) { %>
                               <!-- <button onclick="showMlaDetails('<%= constituency.mla._id %>', '<%= constituency.mla.name %>', '<%= constituency.mla.description %>', '<%= constituency.mla.party %>', '<%= constituency.mla.constituency %>', '<%= constituency.mla.state %>', '<%= constituency.mla.image %>')"
                                        class="w-full mt-2 bg-green-100 hover:bg-green-200 text-green-800 font-bold py-2 px-4 rounded-lg transition duration-200">
                                    View MLA Work
                                </button>-->
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
              </div>
                <!-- Add Pagination -->
                <div class="swiper-pagination"></div>
                <!-- Add Navigation -->
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>
            </div>
        </div>
    <% }); %>
</div>

<!-- Review Modal -->
<div id="reviewModal" class="hidden fixed inset-0 bg-black bg-opacity-75 z-50">
    <div class="bg-gray-800 rounded-lg max-w-lg mx-auto mt-20 p-6 relative">
        <button onclick="closeReviewModal()" class="absolute top-4 right-4 text-gray-400 hover:text-white">&times;</button>
        
        <h3 class="text-xl font-bold text-white mb-4">Reviews</h3>
        
        <div id="reviewsList" class="max-h-96 overflow-y-auto mb-6">
            <!-- Reviews will be loaded here -->
        </div>

        <form id="reviewForm" class="space-y-4">
            <div>
                <label class="block text-gray-300 text-sm font-bold mb-2">Rating</label>
                <div class="flex space-x-2">
                    <% for(let i = 1; i <= 5; i++) { %>
                        <button type="button" onclick="setRating(<%= i %>)"
                                class="rating-star text-2xl text-gray-400 hover:text-yellow-400 focus:text-yellow-400">
                            ☆
                        </button>
                    <% } %>
                </div>
                <input type="hidden" id="ratingInput" name="rating" required>
            </div>

            <div>
                <label class="block text-gray-300 text-sm font-bold mb-2">Comment</label>
                <textarea name="comment" rows="3" required
                          class="w-full bg-gray-700 text-white rounded p-2 focus:ring-2 focus:ring-blue-500"></textarea>
            </div>

            <button type="submit" 
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
                Submit Review
            </button>
        </form>
    </div>
</div>

<!-- MLA Details Modal -->
<div id="mlaDetailsModal" class="hidden fixed inset-0 bg-black bg-opacity-75 z-50">
    <div class="bg-white rounded-lg max-w-lg mx-auto mt-20 p-6 relative">
        <button onclick="closeMlaDetailsModal()" class="absolute top-4 right-4 text-gray-600 hover:text-black text-2xl">&times;</button>
        
        <div class="text-center mb-4">
            <img id="mlaImage" src="" alt="MLA Image" class="w-32 h-32 rounded-full mx-auto mb-4 object-cover border-4 border-blue-500">
            <h3 id="mlaName" class="text-2xl font-bold text-gray-800"></h3>
        </div>
        
        <div class="grid grid-cols-2 gap-4 mb-4 text-center">
            <div class="bg-gray-100 p-3 rounded-lg">
                <p class="text-gray-600 text-sm">Party</p>
                <p id="mlaParty" class="font-semibold text-gray-800"></p>
            </div>
            <div class="bg-gray-100 p-3 rounded-lg">
                <p class="text-gray-600 text-sm">Constituency</p>
                <p id="mlaConstituency" class="font-semibold text-gray-800"></p>
            </div>
        </div>
        
        <% if (election && election.constituencies) { %>
            <% election.constituencies.forEach(constituency => { %>
                <% constituency.candidates.forEach(candidate => { %>
                    <div class="bg-gray-100 p-4 rounded-lg mb-4">
                        <h4 class="font-bold text-gray-800 mb-2">Manifesto</h4>
                        <% if (candidate.manifesto && candidate.manifesto.length > 0) { %>
                            <ul class="list-disc pl-5 space-y-1">
                                <% candidate.manifesto.forEach(item => { %>
                                    <li class="text-gray-700"><%= item %></li>
                                <% }); %>
                            </ul>
                        <% } else { %>
                            <p class="text-gray-600 italic">No manifesto points available.</p>
                        <% } %>
                    </div>
                    
                    <div class="bg-gray-100 p-4 rounded-lg mb-4">
                        <h4 class="font-bold text-gray-800 mb-2">Key Achievements</h4>
                        <% if (candidate.achievements && candidate.achievements.length > 0) { %>
                            <ul class="list-disc pl-5 space-y-1">
                                <% candidate.achievements.forEach(item => { %>
                                    <li class="text-gray-700"><%= item %></li>
                                <% }); %>
                            </ul>
                        <% } else { %>
                            <p class="text-gray-600 italic">No achievements listed yet.</p>
                        <% } %>
                    </div>
                    
                    <div class="bg-gray-100 p-4 rounded-lg mb-4">
                        <h4 class="font-bold text-gray-800 mb-2">Corruption Records</h4>
                        <% if (candidate.corruption && candidate.corruption.length > 0) { %>
                            <ul class="list-disc pl-5 space-y-1">
                                <% candidate.corruption.forEach(item => { %>
                                    <li class="text-gray-700"><%= item %></li>
                                <% }); %>
                            </ul>
                        <% } else { %>
                            <p class="text-gray-600 italic">No corruption records available.</p>
                        <% } %>
                    </div>
                <% }); %>
            <% }); %>
        <% } else { %>
            <p class="text-gray-600 italic">No election data available.</p>
        <% } %>
        
        <div id="mlaDescription" class="mt-4 text-gray-700"></div>
    </div>
</div>

<script>
// Hamburger Menu Logic
document.addEventListener('DOMContentLoaded', function() {
            
            // --- Hamburger Menu Logic ---
            const hamburger = document.getElementById('hamburger');
            const mobileMenu = document.getElementById('mobileMenu');
            const menuClose = document.getElementById('menuClose');

            // Check if the elements actually exist on the page before adding event listeners
            if (hamburger && mobileMenu && menuClose) {
                hamburger.addEventListener('click', () => {
                    mobileMenu.classList.remove('translate-x-full');
                });

                menuClose.addEventListener('click', () => {
                    mobileMenu.classList.add('translate-x-full');
                });
            }
            });
document.addEventListener('DOMContentLoaded', function() {
        
        // --- Hamburger Menu Logic ---
        const hamburger = document.getElementById('hamburger');
        const mobileMenu = document.getElementById('mobileMenu');
        const menuClose = document.getElementById('menuClose');

        // This checks if the menu elements exist before trying to use them.
        if (hamburger && mobileMenu && menuClose) {
            
            // Show the menu when hamburger is clicked
            hamburger.addEventListener('click', () => {
                mobileMenu.classList.remove('translate-x-full');
            });

            // Hide the menu when the close button is clicked
            menuClose.addEventListener('click', () => {
                mobileMenu.classList.add('translate-x-full');
            });
        }

    });


// Add star rating functionality
function setRating(rating) {
    document.getElementById('ratingInput').value = rating;
    const stars = document.querySelectorAll('.rating-star');
    stars.forEach((star, index) => {
        if (index < rating) {
            star.textContent = '★';
            star.classList.add('text-yellow-400');
        } else {
            star.textContent = '☆';
            star.classList.remove('text-yellow-400');
        }
    });
}

function resetStars() {
    const stars = document.querySelectorAll('.rating-star');
    stars.forEach(star => {
        star.textContent = '☆';
        star.classList.remove('text-yellow-400');
    });
    document.getElementById('ratingInput').value = '';
}

// MLA Details Modal Functions
function showMlaDetails(mlaId, name, description, party, constituency, state, image) {
    // Set MLA details in the modal
    document.getElementById('mlaName').textContent = name;
    document.getElementById('mlaParty').textContent = party;
    document.getElementById('mlaConstituency').textContent = constituency;
    
    // Set description if available
    const descriptionElement = document.getElementById('mlaDescription');
    if (description) {
        descriptionElement.textContent = description;
        descriptionElement.classList.remove('hidden');
    } else {
        descriptionElement.classList.add('hidden');
    }
    
    // Set image
    const imageElement = document.getElementById('mlaImage');
    if (image) {
        imageElement.src = image.startsWith('/') ? image : `/${image}`;
        imageElement.classList.remove('hidden');
    } else {
        imageElement.classList.add('hidden');
    }
    
    // Corruption records section removed
    
    // Show the modal
    document.getElementById('mlaDetailsModal').classList.remove('hidden');
}

function closeMlaDetailsModal() {
    document.getElementById('mlaDetailsModal').classList.add('hidden');
}

async function loadReviews(candidateId) {
    const reviewsList = document.getElementById('reviewsList');
    reviewsList.innerHTML = '<p class="text-gray-400 text-center">Loading reviews...</p>';

    try {
        const response = await fetch(`/elections/candidate/${candidateId}/reviews`);
        const data = await response.json();

        if (data.success) {
            if (data.reviews && data.reviews.length > 0) {
        reviewsList.innerHTML = data.reviews.map(review => {
          const isAnon = !!review.anonymous;
          const displayName = review.displayName || (isAnon ? (review.anonymousName || (review.user && review.user.anonName) || 'Anonymous') : ((review.user && (review.user.anonName || review.user.name)) || 'Anonymous'));
          return `
          <div class="bg-gray-700 rounded-lg p-4 mb-4">
            <div class="flex justify-between items-center mb-2">
              <div class="flex items-center">
                <span class="text-yellow-400 mr-2">
                  ${'★'.repeat(review.rating)}${'☆'.repeat(5-review.rating)}
                </span>
                <span class="text-gray-300">${displayName}</span>
              </div>
              <span class="text-gray-400 text-sm">
                ${new Date(review.createdAt).toLocaleDateString()}
              </span>
            </div>
            <p class="text-gray-300">${review.comment}</p>
          </div>
        `}).join('');
            } else {
                reviewsList.innerHTML = '<p class="text-gray-400 text-center">No reviews yet</p>';
            }
        } else {
            throw new Error(data.message);
        }
    } catch (error) {
        console.error('Error loading reviews:', error);
        reviewsList.innerHTML = '<p class="text-red-400 text-center">Error loading reviews</p>';
    }
}

function showReviews(candidateId) {
    currentCandidateId = candidateId;
    document.getElementById('reviewModal').classList.remove('hidden');
    loadReviews(candidateId);
}

function closeReviewModal() {
    document.getElementById('reviewModal').classList.add('hidden');
    document.getElementById('reviewForm').reset();
    resetStars();
    currentCandidateId = null;
}

// Handle form submission
document.getElementById('reviewForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    if (!currentCandidateId) {
        showNotification('No candidate selected', 'error');
        return;
    }

    const rating = document.getElementById('ratingInput').value;
    const comment = this.querySelector('[name="comment"]').value;

    if (!rating || !comment.trim()) {
        showNotification('Please provide both rating and comment', 'error');
        return;
    }

    try {
        const response = await fetch(`/elections/candidate/${currentCandidateId}/reviews`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ rating, comment })
        });

        const data = await response.json();
        if (data.success) {
            showNotification('Review submitted successfully', 'success');
            await loadReviews(currentCandidateId);
            this.reset();
            resetStars();
        } else {
            showNotification(data.message || 'Error submitting review', 'error');
        }
    } catch (error) {
        console.error('Error submitting review:', error);
        showNotification('Error submitting review', 'error');
    }
});

// Close modal when clicking outside
document.getElementById('reviewModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeReviewModal();
    }
});

function showNotification(message, type = 'success') {
    const notification = document.createElement('div');
    notification.className = `fixed top-4 right-4 p-4 rounded-lg shadow-lg ${
        type === 'success' ? 'bg-green-900 text-green-200' : 'bg-red-900 text-red-200'
    } z-50 transition-opacity duration-500`;
    notification.textContent = message;

    document.body.appendChild(notification);

    setTimeout(() => {
        notification.style.opacity = '0';
        setTimeout(() => notification.remove(), 500);
    }, 3000);
}

// Update vote count display
function updateVoteCount(candidateId, newCount) {
    const votesElement = document.querySelector(`[data-candidate="${candidateId}"] .votes-count`);
    if (votesElement) {
        votesElement.textContent = newCount;
    }
}

async function voteForCandidate(electionId, candidateId, constituencyName) {
    try {
        const response = await fetch('/elections/vote', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ electionId, candidateId, constituencyName })
        });

        const data = await response.json();
        if (data.success) {
            // Update UI without reloading
            const candidateCard = document.querySelector(`[data-candidate="${candidateId}"]`);
            const voteButton = candidateCard.querySelector('.vote-button');
            const votesCount = candidateCard.querySelector('.votes-count');
            
            // Update vote count
            const currentVotes = parseInt(votesCount.textContent) || 0;
            votesCount.textContent = currentVotes + 1;
            
            // Update total votes
            const totalVotesElement = document.querySelector('.total-votes-count');
            if (totalVotesElement) {
                const currentTotal = parseInt(totalVotesElement.textContent) || 0;
                totalVotesElement.textContent = currentTotal + 1;
            }

            // Disable vote button
            voteButton.disabled = true;
            voteButton.textContent = 'Voted';
            voteButton.classList.add('bg-gray-500');
            voteButton.classList.remove('bg-blue-600', 'hover:bg-blue-700');

            showNotification('Vote cast successfully', 'success');
        } else {
            showNotification(data.message, 'error');
        }
    } catch (error) {
        console.error('Error casting vote:', error);
        showNotification('Error casting vote', 'error');
    }
}

// Add this function to prevent double reviews
async function submitReview(candidateId, rating, comment) {
    try {
        const response = await fetch(`/elections/candidate/${candidateId}/reviews`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ rating, comment })
        });

        const data = await response.json();
        if (data.success) {
            showNotification('Review submitted successfully', 'success');
            await loadReviews(candidateId); // Reload reviews
            return true;
        } else {
            showNotification(data.message, 'error');
            return false;
        }
    } catch (error) {
        console.error('Error submitting review:', error);
        showNotification('Error submitting review', 'error');
        return false;
    }
}

// Search functionality is now handled in the Swiper initialization script below

// Function to show login message for unauthenticated users
function showLoginMessage() {
    showNotification('Please login to perform this action', 'error');
    setTimeout(() => {
        window.location.href = '/auth/login';
    }, 2000);
}
</script>

