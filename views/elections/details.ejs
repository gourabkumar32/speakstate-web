<!-- Add Swiper JS with optimized loading -->
<script src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js"></script>
<script>
  // Preload Swiper for better performance
  if (window.matchMedia('(max-width: 768px)').matches) {
    const preloadLink = document.createElement('link');
    preloadLink.rel = 'preload';
    preloadLink.as = 'script';
    preloadLink.href = 'https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js';
    document.head.appendChild(preloadLink);
  }
</script>

<!-- Initialize Swiper -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize Swiper for each constituency
    const swiperContainers = document.querySelectorAll('.candidate-swiper');
    
    swiperContainers.forEach(container => {
      new Swiper(container, {
        // Optional parameters with optimized settings for mobile
        slidesPerView: 1,
        spaceBetween: 10,
        loop: false, // Disable loop for better performance on mobile
        centeredSlides: false,
        grabCursor: true,
        effect: 'slide',
        preloadImages: false, // Don't preload all images
        lazy: true, // Enable lazy loading for images
        watchSlidesProgress: true,
        autoplay: {
          delay: 5000,
          disableOnInteraction: false,
          pauseOnMouseEnter: true
        },
        
        // Pagination with optimized settings
        pagination: {
          el: container.querySelector('.swiper-pagination'),
          clickable: true,
          dynamicBullets: true,
          dynamicMainBullets: 3,
          renderBullet: function (index, className) {
            return '<span class="' + className + '"></span>';
          }
        },
        
        // Navigation arrows
        navigation: {
          nextEl: container.querySelector('.swiper-button-next'),
          prevEl: container.querySelector('.swiper-button-prev'),
          hideOnClick: false,
        },
        
        // Enable touch events for mobile with better sensitivity
        touchEventsTarget: 'container',
        touchRatio: 1.5,
        touchAngle: 30,
        longSwipes: true,
        longSwipesRatio: 0.3,
        speed: 400, // Slightly faster transitions
        
        // Better handling of dynamic content
        observer: true,
        observeParents: true,
        
        // Responsive breakpoints - mobile first approach
        breakpoints: {
          // when window width is >= 640px (tablet)
          640: {
            slidesPerView: 2,
            spaceBetween: 15,
            centeredSlides: false,
            effect: 'slide',
          },
          // when window width is >= 768px (tablet)
          768: {
            slidesPerView: 2,
            spaceBetween: 20,
            effect: 'slide',
            centeredSlides: false,
          },
          // when window width is >= 1024px (laptop)
          1024: {
            slidesPerView: 3,
            spaceBetween: 25,
            centeredSlides: false,
            effect: 'slide',
          },
        },
        
        on: {
          init: function() {
            // Add a small delay to ensure proper layout calculation
            setTimeout(() => {
              this.update(); // Force Swiper to recalculate dimensions
            }, 100);
          }
        }
      });
    });
    
    // Optimize for mobile by pausing autoplay when page is not visible
    document.addEventListener('visibilitychange', function() {
      swiperContainers.forEach(container => {
        const swiperInstance = container.swiper;
        if (swiperInstance) {
          if (document.hidden) {
            swiperInstance.autoplay.stop();
          } else {
            swiperInstance.autoplay.start();
          }
        }
      });
    });
    
    // Update search functionality to work with Swiper
    document.getElementById('searchInput').addEventListener('input', function(e) {
      const searchTerm = e.target.value.toLowerCase();
      const constituencySections = document.querySelectorAll('.constituency-section');
      
      constituencySections.forEach(section => {
        const candidates = section.querySelectorAll('.candidate-card');
        let hasVisibleCandidates = false;
        
        candidates.forEach(card => {
          const candidateName = card.dataset.name;
          const cardConstituency = card.dataset.constituency;
          const slide = card.closest('.swiper-slide');
          
          if (candidateName.includes(searchTerm) || cardConstituency.includes(searchTerm)) {
            slide.style.display = '';
            hasVisibleCandidates = true;
          } else {
            slide.style.display = 'none';
          }
        });
        
        section.style.display = hasVisibleCandidates ? '' : 'none';
      });
      
      // Update Swiper instances after search
      swiperContainers.forEach(container => {
        const swiperInstance = container.swiper;
        if (swiperInstance) {
          swiperInstance.update();
        }
      });
    });
  });
</script>

