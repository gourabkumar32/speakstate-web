<%- include('../partials/header') %>

<style>
.container{
    margin-bottom: 50px;
}
.name{
    margin-bottom: 10px;
}

</style>

<div class="container mx-auto px-4 py-8">
    <div class="bg-white-800 rounded-lg shadow-lg overflow-hidden">
        <!-- Candidate Header -->
        <div class="p-6 flex flex-col md:flex-row items-center md:items-start gap-6">
            <div class="w-32 h-32 md:w-48 md:h-48 rounded-lg overflow-hidden flex-shrink-0">
                <img src="/uploads/candidates/<%= candidate.image %>" alt="<%= candidate.name %>" 
                     class="w-full h-full object-cover">
            </div>
            
            <div class="flex-grow text-center md:text-left">
                <h1 class="text-2xl md:text-3xl font-bold text-black mb-2"><%= candidate.name %></h1>
                <div class="flex flex-wrap gap-2 justify-center md:justify-start mb-4">
                    <span class="bg-blue-600 text-white px-3 py-1 rounded-full text-sm">
                        <%= candidate.party %>
                    </span>
                    <span class="bg-purple-600 text-white px-3 py-1 rounded-full text-sm">
                        <%= candidate.constituency %>
                    </span>
                    <% if (candidate.election) { %>
                    <span class="bg-green-600 text-white px-3 py-1 rounded-full text-sm">
                        <%= candidate.election.state %>
                    </span>
                    <% } %>
                </div>
                
                <% if (candidate.reviews && candidate.reviews.length > 0) { %>
                <div class="flex items-center justify-center md:justify-start mb-4">
                    <div class="flex">
                        <% for (let i = 1; i <= 5; i++) { %>
                            <% if (i <= Math.round(averageRating)) { %>
                                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                </svg>
                            <% } else { %>
                                <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                </svg>
                            <% } %>
                        <% } %>
                    </div>
                    <span class="ml-2"><span class="text-yellow-400 font-bold"><%= averageRating.toFixed(1) %></span> <span class="text-black-300">(<%= candidate.reviews.length %> reviews)</span></span>
                </div>
                <% } %>
                
                <div class="flex flex-wrap gap-2 justify-center md:justify-start">
                    <% if (!hasReviewed) { %>
                    <button onclick="showReviewModal()" class="bg-blue-600 hover:bg-blue-700 text-black px-4 py-2 rounded transition duration-200">
                        Add Review
                    </button>
                    <% } %>
                    <!--
                    <a href="/elections/<%= candidate.election._id %>" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded transition duration-200">
                        Back to Election
                    </a>
                    -->
                </div>
            </div>
        </div>
        
        <!-- Manifesto, Corruption Records, and Achievements -->
        <div class="p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 border-t border-gray-700">
            <!-- Manifesto -->
            <div class="bg-white-700 rounded-lg p-4">
                <h2 class="text-xl font-bold text-black mb-4">Manifesto</h2>
                <% if (candidate.manifesto && candidate.manifesto.length > 0 && candidate.manifesto.some(item => item)) { %>
                <ul class="list-disc pl-5 space-y-2 text-black">
                    <% candidate.manifesto.forEach(item => { %>
                    <% if (item) { %>
                    <li class="text-black">
                        <% if (item.includes('http')) { %>
                            <% 
                            // More robust URL extraction
                            const urlMatch = item.match(/https?:\/\/[^\s]+/); 
                            const url = urlMatch ? urlMatch[0] : '';
                            const textContent = url ? item.replace(url, '') : item;
                            %>
                            <%= textContent %> <a href="<%= url %>" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline"><%= url %></a>
                        <% } else { %>
                            <%= item %>
                        <% } %>
                    </li>
                    <% } %>
                    <% }); %>
                </ul>
                <% } else { %>
                <p class="text-black">No manifesto points available.</p>
                <% } %>
            </div>
            
            <!-- Achievements -->
            <div class="bg-white-700 rounded-lg p-4">
                <h2 class="text-xl font-bold text-black mb-4">Achievements & Work</h2>
                <% if (candidate.achievements && candidate.achievements.length > 0 && candidate.achievements.some(item => item)) { %>
                <ul class="list-disc pl-5 space-y-2 text-black">
                    <% candidate.achievements.forEach(item => { %>
                    <% if (item) { %>
                    <li class="text-black">
                        <% if (item.includes('http')) { %>
                            <% 
                            // More robust URL extraction
                            const urlMatch = item.match(/https?:\/\/[^\s]+/); 
                            const url = urlMatch ? urlMatch[0] : '';
                            const textContent = url ? item.replace(url, '') : item;
                            %>
                            <%= textContent %> <a href="<%= url %>" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline"><%= url %></a>
                        <% } else { %>
                            <%= item %>
                        <% } %>
                    </li>
                    <% } %>
                    <% }); %>
                </ul>
                <% } else { %>
                <p class="text-black">No achievements available.</p>
                <% } %>
            </div>

             <!-- Corruption Records -->
            <div class="bg-white-700 rounded-lg p-4">
                <h2 class="text-xl font-bold text-black mb-4">Controversies & Corruption-Related Allegations</h2>
                <% if (candidate.corruption && candidate.corruption.length > 0) { %>
                <ul class="list-disc pl-5 space-y-2 text-black">
                    <% candidate.corruption.forEach(item => { %>
                    <li class="text-black">
                        <% if (item.includes('http')) { %>
                            <% 
                            // More robust URL extraction
                            const urlMatch = item.match(/https?:\/\/[^\s]+/); 
                            const url = urlMatch ? urlMatch[0] : '';
                            const textContent = url ? item.replace(url, '') : item;
                            %>
                            <%= textContent %> <a href="<%= url %>" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline"><%= url %></a>
                        <% } else { %>
                            <%= item %>
                        <% } %>
                    </li>
                    <% }); %>
                </ul>
                <% } else { %>
                <p class="text-black">No corruption records available.</p>
                <% } %>
            </div>
        </div>
        
        <!-- Reviews Section -->
        <div class="p-6 border-t border-gray-700">
            <h2 class="text-xl font-bold text-purple mb-4">Reviews</h2>
            
            <% if (reviews && reviews.length > 0) { %>
            <div class="space-y-4">
                <% reviews.forEach(review => { %>
                <div class="bg-white-700 rounded-lg p-4">
                    <div class="flex justify-between items-start mb-2">
                        <div>
                            <% const isAnon = review.anonymous; %>
                            <% const reviewerName = review.displayName || (isAnon ? (review.anonymousName || (review.user && review.user.anonName) || 'Anonymous') : ((review.user && (review.user.anonName || review.user.name)) || 'Anonymous')); %>
                            <p class="name text-black-200 font-semibold"><%= reviewerName %></p>
                            <div class="flex mb-1">
                                
                                <div class="stars text-yellow-400">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <span class="star <%= i <= review.rating ? 'filled' : '' %> text-xl">
                                            <%= i <= review.rating ? '★' : '☆' %>
                                        </span>
                                    <% } %>
                                </div>
                            </div>
                            
                        </div>
                        <span class="text-black-400 text-sm">
                            <%= new Date(review.createdAt).toLocaleDateString() %>
                        </span>
                    </div>
                    <p class="text-black-300 border-gray-700"><%= review.comment %></p>
                </div>
                <hr class="border-gray-400">
                <% }); %>
            </div>
            <% } else { %>
            <p class="text-gray-400">No reviews yet. Be the first to review!</p>
            <% } %>
        </div>
    </div>
</div>

<!-- Review Modal -->
<div id="reviewModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50">
    <div class="bg-gray-800 rounded-lg max-w-lg mx-auto mt-20 p-6 border border-gray-700">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-bold text-white">Add Review</h3>
            <button onclick="closeReviewModal()" class="text-gray-400 hover:text-white">&times;</button>
        </div>
        <form id="reviewForm" class="space-y-4">
            <input type="hidden" name="candidateId" value="<%= candidate._id %>">
            <div>
                <label class="block text-gray-300 text-sm font-bold mb-2">Rating</label>
                <div class="flex space-x-2">
                    <% for (let i = 1; i <= 5; i++) { %>
                    <button type="button" onclick="setRating(<%= i %>)" class="rating-star text-gray-400 hover:text-yellow-400 focus:outline-none text-2xl" id="star-<%= i %>">
                        ☆
                    </button>
                    <% } %>
                </div>
                <input type="hidden" name="rating" id="ratingInput" value="0" required>
            </div>
            <div>
                <label class="block text-gray-300 text-sm font-bold mb-2">Comment</label>
                <textarea name="comment" rows="4" required
                          class="bg-gray-700 border border-gray-600 text-white rounded p-2 w-full"></textarea>
            </div>
            <button type="submit" id="submitReview"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded transition duration-200">
                Submit Review
            </button>
        </form>
    </div>
</div>


<style>
    .stars {
        display: flex;
        gap: 2px;
    }
    
    .star {
        cursor: pointer;
        transition: color 0.2s;
    }
    
    .star.filled {
        color: #ecc94b; /* yellow-400 */
    }
    
    .rating-star {
        font-size: 1.75rem;
        transition: color 0.2s, transform 0.1s;
    }
    
    .rating-star:hover {
        transform: scale(1.2);
    }
</style>

<script>

    // Hamburger Menu Logic
document.addEventListener('DOMContentLoaded', function() {
            
            // --- Hamburger Menu Logic ---
            const hamburger = document.getElementById('hamburger');
            const mobileMenu = document.getElementById('mobileMenu');
            const menuClose = document.getElementById('menuClose');

            // Check if the elements actually exist on the page before adding event listeners
            if (hamburger && mobileMenu && menuClose) {
                hamburger.addEventListener('click', () => {
                    mobileMenu.classList.remove('translate-x-full');
                });

                menuClose.addEventListener('click', () => {
                    mobileMenu.classList.add('translate-x-full');
                });
            }
            });
document.addEventListener('DOMContentLoaded', function() {
        
        // --- Hamburger Menu Logic ---
        const hamburger = document.getElementById('hamburger');
        const mobileMenu = document.getElementById('mobileMenu');
        const menuClose = document.getElementById('menuClose');

        // This checks if the menu elements exist before trying to use them.
        if (hamburger && mobileMenu && menuClose) {
            
            // Show the menu when hamburger is clicked
            hamburger.addEventListener('click', () => {
                mobileMenu.classList.remove('translate-x-full');
            });

            // Hide the menu when the close button is clicked
            menuClose.addEventListener('click', () => {
                mobileMenu.classList.add('translate-x-full');
            });
        }

    });

    
    // Rating functionality
    function setRating(rating) {
        document.getElementById('ratingInput').value = rating;
        
        // Update star characters and colors
        for (let i = 1; i <= 5; i++) {
            const star = document.getElementById('star-' + i);
            if (i <= rating) {
                star.textContent = '★';
                star.classList.remove('text-gray-400');
                star.classList.add('text-yellow-400');
            } else {
                star.textContent = '☆';
                star.classList.remove('text-yellow-400');
                star.classList.add('text-gray-400');
            }
        }
    }
    
    // Function to handle hover effect on stars
    function handleStarHover(index, isHovering) {
        for (let i = 1; i <= 5; i++) {
            const star = document.getElementById('star-' + i);
            if (isHovering && i <= index) {
                // When hovering, show filled star and gold color up to the hovered star
                star.textContent = '★';
                star.classList.remove('text-gray-400');
                star.classList.add('text-yellow-400');
            } else if (!isHovering) {
                // When not hovering, revert to the selected rating
                const currentRating = parseInt(document.getElementById('ratingInput').value) || 0;
                if (i <= currentRating) {
                    star.textContent = '★';
                    star.classList.remove('text-gray-400');
                    star.classList.add('text-yellow-400');
                } else {
                    star.textContent = '☆';
                    star.classList.remove('text-yellow-400');
                    star.classList.add('text-gray-400');
                }
            }
        }
    }
    
    // Initialize rating stars when the modal is shown
    document.addEventListener('DOMContentLoaded', function() {
        // Add click event listeners to all rating stars
        const stars = document.querySelectorAll('.rating-star');
        stars.forEach((star, index) => {
            // Click event to set the rating
            star.addEventListener('click', function() {
                setRating(index + 1);
            });
            
            // Mouse enter event to show hover effect
            star.addEventListener('mouseenter', function() {
                handleStarHover(index + 1, true);
            });
            
            // Mouse leave event to revert to selected rating
            star.addEventListener('mouseleave', function() {
                handleStarHover(0, false);
            });
        });

        // Initialize the rating stars color when the modal is shown
        document.getElementById('reviewModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeReviewModal();
            }
        });
    });
    
    // Show/hide review modal
    function showReviewModal() {
        document.getElementById('reviewModal').classList.remove('hidden');
    }
    
    function closeReviewModal() {
        document.getElementById('reviewModal').classList.add('hidden');
        document.getElementById('reviewForm').reset();
        
        // Reset star colors and characters when closing the modal
        for (let i = 1; i <= 5; i++) {
            const star = document.getElementById('star-' + i);
            star.textContent = '☆';
            star.classList.remove('text-yellow-400');
            star.classList.add('text-gray-400');
        }
        // Reset the rating input
        document.getElementById('ratingInput').value = 0;
        setRating(0);
    }
    
    // Submit review
    document.getElementById('reviewForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const submitBtn = document.getElementById('submitReview');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting...';
        
        try {
            const formData = new FormData(this);
            const response = await fetch(`/elections/candidate/${formData.get('candidateId')}/reviews`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    rating: formData.get('rating'),
                    comment: formData.get('comment')
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                // Reload page to show the new review
                window.location.reload();
            } else {
                alert(result.message || 'Error submitting review');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Submit Review';
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error submitting review');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit Review';
        }
    });
</script>

<%- include('../partials/footer') %>
